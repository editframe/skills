      />
    );
    
    expect(screen.getByText("Test Item")).toBeInTheDocument();
  });
});
```

## Test Utilities

```typescript
// ~/test/utils.ts
export const createAuthenticatedRequest = (
  url: string, 
  session: { userId: string; orgId: string }
) => {
  const request = new Request(url);
  // Mock session data
  (request as any).session = session;
  return request;
};

export const createRequestWithFormData = (
  data: Record<string, string>,
  session?: { userId: string; orgId: string }
) => {
  const formData = new FormData();
  Object.entries(data).forEach(([key, value]) => {
    formData.append(key, value);
  });
  
  const request = new Request("http://test", {
    method: "POST",
    body: formData
  });
  
  if (session) {
    (request as any).session = session;
  }
  
  return request;
};
```

## Running Tests

```bash
# Run all tests
npm test

# Run specific test file
npm test path/to/test-file.test.ts

# Run tests in watch mode
npm test -- --watch

# Run browser tests
npm run browsertest

# Run specific browser test
npm run browsertest -- path/to/browser-test.browsertest.ts

# Run tests with coverage
npm test -- --coverage
```

## Best Practices

1. **Write tests that fail first** before implementing features
2. **Test behavior, not implementation** details
3. **Use specific file paths** when referencing tests
4. **Mock external dependencies** appropriately
5. **Test both happy and error paths**
6. **Keep tests focused and isolated**
7. **Use descriptive test names** that explain the scenario
8. **Clean up test data** between test runs
9. **Test accessibility** where relevant
10. **Verify all existing tests pass** after changes

## Test Organization

- Place tests next to the files they test: `Component.test.tsx`
- Use `describe` blocks to group related tests
- Use `beforeEach`/`afterEach` for setup/cleanup
- Keep test files focused on a single component/function
- Use meaningful variable names in tests
- Follow the Arrange-Act-Assert pattern
