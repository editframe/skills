#!/usr/bin/env bash
# Verification script for elements worktree Docker environment setup

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

echo "🔍 Verifying Elements worktree Docker environment setup..."
echo ""

# Source worktree configuration
echo "1. Testing worktree-config script..."
if ! . "$SCRIPT_DIR/worktree-config"; then
  echo "❌ ERROR: Failed to source worktree-config"
  exit 1
fi
echo "✅ worktree-config loaded successfully"
echo ""

# Display detected configuration
echo "2. Detected worktree configuration:"
echo "   Branch: $WORKTREE_BRANCH"
echo "   Domain: $WORKTREE_DOMAIN"
echo "   Docker Project: $WORKTREE_DOCKER_PROJECT_NAME"
echo "   Docker Network: $WORKTREE_DOCKER_NETWORK_NAME"
echo "   Worktree ID: $WORKTREE_ID"
echo ""

# Verify variables are set
echo "3. Verifying required environment variables..."
MISSING_VARS=()
[ -z "$WORKTREE_DOMAIN" ] && MISSING_VARS+=("WORKTREE_DOMAIN")
[ -z "$WORKTREE_DOCKER_PROJECT_NAME" ] && MISSING_VARS+=("WORKTREE_DOCKER_PROJECT_NAME")
[ -z "$WORKTREE_DOCKER_NETWORK_NAME" ] && MISSING_VARS+=("WORKTREE_DOCKER_NETWORK_NAME")

if [ ${#MISSING_VARS[@]} -gt 0 ]; then
  echo "❌ ERROR: Missing required variables: ${MISSING_VARS[*]}"
  exit 1
fi
echo "✅ All required variables are set"
echo ""

# Verify Traefik network exists
echo "4. Verifying shared Traefik network..."
if ! docker network inspect telecine-traefik > /dev/null 2>&1; then
  echo "⚠️  WARNING: Shared Traefik network 'telecine-traefik' does not exist"
  echo "   It will be created automatically when telecine Traefik starts"
  echo "   Or create manually: docker network create telecine-traefik"
else
  echo "✅ Shared Traefik network exists"
fi
echo ""

# Verify docker-compose script
echo "5. Verifying docker-compose script..."
if [ ! -f "$SCRIPT_DIR/docker-compose" ]; then
  echo "❌ ERROR: docker-compose script not found"
  exit 1
fi
if [ ! -x "$SCRIPT_DIR/docker-compose" ]; then
  echo "⚠️  WARNING: docker-compose script is not executable"
fi
echo "✅ docker-compose script found"
echo ""

# Test docker-compose can validate configuration
echo "6. Testing docker-compose configuration..."
if "$SCRIPT_DIR/docker-compose" config > /dev/null 2>&1; then
  echo "✅ docker-compose configuration is valid"
else
  echo "❌ ERROR: docker-compose configuration has errors"
  "$SCRIPT_DIR/docker-compose" config
  exit 1
fi
echo ""

# Check if dev-projects service has Traefik labels
echo "7. Checking Traefik labels on dev-projects service..."
COMPOSE_CONFIG=$("$SCRIPT_DIR/docker-compose" config)
if echo "$COMPOSE_CONFIG" | grep -q "traefik.enable: true"; then
  echo "✅ Traefik labels found on dev-projects service"
  if echo "$COMPOSE_CONFIG" | grep -q "traefik.http.routers.elements-dev"; then
    echo "✅ Traefik router configuration found"
  else
    echo "⚠️  WARNING: Traefik router configuration may be missing"
  fi
else
  echo "❌ ERROR: Traefik labels missing on dev-projects service"
  exit 1
fi
echo ""

# Check for .localhost domain support on macOS
echo "8. Checking domain resolution..."
if [[ "$OSTYPE" == "darwin"* ]]; then
  if command -v dscacheutil > /dev/null 2>&1; then
    echo "✅ macOS detected - .localhost domains automatically resolve to 127.0.0.1"
    echo "   Test with: ping $WORKTREE_DOMAIN"
  else
    echo "⚠️  WARNING: macOS utilities not found"
  fi
else
  echo "⚠️  NOTE: Not macOS - .localhost domains may need manual DNS configuration"
fi
echo ""

# Check if Traefik is running (optional check)
echo "9. Checking Traefik status..."
if docker ps --format '{{.Names}}' | grep -q traefik; then
  echo "✅ Traefik container is running"
  TRAEFIK_PORT=$(docker port $(docker ps --format '{{.Names}}' | grep traefik | head -1) 2>/dev/null | grep 4321 || echo "")
  if [ -n "$TRAEFIK_PORT" ]; then
    echo "✅ Traefik port 4321 is exposed"
  else
    echo "⚠️  WARNING: Traefik may not have port 4321 exposed (check telecine Traefik config)"
  fi
else
  echo "⚠️  NOTE: Traefik container not running (start it in telecine main worktree)"
fi
echo ""

# Summary
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Verification complete!"
echo ""
echo "Next steps:"
echo "1. Ensure Traefik is running in telecine main worktree (with port 4321 entrypoint)"
echo "2. Start elements services: ${SCRIPT_DIR}/start"
echo "3. Access dev server at: http://${WORKTREE_DOMAIN}:4321"
echo ""
if [ "$WORKTREE_DOMAIN" != "main.localhost" ] && [ "$WORKTREE_DOMAIN" != "localhost" ]; then
  echo "📝 For Cursor worktree support:"
  echo "   - Worktree domain: $WORKTREE_DOMAIN"
  echo "   - Dev server accessible at: http://$WORKTREE_DOMAIN:4321"
  echo "   - Docker project name: $WORKTREE_DOCKER_PROJECT_NAME"
fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

