#!/usr/bin/env bash
# Manual one-off deploy of the GPU render-fragment worker to Cloud Run.
# Bypasses Pulumi for rapid iteration on GPU/EGL/NVENC compatibility.
#
# Usage:
#   telecine/scripts/deploy-gpu-worker-manual [--skip-build]
#
# Options:
#   --skip-build   Skip docker build+push, re-deploy the existing image tag.

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

set -euo pipefail

SKIP_BUILD=0
for arg in "$@"; do
  case $arg in
    --skip-build) SKIP_BUILD=1 ;;
  esac
done

REPO=us-central1-docker.pkg.dev/editframe/telecine-artifacts
SERVICE_NAME=telecine-worker-render-fragment-gpu
REGION=us-central1
PROJECT=editframe
IMAGE_NAME=worker-render-fragment-gpu
GIT_SHA=$(git -C "${SCRIPT_DIR}" rev-parse HEAD 2>/dev/null || echo "latest")
IMAGE="${REPO}/${IMAGE_NAME}:${GIT_SHA}"

if [ "$SKIP_BUILD" -eq 0 ]; then
  echo "==> Building image..."
  "${SCRIPT_DIR}/build-docker-prod" "${IMAGE_NAME}"

  echo "==> Pushing image..."
  docker push "${IMAGE}"
else
  echo "==> Skipping build, using image: ${IMAGE}"
fi

echo "==> Deploying ${SERVICE_NAME} to Cloud Run..."
gcloud run deploy "${SERVICE_NAME}" \
  --project="${PROJECT}" \
  --region="${REGION}" \
  --image="${IMAGE}" \
  --platform=managed \
  --no-allow-unauthenticated \
  --ingress=internal \
  --service-account=telecine-queues@editframe.iam.gserviceaccount.com \
  --min-instances=0 \
  --max-instances=2 \
  --concurrency=8 \
  --cpu=8 \
  --memory=32Gi \
  --gpu=1 \
  --gpu-type=nvidia-l4 \
  --no-gpu-zonal-redundancy \
  --no-cpu-throttling \
  --add-cloudsql-instances=editframe:us-central1:telecine-db-16cb105 \
  --vpc-egress=private-ranges-only \
  --network=default \
  --subnet=default \
  --set-secrets="\
APPLICATION_SECRET=application-secret:2,\
ACTION_SECRET=action-secret:2,\
HASURA_JWT_SECRET=jwt-secret:2,\
APPLICATION_JWT_SECRET=app-jwt-secret:1,\
POSTGRES_PASSWORD=hasura-db-password:1" \
  --set-env-vars="\
WORKER_MODE=websocket,\
NODE_ENV=production,\
POSTGRES_MIN_CONNECTIONS=1,\
POSTGRES_MAX_CONNECTIONS=1,\
POSTGRES_USER=hasura,\
POSTGRES_DB=telecine-prod,\
POSTGRES_HOST=/cloudsql/editframe:us-central1:telecine-db-16cb105,\
VALKEY_HOST=10.128.0.50,\
VALKEY_PORT=6379,\
STORAGE_BUCKET=telecine-dot-dev-data-4fedc83,\
PUBLIC_STORAGE_BUCKET=editframe-assets,\
HASURA_SERVER_URL=https://editframe.com/v1/graphql,\
VITE_HASURA_CLIENT_URL=https://editframe.com/v1/graphql,\
WEB_HOST=https://editframe.com,\
RENDER_HOST=https://editframe.com,\
ENABLE_ALL_FEATURES=false,\
UPLOAD_TO_BUCKET=true,\
GCLOUD_TRACE_EXPORT=true,\
PINO_LOG_LEVEL=debug,\
INGEST_IMAGE_MAX_WORKER_COUNT=10,\
INGEST_IMAGE_WORKER_CONCURRENCY=20,\
PROCESS_HTML_FINALIZER_MAX_WORKER_COUNT=10,\
PROCESS_HTML_FINALIZER_WORKER_CONCURRENCY=20,\
PROCESS_HTML_INITIALIZER_MAX_WORKER_COUNT=20,\
PROCESS_HTML_INITIALIZER_WORKER_CONCURRENCY=1,\
PROCESS_ISOBMFF_MAX_WORKER_COUNT=20,\
PROCESS_ISOBMFF_WORKER_CONCURRENCY=5,\
RENDER_INITIALIZER_MAX_WORKER_COUNT=10,\
RENDER_INITIALIZER_WORKER_CONCURRENCY=2,\
RENDER_FRAGMENT_MAX_WORKER_COUNT=200,\
RENDER_FRAGMENT_WORKER_CONCURRENCY=1,\
RENDER_FRAGMENT_GPU_MAX_WORKER_COUNT=2,\
RENDER_FRAGMENT_GPU_WORKER_CONCURRENCY=8,\
RENDER_FINALIZER_MAX_WORKER_COUNT=10,\
RENDER_FINALIZER_WORKER_CONCURRENCY=20"

echo ""
echo "==> Done. Service URL:"
gcloud run services describe "${SERVICE_NAME}" \
  --project="${PROJECT}" \
  --region="${REGION}" \
  --format="value(status.url)"
