#!/usr/bin/env bash
set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Check if we have a TTY
if [ -t 0 ]; then
    INTERACTIVE_FLAGS="-it"
else
    INTERACTIVE_FLAGS=""
fi

# Check if runner service is already running
RUNNER_CONTAINER=$(${SCRIPT_DIR}/docker-compose ps -q runner 2>/dev/null)
if [ -n "$RUNNER_CONTAINER" ] && docker inspect "$RUNNER_CONTAINER" --format='{{.State.Status}}' 2>/dev/null | grep -q "running"; then
    # Service is running, exec into the specific container
    # Filter out Docker Debug promotional messages from stderr
    if [ -t 0 ]; then
        # TTY mode: filter stderr but preserve TTY
        docker exec --env EF_CACHE_ONLY="$EF_CACHE_ONLY" --env WORKTREE_DOMAIN="$WORKTREE_DOMAIN" --env MONOREPO_ROOT="$MONOREPO_ROOT" --env WS_ENDPOINT="$WS_ENDPOINT" --env VITEST_BROWSER_MODE="$VITEST_BROWSER_MODE" $INTERACTIVE_FLAGS "$RUNNER_CONTAINER" "$@" 2> >(grep -v "What's next:" | grep -v "Try Docker Debug" | grep -v "Learn more at" >&2)
    else
        # Non-TTY mode: filter both stdout and stderr
        docker exec --env EF_CACHE_ONLY="$EF_CACHE_ONLY" --env WORKTREE_DOMAIN="$WORKTREE_DOMAIN" --env MONOREPO_ROOT="$MONOREPO_ROOT" --env WS_ENDPOINT="$WS_ENDPOINT" --env VITEST_BROWSER_MODE="$VITEST_BROWSER_MODE" $INTERACTIVE_FLAGS "$RUNNER_CONTAINER" "$@" 2>&1 | grep -v "What's next:" | grep -v "Try Docker Debug" | grep -v "Learn more at"
    fi
else
    # Service not running, start new ephemeral container
    "${SCRIPT_DIR}"/docker-compose run --rm $INTERACTIVE_FLAGS -e EF_CACHE_ONLY="$EF_CACHE_ONLY" -e WORKTREE_DOMAIN="$WORKTREE_DOMAIN" -e MONOREPO_ROOT="$MONOREPO_ROOT" -e WS_ENDPOINT="$WS_ENDPOINT" -e VITEST_BROWSER_MODE="$VITEST_BROWSER_MODE" runner "$@"
fi