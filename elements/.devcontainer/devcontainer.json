{
  "name": "Node Container",
  "dockerComposeFile": ["../docker-compose.yaml"],
  "service": "runner",
  "shutdownAction": "none",
  "workspaceFolder": "/packages",
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "biomejs.biome",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh",
            "icon": "terminal-bash"
          }
        }
      }
    }
  }
}
