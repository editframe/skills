#!/usr/bin/env bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

cd "$PROJECT_ROOT"

BRANCH="main"

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --branch)
      BRANCH="$2"
      shift 2
      ;;
    *)
      BRANCH="$1"
      shift
      ;;
  esac
done

# The telecine sync commits and deploys HEAD:telecine to production.
# Running from any branch other than main risks deploying an incomplete
# telecine tree that is missing changes already on main.
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" != "main" ]; then
  echo "error: push-skills must be run from main (current branch: $CURRENT_BRANCH)"
  echo "The telecine sync deploys HEAD:telecine to production -- running from a"
  echo "feature branch will overwrite production with an incomplete tree."
  exit 1
fi

BUILD_DIR="$PROJECT_ROOT/skills/skills-generated"

# Clean and generate LLM-optimized skills
echo "🧹 Cleaning build directory..."
rm -rf "$BUILD_DIR"

echo "🔨 Generating LLM-optimized skills..."
npx tsx scripts/generate-skills.ts

# Initialize a temporary git repo in the build directory
echo "📦 Preparing build for push..."
cd "$BUILD_DIR"
git init
git add .
git commit -m "Generated LLM-optimized skills from source"

# Add the skills remote if it doesn't exist
if ! git remote get-url skills &> /dev/null; then
  SKILLS_REMOTE=$(cd "$PROJECT_ROOT" && git remote get-url skills)
  git remote add skills "$SKILLS_REMOTE"
fi

# Push to the skills remote
echo "🚀 Pushing to skills remote ($BRANCH branch)..."
git push skills HEAD:"$BRANCH" --force

# Clean up
cd "$PROJECT_ROOT"
rm -rf "$BUILD_DIR"

echo "✅ Successfully pushed generated skills to skills remote ($BRANCH branch)"

# Sync source files into telecine subtree for production deployment
echo "🔄 Syncing skills into telecine subtree..."
rsync -a --delete "$PROJECT_ROOT/skills/skills/" "$PROJECT_ROOT/telecine/skills/skills/"

if ! git diff --quiet telecine/skills/; then
  git add telecine/skills/
  git commit -m "sync skills into telecine subtree"
  "$SCRIPT_DIR/push-telecine"
else
  echo "telecine/skills already up to date"
fi
