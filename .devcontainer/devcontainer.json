{
  "name": "Monorepo Dev Container",
  "dockerComposeFile": "../docker-compose.devcontainer.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true,
      "username": "vscode",
      "uid": "1000",
      "gid": "1000"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "typescript.preferences.useAliasesForRenames": false,
        "typescript.preferences.importModuleSpecifier": "relative",
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        }
      }
    }
  },
  "forwardPorts": [
    3000,
    3001,
    4321,
    63315,
    6432,
    6379,
    7777,
    8025,
    8080,
    8794,
    24678
  ],
  "postStartCommand": "bash -c 'cd telecine && . scripts/worktree-config && echo \"Worktree: $WORKTREE_DOMAIN\"'",
  "portsAttributes": {
    "3000": {
      "label": "Web (Telecine)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Web Alt (Telecine)",
      "onAutoForward": "silent"
    },
    "4321": {
      "label": "Dev Projects (Elements)",
      "onAutoForward": "silent"
    },
    "63315": {
      "label": "Test Server (Elements)",
      "onAutoForward": "silent"
    },
    "6432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Valkey",
      "onAutoForward": "silent"
    },
    "7777": {
      "label": "Traefik Dashboard",
      "onAutoForward": "silent"
    },
    "8025": {
      "label": "MailHog UI",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "GraphQL Engine",
      "onAutoForward": "silent"
    },
    "8794": {
      "label": "Record-Replay Proxy",
      "onAutoForward": "silent"
    },
    "24678": {
      "label": "Web Port 24678",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.cursor-worktrees,target=/workspace/.cursor-worktrees,type=bind,consistency=cached"
  ]
}