#!/usr/bin/env bash
# Pull changes from elements remote into the monorepo's elements/ subtree.
# Use this when changes were merged directly to elements/main outside the monorepo.

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

cd "$PROJECT_ROOT"

BRANCH="main"

while [[ $# -gt 0 ]]; do
  case $1 in
    --branch)
      BRANCH="$2"
      shift 2
      ;;
    *)
      BRANCH="$1"
      shift
      ;;
  esac
done

git subtree pull --prefix=elements elements "$BRANCH" --squash 2>&1

echo "pulled elements/${BRANCH} -> elements/"
