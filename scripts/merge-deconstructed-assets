#!/bin/bash
set -e

# Script to merge deconstructed media assets using ffmpeg
# Takes track files from services/web/public/assets/<name>/ directories
# and merges them into complete files in the top-level assets folder

ASSETS_DIR="/Users/collin/Editframe/telecine/services/web/public/assets"
cd "$ASSETS_DIR"

echo "🔍 Looking for deconstructed asset directories..."

# Find all directories that end with media extensions
for dir in *.mp3 *.mp4 *.webm *.mov; do
    if [ -d "$dir" ]; then
        echo "📁 Processing directory: $dir"
        
        # Get the base filename (remove extension from directory name)
        base_name="$dir"
        
        # Look for track files in the directory
        track_files=()
        video_track=""
        audio_track=""
        
        cd "$dir"
        
        # Find all track files
        for track_file in *.track-*.mp4; do
            if [ -f "$track_file" ]; then
                echo "  📄 Found track file: $track_file"
                track_files+=("$track_file")
                
                # Determine if this is video or audio track based on file size
                # (This is a heuristic - video tracks are typically larger)
                file_size=$(stat -f%z "$track_file" 2>/dev/null || stat -c%s "$track_file" 2>/dev/null)
                
                if [ -z "$video_track" ] || [ "$file_size" -gt "$(stat -f%z "$video_track" 2>/dev/null || stat -c%s "$video_track" 2>/dev/null || echo 0)" ]; then
                    if [ -n "$video_track" ]; then
                        audio_track="$video_track"
                    fi
                    video_track="$track_file"
                elif [ -z "$audio_track" ]; then
                    audio_track="$track_file"
                fi
            fi
        done
        
        if [ ${#track_files[@]} -eq 0 ]; then
            echo "  ⚠️  No track files found in $dir, skipping..."
            cd ..
            continue
        fi
        
        echo "  🎬 Video track: ${video_track:-none}"
        echo "  🎵 Audio track: ${audio_track:-none}"
        
        # Build ffmpeg command based on available tracks
        # Create temporary output file first, then we'll move it
        # Keep the same extension as the original for proper format detection
        temp_output="${base_name}.temp"
        final_output="$base_name"
        
        if [ -n "$video_track" ] && [ -n "$audio_track" ]; then
            # Both video and audio tracks
            echo "  🔧 Merging video and audio tracks..."
            if [[ "$base_name" == *.mp4 ]]; then
                ffmpeg -y -i "$video_track" -i "$audio_track" -f mp4 -c copy -map 0:v:0 -map 1:a:0 "$temp_output"
            else
                ffmpeg -y -i "$video_track" -i "$audio_track" -c copy -map 0:v:0 -map 1:a:0 "$temp_output"
            fi
        elif [ -n "$video_track" ]; then
            # Video only (but might actually be audio in an MP4 container)
            echo "  🔧 Copying track..."
            # Check if this is actually audio content based on the directory name
            if [[ "$base_name" == *.mp3 ]]; then
                # Convert MP4 container with AAC to MP3
                # Use explicit format specification
                ffmpeg -y -i "$video_track" -f mp3 -c:a libmp3lame -b:a 128k "$temp_output"
            else
                # Regular video/MP4 content
                if [[ "$base_name" == *.mp4 ]]; then
                    ffmpeg -y -i "$video_track" -f mp4 -c copy "$temp_output"
                else
                    ffmpeg -y -i "$video_track" -c copy "$temp_output"
                fi
            fi
        elif [ -n "$audio_track" ]; then
            # Audio only
            echo "  🔧 Copying audio track..."
            ffmpeg -y -i "$audio_track" -c copy "$temp_output"
        else
            # Multiple tracks - try to merge all
            echo "  🔧 Merging multiple tracks..."
            input_args=""
            map_args=""
            for i in "${!track_files[@]}"; do
                input_args="$input_args -i ${track_files[$i]}"
                map_args="$map_args -map $i"
            done
            ffmpeg -y $input_args -c copy $map_args "$temp_output"
        fi
        
        if [ $? -eq 0 ]; then
            echo "  ✅ Successfully created temporary file: $temp_output"
            
            # Verify the temporary file exists
            if [ -f "$temp_output" ]; then
                echo "  📦 Moving merged file to: $final_output"
                mv "$temp_output" "$final_output"
                
                # Go back to parent directory to remove the source directory
                cd ..
                echo "  🗑️  Removing directory: $dir"
                rm -rf "$dir"
                
                # Verify the output file
                if [ -f "$final_output" ]; then
                    file_size=$(stat -f%z "$final_output" 2>/dev/null || stat -c%s "$final_output" 2>/dev/null)
                    # Convert bytes to human readable format
                    if [ "$file_size" -gt 1048576 ]; then
                        size_mb=$((file_size / 1048576))
                        echo "  📊 Output file size: ${size_mb}MB"
                    elif [ "$file_size" -gt 1024 ]; then
                        size_kb=$((file_size / 1024))
                        echo "  📊 Output file size: ${size_kb}KB"
                    else
                        echo "  📊 Output file size: ${file_size}B"
                    fi
                    
                    # Show basic info about the merged file
                    echo "  ℹ️  File info:"
                    ffprobe -v quiet -show_format -show_streams "$final_output" | grep -E "(codec_name|width|height|duration|bit_rate)" | head -10 | sed 's/^/    /'
                fi
            else
                echo "  ❌ Temporary file not found: $temp_output"
                cd ..
            fi
        else
            echo "  ❌ Failed to create: $temp_output"
            cd ..
        fi
        
        echo ""
    fi
done

echo "🎉 Asset merging complete!"
echo ""
echo "📋 Summary of merged files:"
ls -lh *.mp3 *.mp4 *.webm *.mov 2>/dev/null | grep -v "^d" | awk '{print "  " $9 " (" $5 ")"}'

echo ""
echo "🗂️  Deconstructed directories (can be removed after verification):"
ls -d *.mp3 *.mp4 *.webm *.mov 2>/dev/null | grep -E "\.(mp3|mp4|webm|mov)$" | while read dir; do
    if [ -d "$dir" ]; then
        echo "  $dir/"
    fi
done
