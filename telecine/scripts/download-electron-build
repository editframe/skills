#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Download to telecine/.editframe-downloads/ (Docker build context)
TELECINE_DIR="${SCRIPT_DIR}/.."
DOWNLOAD_DIR="${TELECINE_DIR}/.editframe-downloads"
mkdir -p "$DOWNLOAD_DIR"

# Check if the file exists, if not, download it
ELECTRON_VERSION="${1:-v40.1.0-dmabuf}"
ELECTRON_BUILD_FILE="$DOWNLOAD_DIR/editframe-${ELECTRON_VERSION}.zip"

if [ ! -f "$ELECTRON_BUILD_FILE" ]; then
    echo "Downloading Electron build (${ELECTRON_VERSION})..."
    gcloud storage cp "gs://editframe-electron-builds/editframe-${ELECTRON_VERSION}.zip" "$ELECTRON_BUILD_FILE"
    echo "Download complete."
fi

echo "$ELECTRON_BUILD_FILE"