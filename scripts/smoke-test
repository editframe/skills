#!/usr/bin/env bash
# Run smoke tests against a worktree's render pipeline.
# Temporarily starts render services if the worktree is at web scope,
# runs renders (visible in the dashboard), then stops render services.
#
# Usage: smoke-test <branch>

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

if [ -z "$1" ]; then
  echo "Usage: $0 <branch>" >&2
  exit 1
fi

BRANCH_NAME="$1"

# Find worktree for this branch
WORKTREE_ROOT=""
while IFS= read -r line; do
  if [[ "$line" =~ ^worktree[[:space:]]+(.+)$ ]]; then
    WORKTREE_ROOT="${BASH_REMATCH[1]}"
  elif [[ "$line" =~ ^branch[[:space:]]+refs/heads/(.+)$ ]]; then
    if [ "${BASH_REMATCH[1]}" = "$BRANCH_NAME" ]; then
      break
    fi
    WORKTREE_ROOT=""
  fi
done < <(git worktree list --porcelain)

if [ -z "$WORKTREE_ROOT" ]; then
  echo "error: no worktree for branch '$BRANCH_NAME'" >&2
  exit 1
fi

# WORKTREE_ROOT is the monorepo worktree (worktrees/<branch>/monorepo).
# The worktree container dir (with telecine/, elements/, .worktree-scope) is one level up.
WORKTREE_DIR=$(dirname "$WORKTREE_ROOT")

# Check scope — needs at least web scope (telecine services must be running)
SCOPE="elements"
if [ -f "$WORKTREE_DIR/.worktree-scope" ]; then
  SCOPE=$(cat "$WORKTREE_DIR/.worktree-scope")
fi

if [ "$SCOPE" = "elements" ]; then
  echo "error: smoke-test requires web or render scope (current: elements)" >&2
  echo "       scripts/upgrade-worktree $BRANCH_NAME web" >&2
  exit 1
fi

# Derive domain and Docker project name — mirrors telecine/scripts/worktree-config
sanitize_branch() {
  local n="$1"
  n=$(echo "$n" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/^-\+//; s/-\+$//; s/-\+/-/g' | cut -c1-63 | sed 's/-$//')
  echo "$n"
}

SANITIZED=$(sanitize_branch "$BRANCH_NAME")
WORKTREE_DOMAIN="${SANITIZED}.localhost"
DOCKER_PROJECT="telecine-${SANITIZED}"

TELECINE_DIR="$WORKTREE_DIR/telecine"
MAIN_ROOT="$SCRIPT_DIR/.."

# Ensure scheduler-go image exists — it's a pre-built Go binary not handled by docker-compose build
if ! docker image inspect scheduler-go > /dev/null 2>&1; then
  echo "building scheduler-go image (first run)..."
  docker build \
    -f "$MAIN_ROOT/telecine/services/scheduler-go/Dockerfile.dev" \
    -t scheduler-go \
    "$MAIN_ROOT/telecine/services/scheduler-go" > /dev/null 2>&1
fi

# Get EF_TOKEN stored in elements/.env during worktree creation
EF_TOKEN=$(grep "^EF_TOKEN=" "$WORKTREE_DIR/elements/.env" 2>/dev/null | head -1 | sed 's/^EF_TOKEN=//; s/^"//; s/"$//')

if [ -z "$EF_TOKEN" ]; then
  echo "error: EF_TOKEN not found in $WORKTREE_DIR/elements/.env" >&2
  exit 1
fi

STARTED_RENDER=false

stop_render_services() {
  echo ""
  echo "stopping render services..."
  local render_only
  render_only=$(comm -23 \
    <(cd "$TELECINE_DIR" && COMPOSE_PROFILES="render" ./scripts/docker-compose config --services 2>/dev/null | sort) \
    <(cd "$TELECINE_DIR" && COMPOSE_PROFILES="" ./scripts/docker-compose config --services 2>/dev/null | sort))
  if [ -n "$render_only" ]; then
    # shellcheck disable=SC2086
    cd "$TELECINE_DIR" && ./scripts/docker-compose stop $render_only > /dev/null 2>&1 || true
  fi
}

cleanup() {
  if [ "$STARTED_RENDER" = "true" ]; then
    stop_render_services
  fi
}

trap cleanup EXIT INT TERM

# Start render services if the worktree is only at web scope
if [ "$SCOPE" = "web" ]; then
  echo "starting render services for $BRANCH_NAME..."
  cd "$TELECINE_DIR"
  COMPOSE_PROFILES="render" ./scripts/docker-compose up -d > /dev/null 2>&1
  STARTED_RENDER=true
fi

echo ""
echo "smoke tests: $BRANCH_NAME"
echo ""

# Run smoke-test.ts inside the runner container.
# EF_HOST uses the container-network address so no dependency on Traefik routing.
# The loader.js bootstraps ts-node/esm with tsconfig-paths resolution — same
# pattern used by other container-side TS scripts.
SMOKE_EXIT=0
cd "$TELECINE_DIR"
./scripts/docker-compose exec \
  -T \
  -e EF_TOKEN="$EF_TOKEN" \
  -e EF_HOST="http://web:3000" \
  runner node \
  --import 'data:text/javascript,import { register } from "node:module"; import { pathToFileURL } from "node:url"; register("./loader.js", pathToFileURL("./"));' \
  scripts/smoke-test.ts \
  || SMOKE_EXIT=$?

echo ""
if [ $SMOKE_EXIT -eq 0 ]; then
  echo "all tests passed"
else
  echo "some tests failed"
fi

echo ""
echo "dashboard: http://${WORKTREE_DOMAIN}:3000"
echo ""

if [ "$STARTED_RENDER" = "true" ]; then
  printf "press enter to stop render services: "
  read -r
fi

exit $SMOKE_EXIT
