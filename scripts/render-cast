#!/usr/bin/env node
// Renders a .cast file to mp4 via headless Chromium + asciinema-player.
//
// Usage: node scripts/render-cast [options] input.cast [output.mp4]
//
// Options:
//   --title TEXT        Window title bar text (default: from cast filename)
//   --theme NAME        asciinema theme (default: monokai)
//   --font-px N         Terminal font size in px (default: 14)
//   --idle-limit SECS   Compress idle gaps longer than N seconds (default: 3)
//   --cols N            Override cols (default: from cast header)
//   --rows N            Override rows (default: from cast header)
//   --width N           Output video width (fullbleed mode, no window chrome)
//   --height N          Output video height (fullbleed mode, no window chrome)
//   --player-dir PATH   Path to asciinema-player bundle dir
//                       (default: /tmp/ap-pkg/node_modules/asciinema-player/dist/bundle)

import { chromium } from "playwright";
import { spawnSync } from "node:child_process";
import { mkdirSync, readdirSync, readFileSync } from "node:fs";
import { resolve, basename } from "node:path";
import { tmpdir } from "node:os";

// --- arg parsing ---
const argv = process.argv.slice(2);
const flags = {};
const positionals = [];
for (let i = 0; i < argv.length; i++) {
  if (argv[i].startsWith("--")) {
    flags[argv[i].slice(2)] = argv[++i];
  } else {
    positionals.push(argv[i]);
  }
}

const castFile  = resolve(positionals[0] ?? "/tmp/out.cast");
const outFile   = resolve(positionals[1] ?? castFile.replace(/\.cast$/, ".mp4"));
const videoDir  = `${tmpdir()}/cast-render-${Date.now()}`;

mkdirSync(videoDir, { recursive: true });

const castData  = readFileSync(castFile, "utf8");
const header    = JSON.parse(castData.split("\n")[0]);

const cols      = parseInt(flags["cols"]       ?? header.width  ?? 100);
const rows      = parseInt(flags["rows"]       ?? header.height ?? 28);
const fontPx    = parseInt(flags["font-px"]    ?? 14);
const idleLimit = parseFloat(flags["idle-limit"] ?? 3);
const theme     = flags["theme"]               ?? "monokai";
const title     = flags["title"]               ?? basename(castFile, ".cast");
const playerDir = flags["player-dir"]          ?? "/tmp/ap-pkg/node_modules/asciinema-player/dist/bundle";
const outWidth  = flags["width"]  ? parseInt(flags["width"])  : null;
const outHeight = flags["height"] ? parseInt(flags["height"]) : null;
const fullbleed = outWidth != null && outHeight != null;

// Accumulate effective playback duration with idle clamping
let wallTime = 0;
for (const line of castData.trim().split("\n").filter((l) => l.startsWith("["))) {
  wallTime += Math.min(JSON.parse(line)[0], idleLimit);
}
const castDuration = Math.ceil(wallTime) + 8;

// Sanitize cast data for safe embedding inside a <script> tag:
// </script> sequences must be escaped so they don't terminate the enclosing script block.
const castDataSafe = JSON.stringify(castData).replace(/<\/script>/gi, "<\\/script>");

const playerJs  = readFileSync(`${playerDir}/asciinema-player.min.js`, "utf8");
const playerCss = readFileSync(`${playerDir}/asciinema-player.css`, "utf8");

// --- Layout ---
let vpW, vpH, html;

if (fullbleed) {
  // Full-bleed mode: terminal fills the entire frame, no window chrome
  vpW = outWidth;
  vpH = outHeight;
  html = `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    ${playerCss}
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: ${vpW}px; height: ${vpH}px; overflow: hidden; background: #0d1117; }
    #player { width: 100%; height: 100%; }
    .ap-player { --term-font-size: ${fontPx}px !important; width: 100% !important; height: 100% !important; }
    .ap-wrapper { width: 100% !important; height: 100% !important; }
    .ap-player .ap-terminal { overflow: hidden !important; }
  </style>
</head>
<body>
  <div id="player"></div>
  <script>${playerJs}</script>
  <script>
    const blob = new Blob([${castDataSafe}], { type: 'text/plain' });
    window.__player = AsciinemaPlayer.create(URL.createObjectURL(blob), document.getElementById('player'), {
      autoPlay: false,
      speed: 1,
      theme: ${JSON.stringify(theme)},
      fit: 'both',
      cols: ${cols},
      rows: ${rows},
      controls: false,
      idleTimeLimit: ${idleLimit},
    });
  </script>
</body>
</html>`;

} else {
  // Window chrome mode (default)
  const CHROME_TOP    = 44;
  const CHROME_SIDE   = 20;
  const CHROME_BOTTOM = 20;
  const CORNER        = 12;
  const SHADOW        = 40;

  const CHAR_W = fontPx * 0.601;
  const CHAR_H = fontPx * 1.333;

  const termW    = Math.ceil(cols * CHAR_W);
  const termH    = Math.ceil(rows * CHAR_H);
  const contentW = termW + CHROME_SIDE * 2;
  const contentH = termH + CHROME_TOP + CHROME_BOTTOM;
  vpW = contentW + SHADOW * 2;
  vpH = contentH + SHADOW * 2;

  html = `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    ${playerCss}
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      width: ${vpW}px; height: ${vpH}px;
      background: #1a1a1a;
      display: flex; align-items: center; justify-content: center;
    }
    .window {
      width: ${contentW}px; height: ${contentH}px;
      background: #1e1e1e;
      border-radius: ${CORNER}px;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.08),
        0 20px 60px rgba(0,0,0,0.8),
        0 8px 24px rgba(0,0,0,0.6);
      display: flex; flex-direction: column;
    }
    .titlebar {
      flex: 0 0 ${CHROME_TOP}px;
      background: #2a2a2a;
      display: flex; align-items: center;
      padding: 0 16px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      position: relative;
    }
    .dots { display: flex; gap: 8px; }
    .dot  { width: 12px; height: 12px; border-radius: 50%; }
    .dot.close { background: #ff5f57; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.3); }
    .dot.min   { background: #febc2e; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.3); }
    .dot.max   { background: #28c840; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.3); }
    .title {
      position: absolute; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,0.45);
      font-size: 13px;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      font-weight: 500; letter-spacing: 0.01em; white-space: nowrap;
    }
    .terminal-wrap {
      flex: 1;
      padding: ${CHROME_BOTTOM}px ${CHROME_SIDE}px;
      overflow: hidden;
    }
    .ap-player { --term-font-size: ${fontPx}px !important; height: 100% !important; }
    .ap-wrapper { height: 100% !important; }
    .ap-player .ap-terminal { overflow: hidden !important; }
  </style>
</head>
<body>
  <div class="window">
    <div class="titlebar">
      <div class="dots">
        <div class="dot close"></div>
        <div class="dot min"></div>
        <div class="dot max"></div>
      </div>
      <div class="title">${title}</div>
    </div>
    <div class="terminal-wrap">
      <div id="player"></div>
    </div>
  </div>
  <script>${playerJs}</script>
  <script>
    const blob = new Blob([${castDataSafe}], { type: 'text/plain' });
    window.__player = AsciinemaPlayer.create(URL.createObjectURL(blob), document.getElementById('player'), {
      autoPlay: false,
      speed: 1,
      theme: ${JSON.stringify(theme)},
      fit: 'width',
      cols: ${cols},
      rows: ${rows},
      controls: false,
      idleTimeLimit: ${idleLimit},
    });
  </script>
</body>
</html>`;
} // end else (window chrome mode)

console.log(`${castFile} → ${outFile}`);
console.log(`  cols=${cols} rows=${rows} ${vpW}x${vpH} ~${castDuration}s${fullbleed ? " [fullbleed]" : ""}`);

const browser = await chromium.launch({ headless: true });
const context = await browser.newContext({
  viewport: { width: vpW, height: vpH },
  recordVideo: { dir: videoDir, size: { width: vpW, height: vpH } },
});

const page = await context.newPage();
await page.setContent(html, { waitUntil: "domcontentloaded" });
// Wait for asciinema-player to mount and for __player to be initialized
await page.waitForFunction(() => !!window.__player, { timeout: 30000 });
// One more tick to ensure the player has fully rendered its DOM
await page.evaluate(() => new Promise((r) => setTimeout(r, 500)));

// Two rAF ticks to ensure the window chrome is composited before playback starts
await page.evaluate(() => new Promise((r) => requestAnimationFrame(() => requestAnimationFrame(r))));
await page.evaluate(() => window.__player.play());
await page.waitForTimeout(castDuration * 1000);

await context.close();
await browser.close();

const webm = readdirSync(videoDir).filter((f) => f.endsWith(".webm")).map((f) => `${videoDir}/${f}`)[0];
if (!webm) throw new Error("No webm recorded");

// Trim 0.5s lead to drop any blank frames at the start of the webm
const ffmpeg = spawnSync("ffmpeg", [
  "-y", "-ss", "0.5", "-i", webm,
  "-c:v", "libx264", "-pix_fmt", "yuv420p", "-movflags", "+faststart",
  outFile,
], { stdio: "inherit" });
if (ffmpeg.status !== 0) throw new Error("ffmpeg failed");

console.log(`Done: ${outFile}`);
