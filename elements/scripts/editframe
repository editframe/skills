#!/usr/bin/env bash
#
# Development CLI wrapper for Editframe
# =====================================
# This script allows running the Editframe CLI directly from TypeScript source
# files without building packages. Use this for local development in the monorepo.
#
# Usage:
#   scripts/editframe preview dev-projects/simple-demo.html
#   scripts/editframe render --help
#   scripts/editframe --version
#
# For production use or in external projects:
#   Install @editframe/cli from npm and use: npx editframe <command>
#
# How it works:
# - Runs CLI via tsx (TypeScript execution)
# - Uses tsconfig-paths/register to resolve @editframe/* imports
# - Resolves to source files (packages/*/src/) via tsconfig.json paths
# - When run from external projects, temporarily swaps @editframe dependencies to file: paths
# - No build step required!
#

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
ELEMENTS_ROOT="$SCRIPT_DIR/.."
PACKAGES_DIR="$ELEMENTS_ROOT/packages"

# Save the original working directory where the user ran the command
ORIGINAL_CWD="$(pwd)"

# Detect if we're running from outside the monorepo
RUNNING_EXTERNAL=false
if [[ "$ORIGINAL_CWD" != "$ELEMENTS_ROOT"* ]]; then
  RUNNING_EXTERNAL=true
fi

# Debug logging helper - only output if DEBUG is set
debug_log() {
  if [ -n "$DEBUG" ]; then
    echo "$@" >&2
  fi
}

# Function to cleanup temporary files on exit
cleanup_editframe_dev() {
  debug_log ""
  debug_log "[cleanup] Cleaning up temporary files..."
  
  if [ "$VITE_CONFIG_CREATED" = true ]; then
    # Remove our temporary config
    local our_config="$ORIGINAL_CWD/vite.config.js"
    if [ -f "$our_config" ]; then
      rm -f "$our_config"
      debug_log "[cleanup] Removed temporary vite.config.js"
    fi
    
    # Restore user's original config
    for backup in "$ORIGINAL_CWD"/vite.config.*.editframe-backup; do
      if [ -f "$backup" ]; then
        original="${backup%.editframe-backup}"
        mv "$backup" "$original"
        debug_log "[cleanup] Restored $(basename "$original")"
      fi
    done
  fi
  
  if [ "$TAILWIND_CONFIG_CREATED" = true ]; then
    # Restore PostCSS config if we backed it up
    if [ -f "$ORIGINAL_CWD/postcss.config.cjs.editframe-backup" ]; then
      mv "$ORIGINAL_CWD/postcss.config.cjs.editframe-backup" "$ORIGINAL_CWD/postcss.config.cjs"
      debug_log "[cleanup] Restored postcss.config.cjs"
    fi
    
    # Remove symlink if it exists (including broken symlinks)
    if [ -L "$ORIGINAL_CWD/tailwind.config.cjs" ] || [ -e "$ORIGINAL_CWD/tailwind.config.cjs" ]; then
      rm -f "$ORIGINAL_CWD/tailwind.config.cjs"
      debug_log "[cleanup] Removed tailwind.config.cjs symlink"
    fi

    # Remove our temporary Tailwind config
    local our_tw_config="$ORIGINAL_CWD/tailwind.config.editframe-dev.cjs"
    if [ -f "$our_tw_config" ]; then
      rm -f "$our_tw_config"
      debug_log "[cleanup] Removed temporary tailwind.config.editframe-dev.cjs"
    fi

    # Restore user's original Tailwind config
    for backup in "$ORIGINAL_CWD"/tailwind.config.*.editframe-backup; do
      if [ -f "$backup" ] && [ ! -L "$backup" ]; then
        # Only restore if backup is not our generated config
        if ! head -n 3 "$backup" 2>/dev/null | grep -q "TEMPORARY EDITFRAME DEV"; then
          original="${backup%.editframe-backup}"
          mv "$backup" "$original"
          debug_log "[cleanup] Restored $(basename "$original")"
        else
          rm -f "$backup"
          debug_log "[cleanup] Removed invalid backup $(basename "$backup")"
        fi
      fi
    done
  fi
  
  debug_log "[cleanup] Done!"
}

# Variable to track if we need cleanup
NEEDS_CLEANUP=false
VITE_CONFIG_CREATED=false
TAILWIND_CONFIG_CREATED=false

# If running from external project, inject source aliases for Vite
if [ "$RUNNING_EXTERNAL" = true ] && [ -f "$ORIGINAL_CWD/package.json" ]; then
  # Check if package.json has @editframe dependencies
  if grep -q '"@editframe/' "$ORIGINAL_CWD/package.json"; then
    debug_log "📦 Detected external project with @editframe dependencies"
    debug_log "   Configuring Vite to use monorepo source files..."
    debug_log ""
    
    NEEDS_CLEANUP=true
    
      # Find and backup/rename user's existing Vite config
      USER_VITE_CONFIG=""
      for config_file in vite.config.ts vite.config.js vite.config.mjs vite.config.cjs; do
        if [ -f "$ORIGINAL_CWD/$config_file" ]; then
          # Skip if this is already our generated config (check for our header)
          if head -n 3 "$ORIGINAL_CWD/$config_file" 2>/dev/null | grep -q "TEMPORARY EDITFRAME DEV CONFIG"; then
            debug_log "   Skipping $config_file (already our generated config)"
            continue
          fi
          
          USER_VITE_CONFIG="$config_file"
          # Move (not copy) so Vite won't find it
          mv "$ORIGINAL_CWD/$config_file" "$ORIGINAL_CWD/$config_file.editframe-backup"
          debug_log "   Temporarily moved $config_file"
          break
        fi
      done
    
    # Create our Vite config as the default name (since we moved user's config)
    VITE_DEV_CONFIG="$ORIGINAL_CWD/vite.config.js"
    
    # Create a simple config that mimics typical editframe project setup
    # We'll recreate common patterns rather than trying to parse user config
    cat > "$VITE_DEV_CONFIG" << VITE_CONFIG_EOF
// ============================================================================
// TEMPORARY EDITFRAME DEV CONFIG
// Auto-generated by elements/scripts/editframe for source development
// ============================================================================
import { defineConfig } from 'vite';
import path from 'path';
import { vitePluginEditframe } from '@editframe/vite-plugin';

const __dirname = import.meta.dirname;
const monorepoPackages = '$PACKAGES_DIR';

export default defineConfig({
  plugins: [
    vitePluginEditframe({
      root: path.join(__dirname, 'src'),
      cacheRoot: path.join(__dirname, 'src', 'assets'),
    }),
  ],
  resolve: {
    alias: [
      // Map /assets to src/assets for static file serving
      {
        find: '/assets',
        replacement: path.join(__dirname, 'src/assets')
      },
      // Monorepo source aliases
      // NOTE: We intentionally don't alias CSS files - they're built assets
      // and should load from node_modules. Only source code (TS/JS) is aliased.
      {
        find: /^@editframe\\/elements$/,
        replacement: path.join(monorepoPackages, 'elements/src/index.ts')
      },
      {
        find: /^@editframe\\/api$/,
        replacement: path.join(monorepoPackages, 'api/src/index.ts')
      },
      {
        find: /^@editframe\\/assets$/,
        replacement: path.join(monorepoPackages, 'assets/src/index.ts')
      },
      {
        find: /^@editframe\\/vite-plugin$/,
        replacement: path.join(monorepoPackages, 'vite-plugin/src/index.ts')
      },
      {
        find: /^@editframe\\/react$/,
        replacement: path.join(monorepoPackages, 'react/src/index.ts')
      }
    ]
  }
});
VITE_CONFIG_EOF
    
    VITE_CONFIG_CREATED=true
    
    debug_log "✓ Created temporary vite.config.js with source aliases"
    if [ -n "$USER_VITE_CONFIG" ]; then
      debug_log "   (Your $USER_VITE_CONFIG will be restored on exit)"
    fi
    
      # Handle Tailwind config if present
      USER_TAILWIND_CONFIG=""
      for tw_config in tailwind.config.js tailwind.config.ts tailwind.config.mjs tailwind.config.cjs; do
        if [ -f "$ORIGINAL_CWD/$tw_config" ]; then
          # Skip if this is already our generated config (check for our header)
          if head -n 3 "$ORIGINAL_CWD/$tw_config" 2>/dev/null | grep -q "TEMPORARY EDITFRAME DEV"; then
            debug_log "   Skipping $tw_config (already our generated config)"
            continue
          fi
          
          USER_TAILWIND_CONFIG="$tw_config"
          # Backup and move user's Tailwind config
          mv "$ORIGINAL_CWD/$tw_config" "$ORIGINAL_CWD/$tw_config.editframe-backup"
          debug_log "   Temporarily moved $tw_config"
        
          # Create temporary Tailwind config that extends theirs
          # Use .cjs extension to ensure it's treated as CommonJS even if package.json has "type": "module"
          TW_DEV_CONFIG="$ORIGINAL_CWD/tailwind.config.editframe-dev.cjs"
        
        cat > "$TW_DEV_CONFIG" << 'TW_CONFIG_EOF'
// ============================================================================
// TEMPORARY EDITFRAME DEV TAILWIND CONFIG
// Auto-generated by elements/scripts/editframe for source development
// ============================================================================
const path = require('path');

// Load user's original Tailwind config
let userConfig = {};
try {
  const loadedConfig = require('./TAILWIND_CONFIG_NAME.editframe-backup');
  // Handle default export or direct module.exports
  userConfig = loadedConfig.default || loadedConfig;
  // If it's a function, call it
  if (typeof userConfig === 'function') {
    userConfig = userConfig({ mode: 'jit' });
  }
} catch (e) {
  console.warn('Could not load user Tailwind config:', e.message);
  userConfig = { content: [], theme: { extend: {} }, plugins: [] };
}

const monorepoElementsDist = 'MONOREPO_ELEMENTS_DIST_PLACEHOLDER';

// Helper to merge content arrays
function mergeContent(userContent) {
  const contentArray = Array.isArray(userContent) ? userContent : 
                       userContent?.files || [];
  
  return [
    // User's original content paths
    ...contentArray,
    // Add @editframe/elements dist files so Tailwind scans workbench classes
    // Be specific to avoid performance issues
    path.join(monorepoElementsDist, 'index.js'),
    path.join(monorepoElementsDist, 'gui/**/*.js'),
    path.join(monorepoElementsDist, 'preview/**/*.js'),
  ];
}

// Helper to deep merge theme
function mergeTheme(userTheme = {}) {
  return {
    ...userTheme,
    extend: {
      ...(userTheme.extend || {}),
    }
  };
}

// Always include all standard Tailwind config properties with proper defaults
// This prevents "Cannot read properties of undefined" errors across different Tailwind versions
const exportedConfig = {
  content: mergeContent(userConfig.content),
  theme: mergeTheme(userConfig.theme),
  plugins: userConfig.plugins || [],
  
  // Properties that must have values (use Tailwind defaults if not specified)
  separator: userConfig.separator !== undefined ? userConfig.separator : ':',
  
  // Optional properties that can be undefined
  presets: userConfig.presets,
  darkMode: userConfig.darkMode,
  safelist: userConfig.safelist,
  blocklist: userConfig.blocklist,
  corePlugins: userConfig.corePlugins,
  prefix: userConfig.prefix,
  important: userConfig.important,
  variantOrder: userConfig.variantOrder,
  
  // Feature flags
  future: userConfig.future,
  experimental: userConfig.experimental,
};

module.exports = exportedConfig;
TW_CONFIG_EOF
        
        # Replace placeholders
        if [[ "$OSTYPE" == "darwin"* ]]; then
          sed -i '' "s|TAILWIND_CONFIG_NAME|$USER_TAILWIND_CONFIG|g" "$TW_DEV_CONFIG"
          sed -i '' "s|MONOREPO_ELEMENTS_DIST_PLACEHOLDER|$PACKAGES_DIR/elements/dist|g" "$TW_DEV_CONFIG"
        else
          sed -i "s|TAILWIND_CONFIG_NAME|$USER_TAILWIND_CONFIG|g" "$TW_DEV_CONFIG"
          sed -i "s|MONOREPO_ELEMENTS_DIST_PLACEHOLDER|$PACKAGES_DIR/elements/dist|g" "$TW_DEV_CONFIG"
        fi
        
          # Create symlink with .cjs extension so PostCSS/Tailwind finds it
          # Use .cjs to ensure CommonJS in ES module projects
          ln -sf "$(basename "$TW_DEV_CONFIG")" "$ORIGINAL_CWD/tailwind.config.cjs"
          
          # Update PostCSS config to explicitly point to our Tailwind config
          # This ensures Tailwind finds it even with Vite's caching
          # Use absolute path to ensure it resolves correctly in programmatic Vite context
          if [ -f "$ORIGINAL_CWD/postcss.config.cjs" ]; then
            cp "$ORIGINAL_CWD/postcss.config.cjs" "$ORIGINAL_CWD/postcss.config.cjs.editframe-backup"
            cat > "$ORIGINAL_CWD/postcss.config.cjs" << POSTCSS_EOF
module.exports = {
  plugins: {
    tailwindcss: { config: '$ORIGINAL_CWD/tailwind.config.cjs' },
  },
};
POSTCSS_EOF
          fi

          TAILWIND_CONFIG_CREATED=true
        debug_log "✓ Created temporary Tailwind config with @editframe/elements scanning"
        debug_log "   (Your $USER_TAILWIND_CONFIG will be restored on exit)"
        
        break
      fi
    done
    
    debug_log ""
  fi
fi

# Change to elements directory so tsconfig.json paths resolve correctly
cd "$ELEMENTS_ROOT"

# Run the CLI using tsx with TypeScript path resolution
# Use Node.js loader to handle CSS imports before tsx processes the file
# The CSS loader handles .css?inline imports by converting them to string exports
# Pass the original working directory so the CLI knows where the user actually is
# NOTE: Don't use exec here if we need cleanup so trap can fire
if [ "$NEEDS_CLEANUP" = true ]; then
  # Set up trap before running CLI
  trap cleanup_editframe_dev EXIT INT TERM
  
  # Run CLI normally (not backgrounded) - trap will fire on Ctrl+C
  ORIGINAL_CWD="$ORIGINAL_CWD" node --import "data:text/javascript,import { register } from 'node:module'; import { pathToFileURL } from 'node:url'; register('$SCRIPT_DIR/css-loader.mjs', pathToFileURL('$SCRIPT_DIR/'));" --import tsx --import tsconfig-paths/register packages/cli/src/index.ts "$@"
else
  # No cleanup needed, use exec for efficiency
  ORIGINAL_CWD="$ORIGINAL_CWD" exec node --import "data:text/javascript,import { register } from 'node:module'; import { pathToFileURL } from 'node:url'; register('$SCRIPT_DIR/css-loader.mjs', pathToFileURL('$SCRIPT_DIR/'));" --import tsx --import tsconfig-paths/register packages/cli/src/index.ts "$@"
fi
