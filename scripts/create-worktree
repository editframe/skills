#!/usr/bin/env bash
# Create a new worktree for a branch
# Run from main worktree

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Check for branch name argument
if [ -z "$1" ]; then
  echo "Error: Branch name required" >&2
  echo "Usage: $0 <branch-name>" >&2
  exit 1
fi

BRANCH_NAME="$1"

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

# Get current worktree root
CURRENT_ROOT=$(git rev-parse --show-toplevel)

# Check if we're in main worktree (should be)
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)
if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ]; then
  echo "Warning: Not on main/master branch. Creating worktree from current branch: $CURRENT_BRANCH" >&2
fi

# Sanitize branch name function (from worktree-config)
sanitize_branch_name() {
  local name="$1"
  name=$(echo "$name" | tr '[:upper:]' '[:lower:]')
  name=$(echo "$name" | sed 's/[^a-z0-9]/-/g')
  name=$(echo "$name" | sed 's/^-\+//; s/-\+$//')
  name=$(echo "$name" | sed 's/-\+/-/g')
  name=$(echo "$name" | cut -c1-63)
  name=$(echo "$name" | sed 's/-$//')
  
  if [ -z "$name" ] || ! echo "$name" | grep -q '^[a-z0-9]'; then
    echo "Error: Invalid branch name after sanitization: '$BRANCH_NAME' -> '$name'" >&2
    exit 1
  fi
  
  echo "$name"
}

SANITIZED_BRANCH=$(sanitize_branch_name "$BRANCH_NAME")

# Determine worktree parent directory (monorepo parent)
WORKTREE_PARENT=$(dirname "$CURRENT_ROOT")
WORKTREE_DIR="$WORKTREE_PARENT/editframe-${SANITIZED_BRANCH}"

# Check if worktree already exists
if [ -d "$WORKTREE_DIR" ]; then
  echo "Error: Worktree directory already exists: $WORKTREE_DIR" >&2
  exit 1
fi

# Determine base branch for new branch creation
if [ -z "$CURRENT_BRANCH" ] || [ "$CURRENT_BRANCH" = "HEAD" ]; then
  # Detached HEAD, use main/master
  BASE_BRANCH="main"
  if ! git show-ref --verify --quiet "refs/heads/main"; then
    BASE_BRANCH="master"
  fi
else
  BASE_BRANCH="$CURRENT_BRANCH"
fi

# Check if branch exists
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Creating Worktree"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
  echo "📦 Using existing branch: $BRANCH_NAME"
else
  echo "📦 Creating new branch: $BRANCH_NAME"
fi
echo "🌳 Worktree location: $WORKTREE_DIR"
echo ""

# Create worktree (suppress git output)
if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
  git worktree add "$WORKTREE_DIR" "$BRANCH_NAME" > /dev/null 2>&1
else
  git worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR" "$BASE_BRANCH" > /dev/null 2>&1
fi

# Verify worktree structure
if [ ! -d "$WORKTREE_DIR/elements" ] || [ ! -d "$WORKTREE_DIR/telecine" ] || [ ! -d "$WORKTREE_DIR/scripts" ]; then
  echo "⚠️  Warning: Worktree structure incomplete. Expected elements/, telecine/, scripts/" >&2
fi

echo "✅ Worktree created"
echo ""

# Copy native build artifacts
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Copying Build Artifacts"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if [ -f "$WORKTREE_DIR/telecine/scripts/copy-native-build" ]; then
  cd "$WORKTREE_DIR/telecine"
  ./scripts/copy-native-build 2>&1 | grep -v "^Running:" | sed 's/^/   /' || {
    echo "   ⚠️  Warning: Failed to copy some build artifacts. You may need to rebuild." >&2
  }
  cd "$CURRENT_ROOT"
else
  echo "   ⚠️  Warning: copy-native-build script not found. Skipping artifact copy." >&2
fi

echo ""

# Copy .env files
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Copying Configuration Files"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ENV_COPIED=0
if [ -f "$CURRENT_ROOT/telecine/.env" ]; then
  if cp "$CURRENT_ROOT/telecine/.env" "$WORKTREE_DIR/telecine/.env" 2>/dev/null; then
    echo "   ✅ telecine/.env"
    ENV_COPIED=$((ENV_COPIED + 1))
  else
    echo "   ⚠️  Failed to copy telecine/.env" >&2
  fi
fi

if [ -f "$CURRENT_ROOT/elements/.env" ]; then
  if cp "$CURRENT_ROOT/elements/.env" "$WORKTREE_DIR/elements/.env" 2>/dev/null; then
    echo "   ✅ elements/.env"
    ENV_COPIED=$((ENV_COPIED + 1))
  else
    echo "   ⚠️  Failed to copy elements/.env" >&2
  fi
fi

if [ $ENV_COPIED -eq 0 ]; then
  echo "   ℹ️  No .env files found to copy"
fi

echo ""

# Start Docker resources (this creates volumes, then we can copy node_modules)
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Starting Services"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if [ ! -f "$WORKTREE_DIR/scripts/start" ]; then
  echo "⚠️  Warning: start script not found. Skipping service startup." >&2
else
  cd "$WORKTREE_DIR"
  
  # Start runner services first to create volumes
  echo "Creating volumes and starting runners..."
  cd telecine
  ./scripts/docker-compose up -d runner > /dev/null 2>&1 || true
  cd "$WORKTREE_DIR/elements"
  ./scripts/docker-compose up -d runner > /dev/null 2>&1 || true
  sleep 2
  cd "$WORKTREE_DIR"
  
  # Now copy node_modules from main worktree volumes
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Copying Dependencies"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  
  # Function to copy between Docker volumes
  copy_docker_volume() {
    local source_volume="$1"
    local target_volume="$2"
    local mount_path="$3"
    
    # Check if source volume exists
    if ! docker volume inspect "$source_volume" > /dev/null 2>&1; then
      echo "   ℹ️  Source volume not found (will install on first run)"
      return 0
    fi
    
    # Check if target volume exists (created by docker-compose)
    if ! docker volume inspect "$target_volume" > /dev/null 2>&1; then
      echo "   ℹ️  Target volume not created yet (will install on first run)"
      return 0
    fi
    
    # Use a temporary container to copy between volumes
    # Mount both volumes and copy from source to target
    # Create target directory first, then copy contents
    docker run --rm \
      -v "$source_volume:/source$mount_path:ro" \
      -v "$target_volume:/target$mount_path" \
      alpine:latest \
      sh -c "mkdir -p /target$mount_path && if [ -d \"/source$mount_path\" ] && [ \"\$(ls -A /source$mount_path 2>/dev/null)\" ]; then cp -a \"/source$mount_path/\"* \"/target$mount_path/\" 2>/dev/null; fi" \
      > /dev/null 2>&1 || true
    
    echo "   ✅ Copied"
  }
  
  # Determine main worktree Docker project names
  if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
    MAIN_TELECINE_PROJECT="telecine"
    MAIN_ELEMENTS_PROJECT="ef-elements"
  else
    # If creating from a worktree, try to detect main worktree project names
    MAIN_TELECINE_PROJECT="telecine"
    MAIN_ELEMENTS_PROJECT="ef-elements"
  fi
  
  # Determine new worktree Docker project names
  if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
    NEW_TELECINE_PROJECT="telecine"
    NEW_ELEMENTS_PROJECT="ef-elements"
  else
    NEW_TELECINE_PROJECT="telecine-${SANITIZED_BRANCH}"
    NEW_ELEMENTS_PROJECT="ef-elements-${SANITIZED_BRANCH}"
  fi
  
  # Copy telecine node_modules
  MAIN_TELECINE_VOLUME="${MAIN_TELECINE_PROJECT}_node_modules"
  NEW_TELECINE_VOLUME="${NEW_TELECINE_PROJECT}_node_modules"
  echo -n "   telecine/node_modules ... "
  copy_docker_volume "$MAIN_TELECINE_VOLUME" "$NEW_TELECINE_VOLUME" "/app/node_modules"
  
  # Copy elements node_modules
  MAIN_ELEMENTS_VOLUME="${MAIN_ELEMENTS_PROJECT}_node_modules"
  NEW_ELEMENTS_VOLUME="${NEW_ELEMENTS_PROJECT}_node_modules"
  echo -n "   elements/node_modules ... "
  copy_docker_volume "$MAIN_ELEMENTS_VOLUME" "$NEW_ELEMENTS_VOLUME" "/packages/node_modules"
  
  echo ""
  
  # Now run the full start script
  set +e  # Temporarily disable exit on error
  ./scripts/start
  START_EXIT_CODE=$?
  set -e  # Re-enable exit on error
  
  if [ $START_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "⚠️  Warning: Some services may have failed to start." >&2
    echo "   Check logs and start manually if needed:" >&2
    echo "   cd $WORKTREE_DIR && ./scripts/start" >&2
  fi
fi

cd "$CURRENT_ROOT"

# Calculate domain and docker project names
if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
  DOMAIN="main.localhost"
  TELECINE_DOCKER="telecine"
  ELEMENTS_DOCKER="ef-elements"
else
  DOMAIN="${SANITIZED_BRANCH}.localhost"
  TELECINE_DOCKER="telecine-${SANITIZED_BRANCH}"
  ELEMENTS_DOCKER="ef-elements-${SANITIZED_BRANCH}"
fi

# Calculate ports for display
if [ "$BRANCH_NAME" != "main" ] && [ "$BRANCH_NAME" != "master" ]; then
  # Calculate port offset
  PORT_HASH=$(echo -n "$BRANCH_NAME" | od -An -tu1 | awk '{sum += $1} END {print sum % 10}')
  PORT_OFFSET=$((PORT_HASH * 1000))
  POSTGRES_PORT=$((5432 + PORT_OFFSET))
  VALKEY_PORT=$((6379 + PORT_OFFSET))
else
  POSTGRES_PORT=5432
  VALKEY_PORT=6379
fi

# Display summary
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Worktree Created Successfully"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "   Branch:        $BRANCH_NAME"
echo "   Location:      $WORKTREE_DIR"
echo ""
echo "   Web Services:"
echo "      Telecine:   http://${DOMAIN}:3000"
echo "      Elements:   http://${DOMAIN}:4321"
echo ""
echo "   Database Ports (for host tools):"
echo "      PostgreSQL: localhost:$POSTGRES_PORT"
echo "      Valkey:     localhost:$VALKEY_PORT"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Next steps:"
echo "   1. cd $WORKTREE_DIR"
echo "   2. Make your changes and commit"
echo "   3. ./scripts/merge-worktree  (when ready to merge)"
echo "   4. ./scripts/remove-worktree (after merging)"
echo ""

