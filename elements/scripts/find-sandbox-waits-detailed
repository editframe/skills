#!/usr/bin/env bash
# Find all instances of ctx.wait() in sandbox files with detailed context

# Find all .sandbox.ts files
find elements/packages/elements/src -name "*.sandbox.ts" -type f | while read -r file; do
  # Count occurrences in this file
  count=$(grep -c "ctx\.wait(" "$file" 2>/dev/null)
  
  # Handle empty or invalid count
  if [ -z "$count" ] || [ "$count" = "0" ]; then
    continue
  fi
  
  # Remove any whitespace/newlines
  count=$(echo "$count" | tr -d '[:space:]')
  
  if [ "$count" -gt 0 ] 2>/dev/null; then
    plural=""
    [ "$count" -gt 1 ] && plural="s"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📄 $file ($count instance$plural)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    # Show each occurrence with 2 lines of context
    grep -n -B 2 -A 2 "ctx\.wait(" "$file" | \
      grep -E "^[0-9]+-|^[0-9]+:|ctx\.wait" | \
      sed 's/^\([0-9]\+\)-/\1  │ /' | \
      sed 's/^\([0-9]\+\):/\1→│ /'
  fi
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Summary:"
find elements/packages/elements/src -name "*.sandbox.ts" -type f -exec grep -l "ctx\.wait(" {} \; | wc -l | xargs echo "Files with ctx.wait():"
find elements/packages/elements/src -name "*.sandbox.ts" -type f -exec grep -o "ctx\.wait(" {} \; | wc -l | xargs echo "Total instances:"
