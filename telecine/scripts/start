#/usr/bin/env bash
set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Change to project root so npm install runs in the correct directory
cd "$PROJECT_ROOT"

# Ensure docker services are started (needed for runner service to be available)
echo "Starting runner container..."
${SCRIPT_DIR}/docker-compose up -d runner
# Wait for runner to be ready
sleep 2

# Run npm install in the container
echo "Running npm install in container..."
${SCRIPT_DIR}/npm install

# Build native transcode module (required for jit-transcoding service)
echo "Building native transcode module in container..."
# Clean build directory to avoid CMake cache path mismatches
${SCRIPT_DIR}/docker-compose exec runner rm -rf lib/transcode/build
${SCRIPT_DIR}/docker-compose exec runner npm run build

# Start docker services (all services needed for migrations)
# Use the same approach as start-for-playwright to ensure all services are started
. "$SCRIPT_DIR/worktree-config"

${SCRIPT_DIR}/docker-compose \
  -f ${SCRIPT_DIR}/../docker-compose.yaml \
  -f ${SCRIPT_DIR}/../services/dev-postgres/docker-compose.yaml \
  -f ${SCRIPT_DIR}/../services/dev-valkey/docker-compose.yaml \
  -f ${SCRIPT_DIR}/../services/dev-mailhog/docker-compose.yaml \
  -f ${SCRIPT_DIR}/../services/graphql-engine/docker-compose.yaml \
  up --build -d --force-recreate --wait

# Wait a moment for volumes to be fully mounted and services to be ready
sleep 2

# Run migrations and seed
${SCRIPT_DIR}/migrate-db
${SCRIPT_DIR}/seed
