#!/usr/bin/env bash


SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Source worktree configuration to get project name and domain
. "$SCRIPT_DIR/worktree-config"

# Ensure shared Traefik network exists (needed for all worktrees)
if ! docker network inspect telecine-traefik > /dev/null 2>&1; then
  echo "Creating shared Traefik network: telecine-traefik"
  docker network create telecine-traefik
fi

# Resolve elements path for docker-compose volume mounts
PROJECT_ROOT="$SCRIPT_DIR/.."
WORKTREE_ROOT=$(cd "$PROJECT_ROOT" && git rev-parse --show-toplevel 2>/dev/null || echo "$PROJECT_ROOT")
WORKTREE_PARENT=$(dirname "$WORKTREE_ROOT")

ELEMENTS_PATH=""
if [ -d "$WORKTREE_PARENT/elements" ]; then
    # Main worktree pattern: ../elements
    ELEMENTS_PATH="$WORKTREE_PARENT/elements"
elif [ -n "$WORKTREE_ID" ] && [ "$WORKTREE_ID" != "main" ] && [ -d "$WORKTREE_PARENT/elements-${WORKTREE_ID}" ]; then
    # Parallel worktree pattern: ../elements-<branch>
    ELEMENTS_PATH="$WORKTREE_PARENT/elements-${WORKTREE_ID}"
else
    # Fallback to relative path (relative to docker-compose.yaml location)
    ELEMENTS_PATH="$PROJECT_ROOT/../elements"
fi

export ELEMENTS_PATH

# Export absolute path to telecine root for docker-compose volume mounts
# For docker-in-docker: paths must exist on the HOST filesystem
# Worktrees should be created in /workspace/.cursor-worktrees so they exist on the host
PROJECT_ROOT="$SCRIPT_DIR/.."
WORKTREE_ROOT=$(cd "$PROJECT_ROOT" && git rev-parse --show-toplevel 2>/dev/null || echo "$PROJECT_ROOT")

# Check if we're in a worktree under /workspace/.cursor-worktrees (host-mounted)
if [[ "$WORKTREE_ROOT" == /workspace/.cursor-worktrees/* ]]; then
    # Worktree is in the host-mounted directory - use it directly
    TELECINE_ROOT="$WORKTREE_ROOT/telecine"
    if [[ ! -d "$TELECINE_ROOT" ]]; then
        TELECINE_ROOT="$WORKTREE_ROOT"
    fi
elif [[ "$WORKTREE_ROOT" == /workspace/* ]]; then
    # Main worktree or worktree directly under /workspace
    TELECINE_ROOT="$WORKTREE_ROOT/telecine"
    if [[ ! -d "$TELECINE_ROOT" ]]; then
        TELECINE_ROOT="$WORKTREE_ROOT"
    fi
elif [[ -d "/workspace/telecine" ]]; then
    # Fallback: use main worktree's telecine
    TELECINE_ROOT="/workspace/telecine"
else
    # Last resort: use current directory (may not work in docker-in-docker)
    TELECINE_ROOT=$(cd "$PROJECT_ROOT" && pwd)
fi
export TELECINE_ROOT
    if [ "$WORKTREE_DOMAIN" = "main.localhost" ]; then
        # Main worktree: include Traefik service by activating profile
        compose_files="$root_compose_file"$'\n'"$compose_files"
        export COMPOSE_PROFILES="main-worktree"
    else
        # Worktree: include compose file but Traefik won't start (profile not activated)
        compose_files="$root_compose_file"$'\n'"$compose_files"
    fi
fi

# Remove any potential duplicate entries
compose_files=$(echo "$compose_files" | awk '!seen[$0]++')

# Add -f flag to each file
compose_flags=$(echo "$compose_files" | sed 's/^/-f /' | tr '\n' ' ')

# Debug output
if [ -n "$CI" ]; then
    echo "Found docker-compose files: $compose_flags"
fi

# Run docker compose with worktree-specific project name
# COMPOSE_PROFILES is set above for main worktree to activate Traefik service
docker compose ${compose_flags} --project-name "$WORKTREE_DOCKER_PROJECT_NAME" "$@"
