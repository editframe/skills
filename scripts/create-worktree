#!/usr/bin/env bash
# Create a new worktree for a branch with scope-based service startup.
# Run from main worktree.
#
# Usage: create-worktree <branch-name> [scope]
#   scope: elements | web | render  (default: web)
#
# Scopes:
#   elements  - Elements runner + dev-projects only. No telecine services.
#   web       - Elements + telecine core (web, hasura, valkey, maintenance).
#   render    - Elements + telecine core + render pipeline (workers, scheduler).

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

if [ -z "$1" ]; then
  echo "Usage: $0 <branch-name> [elements|web|render]" >&2
  exit 1
fi

BRANCH_NAME="$1"
SCOPE="${2:-web}"

case "$SCOPE" in
  elements|web|render) ;;
  *) echo "Invalid scope: $SCOPE (must be elements, web, or render)" >&2; exit 1 ;;
esac

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

CURRENT_ROOT=$(git rev-parse --show-toplevel)
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)

sanitize_branch_name() {
  local name="$1"
  name=$(echo "$name" | tr '[:upper:]' '[:lower:]')
  name=$(echo "$name" | sed 's/[^a-z0-9]/-/g')
  name=$(echo "$name" | sed 's/^-\+//; s/-\+$//')
  name=$(echo "$name" | sed 's/-\+/-/g')
  name=$(echo "$name" | cut -c1-63)
  name=$(echo "$name" | sed 's/-$//')
  if [ -z "$name" ] || ! echo "$name" | grep -q '^[a-z0-9]'; then
    echo "Error: Invalid branch name after sanitization" >&2
    exit 1
  fi
  echo "$name"
}

SANITIZED_BRANCH=$(sanitize_branch_name "$BRANCH_NAME")
WORKTREE_PARENT=$(dirname "$CURRENT_ROOT")
WORKTREE_DIR="$WORKTREE_PARENT/editframe-${SANITIZED_BRANCH}"

if [ -d "$WORKTREE_DIR" ]; then
  echo "Error: Worktree directory already exists: $WORKTREE_DIR" >&2
  exit 1
fi

# Determine base branch
BASE_BRANCH="${CURRENT_BRANCH:-main}"
if [ "$BASE_BRANCH" = "HEAD" ]; then
  BASE_BRANCH="main"
fi

echo ""
echo "Creating worktree: $BRANCH_NAME (scope: $SCOPE)"
echo "  Location: $WORKTREE_DIR"
echo ""

# 1. Create git worktree
if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
  git worktree add "$WORKTREE_DIR" "$BRANCH_NAME" > /dev/null 2>&1
else
  git worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR" "$BASE_BRANCH" > /dev/null 2>&1
fi

# Write scope file
echo "$SCOPE" > "$WORKTREE_DIR/.worktree-scope"

# 2. Copy .env files
if [ -f "$CURRENT_ROOT/elements/.env" ]; then
  cp "$CURRENT_ROOT/elements/.env" "$WORKTREE_DIR/elements/.env" 2>/dev/null || true
fi

if [ "$SCOPE" != "elements" ] && [ -f "$CURRENT_ROOT/telecine/.env" ]; then
  cp "$CURRENT_ROOT/telecine/.env" "$WORKTREE_DIR/telecine/.env" 2>/dev/null || true
fi

# 3. Copy native build artifacts (needed for telecine scopes)
if [ "$SCOPE" != "elements" ] && [ -f "$WORKTREE_DIR/telecine/scripts/copy-native-build" ]; then
  cd "$WORKTREE_DIR/telecine"
  ./scripts/copy-native-build > /dev/null 2>&1 || true
  cd "$CURRENT_ROOT"
fi

# Point dev-projects at the main worktree's copy via Docker volume override.
# dev-projects is gitignored so worktrees only have committed stubs; the main
# copy has the full set of assets, src files, etc.
if [ -d "$CURRENT_ROOT/elements/dev-projects" ]; then
  ELEMENTS_ENV="$WORKTREE_DIR/elements/.env"
  grep -v "^DEV_PROJECTS_HOST=" "$ELEMENTS_ENV" > "$ELEMENTS_ENV.tmp" 2>/dev/null || true
  mv "$ELEMENTS_ENV.tmp" "$ELEMENTS_ENV"
  echo "DEV_PROJECTS_HOST=\"$CURRENT_ROOT/elements/dev-projects\"" >> "$ELEMENTS_ENV"
fi

# 4. Ensure shared infrastructure is running
if ! docker network inspect editframe-shared > /dev/null 2>&1; then
  echo "Starting shared infrastructure..."
  cd "$PROJECT_ROOT"
  docker compose --project-name editframe up -d > /dev/null 2>&1
  cd "$CURRENT_ROOT"
fi

# 5. Database setup (for web/render scopes)
if [ "$SCOPE" != "elements" ]; then
  WORKTREE_DATABASE="telecine-${SANITIZED_BRANCH}"

  # Check if template exists
  TEMPLATE_EXISTS=$(docker exec editframe-postgres psql -U postgres -tAc "SELECT 1 FROM pg_database WHERE datname = 'telecine-template'" 2>/dev/null)

  if [ "$TEMPLATE_EXISTS" = "1" ]; then
    echo "Cloning database from template..."
    docker exec editframe-postgres psql -U postgres \
      -c "CREATE DATABASE \"$WORKTREE_DATABASE\" TEMPLATE \"telecine-template\";" \
      > /dev/null 2>&1
  else
    echo "No template database found. Database will be created on first docker-compose run."
  fi
fi

# 6. Start elements runner and install dependencies
echo "Starting elements runner..."
cd "$WORKTREE_DIR/elements"
./scripts/docker-compose up -d runner > /dev/null 2>&1

echo "Installing elements dependencies..."
./scripts/npm install > /dev/null 2>&1

echo "Starting elements dev server..."
./scripts/docker-compose up -d dev-projects > /dev/null 2>&1
cd "$CURRENT_ROOT"

# 8. Start telecine containers (for web/render scopes)
if [ "$SCOPE" != "elements" ]; then
  # Set profile based on scope
  case "$SCOPE" in
    web)    export COMPOSE_PROFILES="" ;;
    render) export COMPOSE_PROFILES="render" ;;
  esac

  # Start telecine runner and install dependencies first
  echo "Starting telecine runner..."
  cd "$WORKTREE_DIR/telecine"
  ./scripts/docker-compose up -d runner > /dev/null 2>&1

  echo "Installing telecine dependencies..."
  ./scripts/npm install > /dev/null 2>&1

  echo "Starting telecine services ($SCOPE)..."
  ./scripts/docker-compose up -d > /dev/null 2>&1
  cd "$CURRENT_ROOT"

  # Run delta migrations if template was used (applies only new branch-specific migrations)
  if [ "$TEMPLATE_EXISTS" = "1" ]; then
    echo "Applying delta migrations..."
    cd "$WORKTREE_DIR/telecine"
    ./scripts/migrate-db > /dev/null 2>&1 || true
    cd "$CURRENT_ROOT"
  else
    # No template: run full migrations + seed
    echo "Running full migrations and seed..."
    cd "$WORKTREE_DIR/telecine"
    ./scripts/migrate-db > /dev/null 2>&1 || true
    ./scripts/seed > /dev/null 2>&1 || true
    cd "$CURRENT_ROOT"
  fi

  # Generate EF_TOKEN for elements to talk to this worktree's telecine
  TELECINE_PROJECT_NAME="telecine-${SANITIZED_BRANCH}"
  cd "$WORKTREE_DIR/telecine"
  . scripts/worktree-config > /dev/null 2>&1 || true

  EF_TOKEN=$(./scripts/run node \
    --import 'data:text/javascript,import { register } from "node:module"; import { pathToFileURL } from "node:url"; register("./loader.js", pathToFileURL("./"));' \
    scripts/generate-forever-token.ts 2>&1 | tail -n1) || true
  cd "$CURRENT_ROOT"

  if [ -n "$EF_TOKEN" ] && ! echo "$EF_TOKEN" | grep -q "Error"; then
    ELEMENTS_ENV="$WORKTREE_DIR/elements/.env"
    # Determine telecine web container host
    TELECINE_WEB_HOST="http://telecine-${SANITIZED_BRANCH}-web-1:3000"

    # Remove existing lines if present, then add
    grep -v "^EF_TOKEN=\|^EF_HOST=\|^VITEST_BROWSER_MODE=" "$ELEMENTS_ENV" > "$ELEMENTS_ENV.tmp" 2>/dev/null || true
    mv "$ELEMENTS_ENV.tmp" "$ELEMENTS_ENV"
    echo "EF_TOKEN=\"$EF_TOKEN\"" >> "$ELEMENTS_ENV"
    echo "EF_HOST=\"$TELECINE_WEB_HOST\"" >> "$ELEMENTS_ENV"
    echo "VITEST_BROWSER_MODE=\"connect\"" >> "$ELEMENTS_ENV"
  fi
fi

# Calculate display info
if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
  DOMAIN="main.localhost"
else
  DOMAIN="${SANITIZED_BRANCH}.localhost"
fi

echo ""
echo "Worktree created: $BRANCH_NAME (scope: $SCOPE)"
echo "  Location:  $WORKTREE_DIR"
if [ "$SCOPE" != "elements" ]; then
  echo "  Telecine:  http://${DOMAIN}:3000"
fi
echo "  Elements:  http://${DOMAIN}:4321"
echo ""
echo "Lifecycle:"
echo "  Pause:     scripts/pause-worktree $BRANCH_NAME"
echo "  Resume:    scripts/resume-worktree $BRANCH_NAME"
if [ "$SCOPE" = "elements" ]; then
  echo "  Upgrade:   scripts/upgrade-worktree $BRANCH_NAME web"
elif [ "$SCOPE" = "web" ]; then
  echo "  Upgrade:   scripts/upgrade-worktree $BRANCH_NAME render"
fi
echo "  Merge:     scripts/merge-worktree $BRANCH_NAME"
echo "  Remove:    scripts/remove-worktree $BRANCH_NAME"
echo ""
