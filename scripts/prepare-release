#!/usr/bin/env bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

if [ -z "$1" ]; then
  echo "Usage: $0 <version>"
  echo "Example: $0 0.27.0"
  exit 1
fi

VERSION="$1"
TAG_NAME="v${VERSION}"

# Ensure we're in the monorepo root
cd "$PROJECT_ROOT"

# Check if gh CLI is installed
if ! command -v gh &> /dev/null; then
  echo "Error: GitHub CLI (gh) is required but not installed."
  echo "Install it from: https://cli.github.com/"
  exit 1
fi

# Check if gh is authenticated
if ! gh auth status &> /dev/null; then
  echo "Error: GitHub CLI is not authenticated."
  echo "Run: gh auth login"
  exit 1
fi

# Get the repository name from git remote (elements remote)
# In monorepo, check for elements remote; otherwise use origin
cd "$PROJECT_ROOT"
if git remote | grep -q "^elements$"; then
  REMOTE_URL=$(git remote get-url elements 2>/dev/null || echo "")
else
  cd "$PROJECT_ROOT/elements"
  REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
  cd "$PROJECT_ROOT"
fi

if [ -n "$REMOTE_URL" ]; then
  # Extract repo name and remove .git suffix if present
  REPO_NAME=$(echo "$REMOTE_URL" | sed -E 's/.*github.com[:/]([^/]+\/[^/]+)\.git$/\1/' | sed -E 's/.*github.com[:/]([^/]+\/[^/]+)$/\1/')
else
  REPO_NAME="editframe/elements"
fi
echo "Detected repository: $REPO_NAME"

# Step 1: Run prepare-release in elements
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Step 1: Running prepare-release in elements"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cd "$PROJECT_ROOT/elements"
"$PROJECT_ROOT/elements/scripts/prepare-release" "$VERSION"

# Step 2: Wait for GitHub Actions workflow to complete
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Step 2: Waiting for GitHub Actions workflow to complete"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cd "$PROJECT_ROOT"

"$PROJECT_ROOT/scripts/wait-for-elements-action" "release.yaml"

# Step 3: Update editframe packages in telecine
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Step 3: Updating @editframe packages in telecine"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cd "$PROJECT_ROOT/telecine"
"$PROJECT_ROOT/telecine/scripts/update-editframe-packages" "$VERSION"

# Step 4: Run full-render tests in telecine
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Step 4: Running full-render tests in telecine"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cd "$PROJECT_ROOT/telecine"

# Check if working tree is clean before running tests
if ! git diff-index --quiet HEAD --; then
  echo "Warning: Working tree has uncommitted changes. Staging them for commit..."
  git add package.json package-lock.json
fi

# Run full-render tests using the telecine test script
"$PROJECT_ROOT/telecine/scripts/test" --run lib/queues/units-of-work/Render/full-render

if [ $? -ne 0 ]; then
  echo "Error: Telecine full-render tests failed!"
  exit 1
fi

echo "✅ Telecine full-render tests passed"

# Step 5: Commit and push changes to main
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Step 5: Committing and pushing changes to main"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cd "$PROJECT_ROOT/telecine"

# Check if there are changes to commit
if git diff-index --quiet HEAD --; then
  echo "No changes to commit in telecine"
else
  # Ensure we're on main branch
  CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)
  if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ]; then
    echo "Warning: Not on main branch (currently on $CURRENT_BRANCH)"
    echo "Switching to main branch..."
    git checkout main
  fi

  git commit -m "Update @editframe packages to v${VERSION}"
  echo "✅ Changes committed"
fi

# Push telecine subtree to telecine remote using push-telecine script
cd "$PROJECT_ROOT"
"$PROJECT_ROOT/scripts/push-telecine" main

# Step 6: Wait for GitHub Actions workflow to complete
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Step 6: Waiting for telecine deployment action to complete"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
cd "$PROJECT_ROOT"

"$PROJECT_ROOT/scripts/wait-for-telecine-action" "deploy.yaml"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Release preparation complete!"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Version: $VERSION"
echo "Tag: $TAG_NAME"
echo "Packages published to npm"
echo "Telecine updated and tested"
echo "Changes pushed to main"
echo "Telecine deployment completed"

