### Performance Optimization
- **Concurrent request limits**: Prevent resource exhaustion
- **Metadata caching**: Cache video metadata for repeated requests
- **Resource cleanup**: Proper disposal of FFmpeg resources
- **Memory management**: Monitor and limit transcoding memory usage

### Testing JIT Endpoints
```typescript
// Integration testing for transcoding endpoints using vitest
import { describe, test, expect, vi, beforeEach } from 'vitest';
import { createServer } from './server.js';
import { transcodeVideoSegment } from '../lib/transcode/src/jit/JitTranscoder.js';

// Mock the JitTranscoder for unit tests
vi.mock('../lib/transcode/src/jit/JitTranscoder.js');

describe('JIT Transcoding API', () => {
  let server: any;
  
  beforeEach(() => {
    server = createServer();
    vi.clearAllMocks();
  });

  describe('Quality Presets', () => {
    test('should transcode 2s segment with low quality preset', async () => {
      const mockResult = {
        success: true,
        outputData: new Uint8Array([0x00, 0x00, 0x00, 0x20, 0x66, 0x74, 0x79, 0x70]), // Mock MP4 header
        actualStartTimeMs: 0,
        actualDurationMs: 2000
      };
      
      vi.mocked(transcodeVideoSegment).mockResolvedValue(mockResult);
      
      const response = await fetch(
        `http://localhost:3001/api/v1/transcode/low?url=https://example.com/video.mp4&start=0`
      );
      
      expect(response.status).toBe(200);
      expect(response.headers.get('content-type')).toBe('video/mp4');
      expect(transcodeVideoSegment).toHaveBeenCalledWith({
        url: 'https://example.com/video.mp4',
        startTimeMs: 0,
        durationMs: 2000,
        width: 480,
        height: 270,
        videoBitrate: 400000,
        audioBitrate: 64000,
        audioChannels: 2,
        audioSampleRate: 48000,
        audioCodec: 'aac'
      });
    });

    test('should reject custom preset for security', async () => {
      const response = await fetch(
        `http://localhost:3001/api/v1/transcode/custom?url=https://example.com/video.mp4&start=0`
      );
      
      expect(response.status).toBe(400);
      expect(await response.text()).toContain('Invalid quality preset');
    });
  });

  describe('Validation', () => {
    test('should reject misaligned start times', async () => {
      const response = await fetch(
        `http://localhost:3001/api/v1/transcode/low?url=https://example.com/video.mp4&start=1500`
      );
      
      expect(response.status).toBe(400);
      expect(await response.text()).toContain('2s boundaries');
    });

    test('should reject invalid preset', async () => {
      const response = await fetch(
        `http://localhost:3001/api/v1/transcode/invalid?url=https://example.com/video.mp4&start=0`
      );
      
      expect(response.status).toBe(400);
      expect(await response.text()).toContain('Invalid quality preset');
    });

    test('should reject missing url parameter', async () => {
      const response = await fetch(
        `http://localhost:3001/api/v1/transcode/low?start=0`
      );
      
      expect(response.status).toBe(400);
    });
  });

  describe('Error Handling', () => {
    test('should handle transcoding failures gracefully', async () => {
      vi.mocked(transcodeVideoSegment).mockRejectedValue(new Error('Network error'));
      
      const response = await fetch(
        `http://localhost:3001/api/v1/transcode/low?url=https://example.com/video.mp4&start=0`
      );
      
      expect(response.status).toBe(500);
      expect(await response.text()).toContain('Transcoding failed');
    });
  });
});
```

## GraphQL Integration

### Hasura Engine (`services/graphql-engine/`)
- Auto-generated GraphQL API from PostgreSQL schema
- Role-based access control (RBAC)
- Real-time subscriptions support
- Custom business logic through actions and events

### Client Integration
```typescript
// Progressive enhancement pattern
const AllProjects = progressiveQuery(
  "org-reader", // Hasura role
  graphql(`
    query AllProjects {
      video_projects(order_by: { created_at: desc }) {
        id
        title
      }
    }
  `),
);

// Server-side usage
export const loader = requireSession(async function loader(args) {
  return serverQuery(args, AllProjects, {});
});

// Client-side subscription
const result = useSubscriptionForQuery(
  data.token,
  AllProjects,
  {},
  data.result, // Initial server data
);
```

### Security Roles
- **user**: Personal data access
- **primary**: Organization owner privileges
- **org-admin**: Administrative actions
- **org-editor**: Content modification
- **org-viewer**: Read-only access

