        <div className="h-4 bg-gray-200 rounded w-1/6"></div>
      </div>
    ))}
  </div>
);
```

## Bulk Actions Pattern

```tsx
interface BulkActionsTableProps {
  items: RowData[];
}

export default function BulkActionsTable({ items }: BulkActionsTableProps) {
  const [selectedRows, setSelectedRows] = useState<Set<string>>(new Set());
  
  const handleSelectAll = (checked: boolean) => {
    setSelectedRows(checked ? new Set(items.map(item => item.id)) : new Set());
  };
  
  const handleSelectRow = (id: string, checked: boolean) => {
    const newSelected = new Set(selectedRows);
    if (checked) {
      newSelected.add(id);
    } else {
      newSelected.delete(id);
    }
    setSelectedRows(newSelected);
  };
  
  const columnsWithSelection = [
    {
      name: (
        <input
          type="checkbox"
          checked={selectedRows.size === items.length && items.length > 0}
          onChange={(e) => handleSelectAll(e.target.checked)}
        />
      ),
      content: (row: RowData) => (
        <input
          type="checkbox"
          checked={selectedRows.has(row.id)}
          onChange={(e) => handleSelectRow(row.id, e.target.checked)}
        />
      )
    },
    ...columns
  ];
  
  return (
    <div>
      {selectedRows.size > 0 && (
        <BulkActionsBar 
          selectedCount={selectedRows.size}
          onBulkDelete={() => handleBulkDelete(Array.from(selectedRows))}
          onBulkEdit={() => handleBulkEdit(Array.from(selectedRows))}
        />
      )}
      
      <Table
        rows={items}
        columns={columnsWithSelection}
        emptyResultMessage="No items found"
        rowClassName={(row) => selectedRows.has(row.id) ? "bg-blue-50" : undefined}
      />
    </div>
  );
}
```

## Export Functionality

```tsx
export const action = async (args: Route.ActionArgs) => {
  if (args.request.method === "POST") {
    const formData = await args.request.formData();
    const action = formData.get("action");
    
    if (action === "export") {
      const session = await requireCookieOrTokenSession(args.request);
      const items = await fetchAllItems(session.orgId);
      
      const csv = generateCSV(items);
      
      return new Response(csv, {
        headers: {
          "Content-Type": "text/csv",
          "Content-Disposition": `attachment; filename="items-${Date.now()}.csv"`
        }
      });
    }
  }
};

// In component
const ExportButton = () => {
  const submit = useSubmit();
  
  return (
    <Button
      mode="secondary"
      onClick={() => {
        submit({ action: "export" }, { method: "post" });
      }}
    >
      Export CSV
    </Button>
  );
};
```

## Testing Patterns

```typescript
import { render, screen, fireEvent } from "@testing-library/react";
import { Table } from "~/components/Table";

test("renders table with data", () => {
  const data = [
    { id: "1", name: "Item 1", status: "active" },
    { id: "2", name: "Item 2", status: "inactive" }
  ];
  
  const columns = [
    { name: "Name", content: ({ name }: any) => name },
    { name: "Status", content: ({ status }: any) => status }
  ];
  
  render(
    <Table
      rows={data}
      columns={columns}
      emptyResultMessage="No items"
    />
  );
  
  expect(screen.getByText("Item 1")).toBeInTheDocument();
  expect(screen.getByText("Item 2")).toBeInTheDocument();
});

test("handles row click navigation", () => {
  const mockNavigate = vi.fn();
  
  render(
    <Table
      rows={data}
      columns={columns}
      buildRowURL={(row) => `/items/${row.id}`}
      emptyResultMessage="No items"
    />
  );
  
  fireEvent.click(screen.getByText("Item 1"));
  expect(mockNavigate).toHaveBeenCalledWith("/items/1");
});
```

## Best Practices

1. **Use TypeScript interfaces** for row data
2. **Implement proper loading states** during navigation
3. **Handle empty states** with helpful messages
4. **Make tables responsive** on mobile devices
5. **Use semantic HTML** for accessibility
6. **Implement keyboard navigation** where appropriate
7. **Optimize for large datasets** with pagination
8. **Test interactive elements** thoroughly
9. **Follow consistent styling** patterns
10. **Consider performance** with large numbers of rows
