#!/usr/bin/env bash
# Build, push, and run a one-off Cloud Run Job to do a GPU render test:
#   Renders a simple HTML composition via EGL + h264_nvenc, uploads the
#   resulting MP4 to GCS, and prints a signed download URL.
#
# Usage:
#   telecine/scripts/deploy-gpu-render-test-job [--skip-build] [--logs-only]
#
# Options:
#   --skip-build   Skip docker build+push, re-run existing image.
#   --logs-only    Skip build+create, just stream logs from the last execution.

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

set -euo pipefail

SKIP_BUILD=0
LOGS_ONLY=0
RENDER_MODE=both
for arg in "$@"; do
  case $arg in
    --skip-build) SKIP_BUILD=1 ;;
    --logs-only)  LOGS_ONLY=1; SKIP_BUILD=1 ;;
    --mode=*)     RENDER_MODE="${arg#--mode=}" ;;
  esac
done

REPO=us-central1-docker.pkg.dev/editframe/telecine-artifacts
JOB_NAME=telecine-gpu-render-test
REGION=us-central1
PROJECT=editframe
IMAGE_NAME=gpu-render-test
GIT_SHA=$(git -C "${SCRIPT_DIR}" rev-parse HEAD 2>/dev/null || echo "latest")
IMAGE="${REPO}/${IMAGE_NAME}:${GIT_SHA}"

if [ "$LOGS_ONLY" -eq 0 ]; then
  if [ "$SKIP_BUILD" -eq 0 ]; then
    echo "==> Building image..."
    "${SCRIPT_DIR}/build-docker-prod" "${IMAGE_NAME}"

    echo "==> Pushing image..."
    docker push "${IMAGE}"
  fi

  echo "==> Creating/updating Cloud Run Job ${JOB_NAME}..."
  gcloud alpha run jobs create "${JOB_NAME}" \
    --project="${PROJECT}" \
    --region="${REGION}" \
    --image="${IMAGE}" \
    --service-account=telecine-queues@editframe.iam.gserviceaccount.com \
    --max-retries=0 \
    --task-timeout=300s \
    --cpu=8 \
    --memory=32Gi \
    --gpu=1 \
    --gpu-type=nvidia-l4 \
    --no-gpu-zonal-redundancy \
    --vpc-egress=private-ranges-only \
    --network=default \
    --subnet=default \
    --set-env-vars="NODE_ENV=production,PINO_LOG_LEVEL=debug,STORAGE_BUCKET=telecine-dot-dev-data-4fedc83,RENDER_MODE=${RENDER_MODE}" \
  2>/dev/null || \
  gcloud alpha run jobs update "${JOB_NAME}" \
    --project="${PROJECT}" \
    --region="${REGION}" \
    --image="${IMAGE}" \
    --service-account=telecine-queues@editframe.iam.gserviceaccount.com \
    --max-retries=0 \
    --task-timeout=300s \
    --cpu=8 \
    --memory=32Gi \
    --gpu=1 \
    --gpu-type=nvidia-l4 \
    --no-gpu-zonal-redundancy \
    --vpc-egress=private-ranges-only \
    --network=default \
    --subnet=default \
    --set-env-vars="NODE_ENV=production,PINO_LOG_LEVEL=debug,STORAGE_BUCKET=telecine-dot-dev-data-4fedc83,RENDER_MODE=${RENDER_MODE}"

  echo "==> Executing job..."
  gcloud alpha run jobs execute "${JOB_NAME}" \
    --project="${PROJECT}" \
    --region="${REGION}" \
    --wait
fi

echo "==> Streaming logs..."
EXECUTION=$(gcloud run jobs executions list \
  --job="${JOB_NAME}" \
  --project="${PROJECT}" \
  --region="${REGION}" \
  --limit=1 \
  --format="value(name)")

echo "Execution: ${EXECUTION}"
gcloud logging read \
  "resource.type=cloud_run_job AND resource.labels.job_name=${JOB_NAME} AND resource.labels.execution_name=${EXECUTION}" \
  --project="${PROJECT}" \
  --order=asc \
  --format="value(textPayload)" \
  --limit=500
