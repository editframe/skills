#!/usr/bin/env bash
set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Copy native build artifacts (required before startup)
"${SCRIPT_DIR}/../telecine/scripts/copy-native-build"

# Delegate to telecine's start script
# It handles npm install, docker-compose, migrations, and seeding
"${SCRIPT_DIR}/../telecine/scripts/start" "$@"

