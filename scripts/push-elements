#!/usr/bin/env bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

cd "$PROJECT_ROOT"

WAIT_FOR_ACTION=false
BRANCH="main"

while [[ $# -gt 0 ]]; do
  case $1 in
    --wait)
      WAIT_FOR_ACTION=true
      shift
      ;;
    --branch)
      BRANCH="$2"
      shift 2
      ;;
    *)
      BRANCH="$1"
      shift
      ;;
  esac
done

git fetch elements "$BRANCH" 2>/dev/null || true

SPLIT=$(git subtree split --prefix=elements --onto="elements/$BRANCH" --ignore-joins HEAD 2>/dev/null)

git push elements "${SPLIT}:${BRANCH}" --force-with-lease 2>&1 | grep -v "^$"

echo "pushed elements -> ${BRANCH} (${SPLIT:0:10})"

if [ "$WAIT_FOR_ACTION" = "true" ]; then
  "$SCRIPT_DIR/wait-for-elements-action" "release.yaml"
fi
