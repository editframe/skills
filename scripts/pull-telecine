#!/usr/bin/env bash
# Pull changes from telecine remote into the monorepo's telecine/ subtree.
# Use this when changes were merged directly to telecine/main outside the monorepo.

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

cd "$PROJECT_ROOT"

BRANCH="main"

while [[ $# -gt 0 ]]; do
  case $1 in
    --branch)
      BRANCH="$2"
      shift 2
      ;;
    *)
      BRANCH="$1"
      shift
      ;;
  esac
done

git subtree pull --prefix=telecine telecine "$BRANCH" --squash 2>&1

echo "pulled telecine/${BRANCH} -> telecine/"
