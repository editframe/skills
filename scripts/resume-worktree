#!/usr/bin/env bash
# Restart stopped containers for a worktree.
#
# Usage: resume-worktree <branch-name>

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

if [ -z "$1" ]; then
  echo "Usage: $0 <branch-name>" >&2
  exit 1
fi

BRANCH_NAME="$1"
MAIN_WORKTREE=$(git rev-parse --show-toplevel)
EDITFRAME_DIR=$(dirname "$(dirname "$(dirname "$MAIN_WORKTREE")")")
WORKTREES_DIR="$EDITFRAME_DIR/worktrees"

sanitize_branch_name() {
  local name="$1"
  name=$(echo "$name" | tr '[:upper:]' '[:lower:]')
  name=$(echo "$name" | sed 's/[^a-z0-9]/-/g')
  name=$(echo "$name" | sed 's/^-\+//; s/-\+$//')
  name=$(echo "$name" | sed 's/-\+/-/g')
  name=$(echo "$name" | cut -c1-63)
  name=$(echo "$name" | sed 's/-$//')
  echo "$name"
}

SANITIZED_BRANCH=$(sanitize_branch_name "$BRANCH_NAME")
WORKTREE_DIR="$WORKTREES_DIR/$SANITIZED_BRANCH"
TELECINE_WORKTREE_DIR="$WORKTREE_DIR/telecine"
ELEMENTS_WORKTREE_DIR="$WORKTREE_DIR/elements"

SCOPE="web"
if [ -f "$WORKTREE_DIR/.worktree-scope" ]; then
  SCOPE=$(cat "$WORKTREE_DIR/.worktree-scope")
fi

echo "Resuming worktree: $BRANCH_NAME (scope: $SCOPE)"

if ! docker network inspect editframe-shared > /dev/null 2>&1; then
  echo "Starting shared infrastructure..."
  cd "$SCRIPT_DIR/.."
  docker compose --project-name editframe up -d > /dev/null 2>&1
fi

if [ "$SCOPE" != "elements" ] && [ -f "$TELECINE_WORKTREE_DIR/scripts/docker-compose" ]; then
  case "$SCOPE" in
    web)    export COMPOSE_PROFILES="" ;;
    render) export COMPOSE_PROFILES="render" ;;
  esac
  cd "$TELECINE_WORKTREE_DIR"
  ./scripts/docker-compose start > /dev/null 2>&1 || true
fi

if [ -f "$ELEMENTS_WORKTREE_DIR/scripts/docker-compose" ]; then
  cd "$ELEMENTS_WORKTREE_DIR"
  ./scripts/docker-compose start > /dev/null 2>&1 || true
fi

echo "Resumed."
