## Confirmation Dialog Pattern

```tsx
<Button
  mode="destructive"
  confirmation={{
    title: "Delete Item",
    description: "Are you sure you want to delete this item? This action cannot be undone.",
    confirmText: "Delete",
    cancelText: "Cancel"
  }}
  onConfirm={() => handleDelete(itemId)}
>
  Delete Item
</Button>
```

## Confirmation with Form Inputs

```tsx
<Button
  mode="destructive"
  confirmation={{
    title: "Archive Project",
    description: "Please provide a reason for archiving this project.",
    confirmText: "Archive",
    inputs: [
      {
        type: "textarea",
        name: "reason",
        label: "Reason for archiving",
        description: "This will be logged for audit purposes",
        schema: z.string().min(10, "Please provide at least 10 characters")
      }
    ]
  }}
  onConfirm={(values) => handleArchive(projectId, values.reason)}
>
  Archive Project
</Button>
```

## Challenge Text Pattern

```tsx
<Button
  mode="destructive"
  confirmation={{
    title: "Delete Organization",
    description: "This will permanently delete all data associated with this organization.",
    challengeText: orgName, // User must type this to confirm
    confirmText: "Delete Forever",
    cancelText: "Keep Organization"
  }}
  onConfirm={() => handleDeleteOrg(orgId)}
>
  Delete Organization
</Button>
```

## Fetcher-Based Actions

```tsx
import { useFetcher } from "react-router";

export default function ActionButton({ memberId, orgId }: { memberId: string; orgId: string }) {
  const fetcher = useFetcher<{ success: boolean }>();
  
  const isLoading = fetcher.state !== "idle";
  const isSuccess = fetcher.state === "idle" && !!fetcher.data?.success;
  const isError = fetcher.state === "idle" && !!fetcher.data && !fetcher.data.success;
  
  return (
    <div className="flex gap-2">
      <Button
        mode="destructive"
        disabled={isLoading}
        loading={isLoading}
        confirmation={{
          title: "Revoke Membership",
          description: "Are you sure you want to remove this member?",
          confirmText: "Remove member"
        }}
        onConfirm={() => {
          fetcher.submit(
            {},
            {
              method: "POST",
              action: `/organizations/${orgId}/members/${memberId}/revoke`
            }
          );
        }}
      >
        {isSuccess ? "Removed!" : "Remove"}
      </Button>
      
      {isError && (
        <span className="text-red-600 text-xs self-center">
          Action failed. Please try again.
        </span>
      )}
    </div>
  );
}
```

## Form Action Buttons

```tsx
import { useSubmit } from "react-router";

// Export action button
const ExportButton = () => {
  const submit = useSubmit();
  
  return (
    <Button
      mode="secondary"
      onClick={() => {
        submit({ action: "export" }, { method: "post" });
      }}
    >
      Export CSV
    </Button>
  );
};

// Bulk action button
const BulkDeleteButton = ({ selectedIds }: { selectedIds: string[] }) => {
  const submit = useSubmit();
  
  return (
    <Button
      mode="destructive"
      disabled={selectedIds.length === 0}
      confirmation={{
        title: `Delete ${selectedIds.length} items`,
        description: "Are you sure you want to delete the selected items?",
        confirmText: "Delete All"
      }}
      onConfirm={() => {
        submit(
          { action: "bulk_delete", ids: selectedIds },
          { method: "post" }
        );
      }}
    >
      Delete Selected ({selectedIds.length})
    </Button>
  );
};
```

## Link-Style Buttons

```tsx
import { Link } from "react-router";

// Navigation button
<Link to="/create-new">
  <Button mode="creative" icon={PlusIcon}>
