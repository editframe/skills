FROM node:22 AS builder

ENV NODE_ENV=production
ENV NODE_COMPILE_CACHE=/app/.compile-cache

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY lib/ lib/
COPY services/worker-render-finalizer/ services/worker-render-finalizer/
COPY tsconfig.json ./

WORKDIR /app/services/worker-render-finalizer
RUN npx vite build

WORKDIR /app

RUN rm -rf node_modules && npm install --only=production

COPY scripts/docker-compile-cache-prewarm /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-compile-cache-prewarm && \
    docker-compile-cache-prewarm "node /app/services/worker-render-finalizer/dist/server.js" 3000 /health

FROM node:22-slim

ENV NODE_ENV=production
ENV NODE_COMPILE_CACHE=/app/.compile-cache

WORKDIR /app

COPY --from=builder /app/package.json /app/package.json
COPY --from=builder /app/node_modules/ /app/node_modules/
COPY --from=builder /app/services/worker-render-finalizer/dist/ /app/services/worker-render-finalizer/dist/
COPY --from=builder /app/.compile-cache/ /app/.compile-cache/

CMD ["node", "/app/services/worker-render-finalizer/dist/server.js"]
