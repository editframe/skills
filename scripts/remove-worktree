#!/usr/bin/env bash
# Remove worktree and branch
# Can be run from within worktree directory or from main with branch name argument
# Usage: ./scripts/remove-worktree [--force] [branch-name]
# Fails if branch is not merged into main or identical to main (unless --force is used)

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Parse arguments
FORCE=false
BRANCH_ARG=""

if [ "$1" = "--force" ]; then
  FORCE=true
  BRANCH_ARG="$2"
elif [ "$2" = "--force" ]; then
  FORCE=true
  BRANCH_ARG="$1"
elif [ -n "$1" ]; then
  BRANCH_ARG="$1"
fi

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

# Detect current worktree and branch
CURRENT_ROOT=$(git rev-parse --show-toplevel)
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)

# Check if branch name provided as argument (running from main)
if [ -n "$BRANCH_ARG" ]; then
  BRANCH_NAME="$BRANCH_ARG"
  # Find worktree for this branch using porcelain output
  WORKTREE_ROOT=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^worktree[[:space:]]+(.+)$ ]]; then
      WORKTREE_ROOT="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^branch[[:space:]]+refs/heads/(.+)$ ]]; then
      if [ "${BASH_REMATCH[1]}" = "$BRANCH_NAME" ]; then
        break
      fi
      WORKTREE_ROOT=""
    fi
  done < <(git worktree list --porcelain)
  
  if [ -z "$WORKTREE_ROOT" ]; then
    echo "Error: Could not find worktree for branch '$BRANCH_NAME'" >&2
    exit 1
  fi
else
  # Running from within worktree
  WORKTREE_ROOT="$CURRENT_ROOT"
  BRANCH_NAME="$CURRENT_BRANCH"
  
  if [ -z "$BRANCH_NAME" ]; then
    echo "Error: Could not detect git branch name. Ensure you are on a valid branch or provide branch name as argument." >&2
    exit 1
  fi
  
  # Check if we're in main worktree
  if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
    echo "Error: Cannot remove main/master worktree. This script should be run from a worktree branch or with a branch name argument." >&2
    exit 1
  fi
fi

# Find main worktree
MAIN_WORKTREE=$(git worktree list | grep -E '\[main\]|\[master\]' | awk '{print $1}' | head -1)
if [ -z "$MAIN_WORKTREE" ]; then
  echo "Error: Could not find main worktree" >&2
  exit 1
fi

# Determine main branch name
cd "$MAIN_WORKTREE"
MAIN_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)
if [ "$MAIN_BRANCH" != "main" ] && [ "$MAIN_BRANCH" != "master" ]; then
  if git show-ref --verify --quiet "refs/heads/main"; then
    MAIN_BRANCH="main"
  elif git show-ref --verify --quiet "refs/heads/master"; then
    MAIN_BRANCH="master"
  else
    echo "Error: Could not determine main branch" >&2
    exit 1
  fi
fi

echo "🗑️  Removing worktree for branch '$BRANCH_NAME'"
echo "   Worktree: $WORKTREE_ROOT"
if [ "$FORCE" = true ]; then
  echo "   ⚠️  Force mode: Skipping merge check"
fi
echo ""

# Check if branch has been merged into main or is identical to main (unless --force)
if [ "$FORCE" = false ]; then
  cd "$MAIN_WORKTREE"
  git checkout "$MAIN_BRANCH" > /dev/null 2>&1

  # Check if branch is merged
  IS_MERGED=false
  if git branch --merged | grep -q "^\s*${BRANCH_NAME}$" || git branch --merged | grep -q "^\s*\*.*${BRANCH_NAME}$"; then
    IS_MERGED=true
  fi

  # Check if branch is identical to main (no commits ahead)
  IS_IDENTICAL=false
  if git rev-parse --verify "refs/heads/${BRANCH_NAME}" > /dev/null 2>&1; then
    BRANCH_COMMIT=$(git rev-parse "refs/heads/${BRANCH_NAME}")
    MAIN_COMMIT=$(git rev-parse "refs/heads/${MAIN_BRANCH}")
    if [ "$BRANCH_COMMIT" = "$MAIN_COMMIT" ]; then
      IS_IDENTICAL=true
    fi
  fi

  if [ "$IS_MERGED" = false ] && [ "$IS_IDENTICAL" = false ]; then
    echo "❌ Error: Branch '$BRANCH_NAME' has not been merged into '$MAIN_BRANCH' and is not identical to main" >&2
    echo ""
    echo "Please merge the branch first:"
    echo "  ./scripts/merge-worktree $BRANCH_NAME"
    echo ""
    echo "Or use --force to remove without merging:"
    echo "  ./scripts/remove-worktree --force $BRANCH_NAME"
    exit 1
  fi

  if [ "$IS_IDENTICAL" = true ]; then
    echo "✅ Branch is identical to main (no changes). Proceeding with cleanup..."
  else
    echo "✅ Branch is merged. Proceeding with cleanup..."
  fi
  echo ""
fi

# Read scope to know what was running
WORKTREE_SCOPE="web"
if [ -f "$WORKTREE_ROOT/.worktree-scope" ]; then
  WORKTREE_SCOPE=$(cat "$WORKTREE_ROOT/.worktree-scope")
fi

# Stop and remove Docker containers
echo "1️⃣  Stopping and removing Docker containers..."
if [ "$WORKTREE_SCOPE" != "elements" ] && [ -d "$WORKTREE_ROOT/telecine" ] && [ -f "$WORKTREE_ROOT/telecine/scripts/docker-compose" ]; then
  cd "$WORKTREE_ROOT/telecine"
  # Source worktree-config to get Docker project name
  if [ -f "$WORKTREE_ROOT/telecine/scripts/worktree-config" ]; then
    . "$WORKTREE_ROOT/telecine/scripts/worktree-config" 2>/dev/null || true
  fi
  # Stop and remove containers, volumes, and networks
  ./scripts/docker-compose down -v --remove-orphans 2>&1 | grep -v "No such" || true
  echo "   ✅ Telecine Docker resources stopped and removed"

  # Drop worktree database from shared PostgreSQL
  if [ -n "$WORKTREE_DATABASE" ] && [ "$WORKTREE_DATABASE" != "telecine-main" ]; then
    if docker ps --filter "name=editframe-postgres" --format "{{.Names}}" | grep -q editframe-postgres; then
      docker exec editframe-postgres psql -U postgres \
        -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$WORKTREE_DATABASE' AND pid <> pg_backend_pid();" \
        -c "DROP DATABASE IF EXISTS \"$WORKTREE_DATABASE\";" > /dev/null 2>&1 || true
      echo "   ✅ Database '$WORKTREE_DATABASE' dropped"
    fi
  fi
fi

if [ -d "$WORKTREE_ROOT/elements" ]; then
  cd "$WORKTREE_ROOT/elements"
  # Source worktree-config to get Docker project name
  if [ -f "$WORKTREE_ROOT/elements/scripts/worktree-config" ]; then
    . "$WORKTREE_ROOT/elements/scripts/worktree-config" 2>/dev/null || true
  fi
  # Use elements docker-compose script if available, otherwise fall back to docker compose
  if [ -f "$WORKTREE_ROOT/elements/scripts/docker-compose" ]; then
    ./scripts/docker-compose down -v --remove-orphans 2>&1 | grep -v "No such" || true
  elif [ -f "$WORKTREE_ROOT/elements/docker-compose.yaml" ]; then
    if command -v docker-compose > /dev/null 2>&1; then
      docker-compose -f "$WORKTREE_ROOT/elements/docker-compose.yaml" down -v --remove-orphans 2>&1 | grep -v "No such" || true
    elif docker compose version > /dev/null 2>&1; then
      docker compose -f "$WORKTREE_ROOT/elements/docker-compose.yaml" down -v --remove-orphans 2>&1 | grep -v "No such" || true
    fi
  fi
  echo "   ✅ Elements Docker resources stopped and removed"
fi

echo ""

# Remove git worktree
echo "2️⃣  Removing git worktree..."
cd "$MAIN_WORKTREE"
git worktree remove "$WORKTREE_ROOT" --force 2>&1 || {
  echo "   ⚠️  Git worktree removal had issues, but continuing..."
}
echo "   ✅ Git worktree removed"
echo ""

# Remove branch
echo "3️⃣  Removing branch..."
if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
  git branch -D "$BRANCH_NAME" 2>&1 || {
    echo "   ⚠️  Branch removal had issues, but continuing..."
  }
  echo "   ✅ Branch '$BRANCH_NAME' removed"
else
  echo "   ℹ️  Branch '$BRANCH_NAME' already removed"
fi
echo ""

# Clean up directory if still exists
if [ -d "$WORKTREE_ROOT" ]; then
  echo "4️⃣  Cleaning up directory..."
  rm -rf "$WORKTREE_ROOT"
  echo "   ✅ Directory removed"
  echo ""
fi

echo "✅ Worktree removal complete!"
echo ""
if [ "$FORCE" = true ]; then
  echo "Branch '$BRANCH_NAME' has been force removed (may not have been merged)."
else
  echo "Branch '$BRANCH_NAME' has been merged and removed."
fi

