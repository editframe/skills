FROM golang:1.23-alpine AS builder

RUN apk add --no-cache gcc g++ make

WORKDIR /app

COPY services/scheduler-go/go.mod services/scheduler-go/go.sum ./
RUN go mod download

COPY services/scheduler-go/ ./

RUN CGO_ENABLED=0 go build -o /scheduler ./cmd/scheduler

FROM alpine:latest

RUN apk add --no-cache ca-certificates curl

WORKDIR /app

COPY --from=builder /scheduler .

EXPOSE 3000

CMD ["./scheduler"]
