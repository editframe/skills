#!/usr/bin/env bash

# Wait for telecine deployment action to complete
# Usage: wait-for-telecine-action [workflow-file] [timeout-seconds]

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

cd "$PROJECT_ROOT"

# Get the repository name from git remote (telecine remote)
if git remote | grep -q "^telecine$"; then
  REMOTE_URL=$(git remote get-url telecine 2>/dev/null || echo "")
else
  cd "$PROJECT_ROOT/telecine"
  REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
  cd "$PROJECT_ROOT"
fi

if [ -n "$REMOTE_URL" ]; then
  # Extract repo name and remove .git suffix if present
  REPO_NAME=$(echo "$REMOTE_URL" | sed -E 's/.*github.com[:/]([^/]+\/[^/]+)\.git$/\1/' | sed -E 's/.*github.com[:/]([^/]+\/[^/]+)$/\1/')
else
  REPO_NAME="editframe/telecine"
fi

WORKFLOW_FILE="${1:-deploy.yaml}"
TIMEOUT="${2:-3600}"

"$SCRIPT_DIR/wait-for-github-action" "$REPO_NAME" "$WORKFLOW_FILE" "$TIMEOUT"

