#!/usr/bin/env bash


SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Source worktree configuration to get project name and domain
. "$SCRIPT_DIR/worktree-config"

# Ensure shared Traefik network exists (needed for all worktrees)
if ! docker network inspect telecine-traefik > /dev/null 2>&1; then
  echo "Creating shared Traefik network: telecine-traefik"
  docker network create telecine-traefik
fi

# Export absolute path to telecine root for docker-compose volume mounts
PROJECT_ROOT="$SCRIPT_DIR/.."
WORKTREE_ROOT=$(cd "$PROJECT_ROOT" && git rev-parse --show-toplevel 2>/dev/null || echo "$PROJECT_ROOT")

# Determine telecine root path
if [ -d "$WORKTREE_ROOT/telecine" ]; then
    TELECINE_ROOT="$WORKTREE_ROOT/telecine"
else
    TELECINE_ROOT="$WORKTREE_ROOT"
fi

# Export TELECINE_ROOT_HOST for docker-compose.yaml volume mounts
TELECINE_ROOT_HOST="$TELECINE_ROOT"
export TELECINE_ROOT TELECINE_ROOT_HOST

# Resolve elements path for docker-compose volume mounts
# Elements is at the same level as telecine in the workspace
ELEMENTS_PATH=""
if [ -d "$WORKTREE_ROOT/elements" ]; then
    # Elements is in the workspace root (same level as telecine)
    ELEMENTS_PATH="$WORKTREE_ROOT/elements"
elif [ -d "$PROJECT_ROOT/../elements" ]; then
    # Elements is sibling to telecine directory
    ELEMENTS_PATH="$PROJECT_ROOT/../elements"
else
    WORKTREE_PARENT=$(dirname "$WORKTREE_ROOT")
    if [ -d "$WORKTREE_PARENT/elements" ]; then
        # Main worktree pattern: ../elements
        ELEMENTS_PATH="$WORKTREE_PARENT/elements"
    elif [ -n "$WORKTREE_ID" ] && [ "$WORKTREE_ID" != "main" ] && [ -d "$WORKTREE_PARENT/elements-${WORKTREE_ID}" ]; then
        # Parallel worktree pattern: ../elements-<branch>
        ELEMENTS_PATH="$WORKTREE_PARENT/elements-${WORKTREE_ID}"
    fi
fi

export ELEMENTS_PATH

# Find all docker-compose files in the telecine directory
compose_files=""
root_compose_file=""

# Find root docker-compose.yaml
if [ -f "$TELECINE_ROOT/docker-compose.yaml" ]; then
    root_compose_file="$TELECINE_ROOT/docker-compose.yaml"
fi

# Find all docker-compose.*.yaml files in root
for file in "$TELECINE_ROOT"/docker-compose.*.yaml; do
    if [ -f "$file" ]; then
        compose_files="$compose_files"$'\n'"$file"
    fi
done

# Find all service-specific docker-compose.yaml files
if [ -d "$TELECINE_ROOT/services" ]; then
    for file in "$TELECINE_ROOT"/services/*/docker-compose.yaml; do
        if [ -f "$file" ]; then
            compose_files="$compose_files"$'\n'"$file"
        fi
    done
fi

# Handle main worktree vs regular worktree
if [ "$WORKTREE_DOMAIN" = "main.localhost" ]; then
    # Main worktree: include Traefik service by activating profile
    if [ -n "$root_compose_file" ]; then
        compose_files="$root_compose_file"$'\n'"$compose_files"
    fi
    export COMPOSE_PROFILES="main-worktree"
else
    # Worktree: include compose file but Traefik won't start (profile not activated)
    # Add worktree override to remove port mappings (services accessed via Traefik)
    worktree_override="$TELECINE_ROOT/docker-compose.worktree-override.yaml"
    if [ -f "$worktree_override" ]; then
        compose_files="$compose_files"$'\n'"$worktree_override"
    fi
    if [ -n "$root_compose_file" ]; then
        compose_files="$root_compose_file"$'\n'"$compose_files"
    fi
fi

# Remove any potential duplicate entries and empty lines, then build flags
compose_flags=""
for file in $(echo "$compose_files" | awk 'NF && !seen[$0]++'); do
    if [ -n "$file" ] && [ -f "$file" ]; then
        if [ -z "$compose_flags" ]; then
            compose_flags="-f $file"
        else
            compose_flags="$compose_flags -f $file"
        fi
    fi
done

# Trim leading/trailing whitespace
compose_flags=$(echo "$compose_flags" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

# Debug output
if [ -n "$CI" ]; then
    echo "Found docker-compose files: $compose_flags"
fi

# Run docker compose with worktree-specific project name
# COMPOSE_PROFILES is set above for main worktree to activate Traefik service
if [ -z "$compose_flags" ]; then
    echo "Error: No docker-compose files found in $TELECINE_ROOT" >&2
    exit 1
fi

# Change to TELECINE_ROOT so that ${PWD}/.env resolves correctly in compose files
# The compose files use ${PWD}/.env which expects to be run from the telecine directory
cd "$TELECINE_ROOT"

# Rebuild compose_flags with relative paths from TELECINE_ROOT
relative_compose_flags=""
for file in $(echo "$compose_files" | awk 'NF && !seen[$0]++'); do
    if [ -n "$file" ] && [ -f "$file" ]; then
        # Convert absolute paths to relative paths from TELECINE_ROOT
        rel_file="${file#$TELECINE_ROOT/}"
        # If path doesn't start with TELECINE_ROOT, use it as-is (already relative)
        if [ "$rel_file" = "$file" ]; then
            rel_file="$file"
        fi
        if [ -z "$relative_compose_flags" ]; then
            relative_compose_flags="-f $rel_file"
        else
            relative_compose_flags="$relative_compose_flags -f $rel_file"
        fi
    fi
done

# Export TELECINE_ROOT_HOST so docker-compose can use it in volume mounts
export TELECINE_ROOT_HOST

# Detect which compose command is available
if command -v docker-compose > /dev/null 2>&1; then
    # Use standalone docker-compose (hyphenated)
    docker-compose $relative_compose_flags --project-name "$WORKTREE_DOCKER_PROJECT_NAME" "$@"
elif docker compose version > /dev/null 2>&1; then
    # Use docker compose plugin (space-separated)
    docker compose $relative_compose_flags --project-name "$WORKTREE_DOCKER_PROJECT_NAME" "$@"
else
    echo "Error: Neither 'docker-compose' nor 'docker compose' is available" >&2
    exit 1
fi
