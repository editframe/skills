    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/browser-playwright": "^4.0.0",
    "eventsource-parser": "^3.0.0",
    "jsdom": "^26.1.0",
    "lefthook": "^1.7.14",
    "lit": "^3.3.1",
    "msw": "^2.10.2",
    "oxfmt": "^0.15.0",
    "oxlint": "^1.30.0",
    "playwright": "^1.53.0",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "publint": "^0.3.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rolldown": "^1.0.0-beta.57",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.15.7",
