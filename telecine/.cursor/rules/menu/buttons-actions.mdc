  </div>
);
```

## Conditional Action Buttons

```tsx
interface ConditionalActionsProps {
  canEdit: boolean;
  canDelete: boolean;
  item: { id: string; name: string };
}

const ConditionalActions = ({ canEdit, canDelete, item }: ConditionalActionsProps) => {
  if (!canEdit && !canDelete) {
    return <span className="text-gray-400 text-xs">No access</span>;
  }
  
  return (
    <div className="flex gap-2">
      {canEdit && (
        <Link to={`/items/${item.id}/edit`}>
          <Button mode="secondary">Edit</Button>
        </Link>
      )}
      
      {canDelete && (
        <Button
          mode="destructive"
          confirmation={{
            title: `Delete ${item.name}`,
            description: "This action cannot be undone.",
            confirmText: "Delete"
          }}
          onConfirm={() => handleDelete(item.id)}
        >
          Delete
        </Button>
      )}
    </div>
  );
};
```

## Disabled Button States

```tsx
// Conditional disable
<Button
  mode="primary"
  disabled={!isFormValid}
  title={!isFormValid ? "Please fill all required fields" : undefined}
>
  Submit
</Button>

// Loading disable
<Button
  mode="primary"
  disabled={isSubmitting}
  loading={isSubmitting}
>
  {isSubmitting ? "Saving..." : "Save"}
</Button>
```

