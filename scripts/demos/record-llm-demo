#!/usr/bin/env bash
# Records an LLM demo video in three clips:
#   clip-1-llm.mp4    — terminal showing Claude prompted + writing + rendering
#   clip-2-output.mp4 — the actual rendered weather video
#
# Usage: scripts/demos/record-llm-demo [output-dir]
#   output-dir defaults to /tmp/llm-demo

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS="$(cd "$SCRIPT_DIR/.." && pwd)"
MONOREPO="$(cd "$SCRIPTS/.." && pwd)"

OUT_DIR="${1:-/tmp/llm-demo}"
mkdir -p "$OUT_DIR"

CREATE_BIN="$MONOREPO/elements/packages/create/dist/index.js"
WORK_DIR="$OUT_DIR/weather-composition"

# ── 1. Scaffold a fresh project ───────────────────────────────────────────────
echo "→ Scaffolding project..."
rm -rf "$WORK_DIR"
cd "$OUT_DIR"
node "$CREATE_BIN" --directory weather-composition --yes
cd "$WORK_DIR"

# ── 2. Fetch live weather data ────────────────────────────────────────────────
echo "→ Fetching weather data..."
WEATHER_DATA=$(curl -s \
  "https://api.open-meteo.com/v1/forecast?latitude=37.45&longitude=-122.18&hourly=temperature_2m,precipitation_probability,weathercode&temperature_unit=fahrenheit&forecast_days=1&timezone=America/Los_Angeles" \
  | python3 -c "
import json, sys
d = json.load(sys.stdin)
h = d['hourly']
rows = []
for i in range(12):
    t = h['time'][i].split('T')[1]
    temp = int(h['temperature_2m'][i])
    precip = h['precipitation_probability'][i]
    rows.append(f'{t}: {temp}F, {precip}% precip')
print('\n'.join(rows))
")

# ── 3. Write the prompt file (avoids typing thousands of chars in expect) ─────
cat > "$WORK_DIR/prompt.txt" << PROMPT_EOF
Write an Editframe HTML weather forecast video for Menlo Oaks CA. Today's data:
$WEATHER_DATA

Use ef-timegroup (mode="sequence"), ef-text (split="word"). Root: class="w-[1920px] h-[1080px]".

3 scenes:
1. Title 3s — huge "MENLO OAKS", "HOURLY FORECAST", gradient rule, date. Word-stagger fade-up.
2. Bar chart 8s — 12 temp bars staggered grow-up. Scale heights to data range. Blue=cool, orange=warm. Labels above/below.
3. Summary 4s — giant LOW/HIGH temps with gradient text, condition pills, tagline.

Dark #0a0a0f bg, atmospheric blobs, animation-fill-mode: both. Do not touch src/index.js. No explanation — write ONLY the file, no text before or after.
PROMPT_EOF

# ── 4. Record Clip 1: LLM prompt + render in single terminal session ──────────
echo "→ Recording LLM + render session..."
CAST="$(mktemp /tmp/llm-demo-XXXXXX.cast)"
trap 'rm -f "$CAST"' EXIT

export WORK_DIR
export PROMPT_FILE="$WORK_DIR/prompt.txt"

"$SCRIPTS/record-cast" \
  "$SCRIPT_DIR/llm-demo.exp" \
  "$CAST" \
  --cols 100 \
  --rows 30

# Strip the shell setup noise, replace internal markers, compress gaps,
# then prepend a clean human-readable prompt being typed.
# Strip up to (but not including) the head -40 index.html output showing actual code,
# then prepend a clean command being typed followed by a "Writing..." line.
"$SCRIPTS/cast-edit" \
  --strip-until "ef-timegroup" \
  --replace "EF_CLAUDE_DONE_7x9q:" \
  --clamp-gaps 2.0 \
  --prepend-prompt $'~/weather-composition $ :claude "make a weather forecast video for Menlo Oaks CA" > index.html' \
  --prepend-pause 1.0 \
  --post-pause 0.5 \
  "$CAST"

# Render fullbleed 1920x1080 — terminal fills the entire frame
node "$SCRIPTS/render-cast" \
  --theme "dracula" \
  --font-px 20 \
  --idle-limit 2 \
  --width 1920 \
  --height 1080 \
  "$CAST" \
  "$OUT_DIR/clip-1-llm.mp4"

# ── 5. Clip 2: the rendered weather video ─────────────────────────────────────
if [[ -f "$WORK_DIR/output.mp4" ]]; then
  cp "$WORK_DIR/output.mp4" "$OUT_DIR/clip-2-output.mp4"
  echo "→ Clip 2: used output from live render"
else
  echo "→ Clip 2: Claude output not found — using reference composition"
  # Use the known-good reference composition
  cp "$SCRIPT_DIR/weather-demo/index.html" "$WORK_DIR/index.html"
  sed -i '' 's|./src/weather-demo.ts|./src/index.js|' "$WORK_DIR/index.html" 2>/dev/null || true
  cd "$WORK_DIR"
  npx editframe render -o "$OUT_DIR/clip-2-output.mp4"
fi

echo ""
echo "✔ Clips ready in $OUT_DIR:"
ls -lh "$OUT_DIR"/*.mp4
