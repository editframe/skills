#!/bin/bash

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Source worktree configuration to get project name
. "$SCRIPT_DIR/worktree-config"

# Determine elements root path
PROJECT_ROOT="$SCRIPT_DIR/.."
WORKTREE_ROOT=$(cd "$PROJECT_ROOT" && git rev-parse --show-toplevel 2>/dev/null || echo "$PROJECT_ROOT")

# Determine elements root path
if [ -d "$WORKTREE_ROOT/elements" ]; then
    ELEMENTS_ROOT="$WORKTREE_ROOT/elements"
else
    ELEMENTS_ROOT="$WORKTREE_ROOT"
fi

# Export ELEMENTS_ROOT_HOST for docker-compose.yaml volume mounts
ELEMENTS_ROOT_HOST="$ELEMENTS_ROOT"
export ELEMENTS_ROOT_HOST

# Export WORKTREE_ID for substitution (ensure it has a default)
export WORKTREE_ID="${WORKTREE_ID:-main}"

# Change to ELEMENTS_ROOT so that ${PWD}/.env resolves correctly in compose files
# The compose files use ${PWD}/.env which expects to be run from the elements directory
cd "$ELEMENTS_ROOT"

# Process compose file with sed to substitute WORKTREE_ID in label keys
# Docker Compose doesn't substitute variables in YAML keys, so we need to do it manually
COMPOSE_FILE="docker-compose.yaml"

# Check if file contains WORKTREE_ID or WORKTREE_DOMAIN (to avoid unnecessary processing)
if grep -qE '\${WORKTREE_ID|\${WORKTREE_DOMAIN' "$COMPOSE_FILE" 2>/dev/null; then
    # Create temp file in the same directory so .env file resolution works
    # Use process ID to make it unique and avoid conflicts
    PROCESSED_FILE="${COMPOSE_FILE}.processed.$$"
    trap "rm -f $PROCESSED_FILE" EXIT
    
    # Replace ${WORKTREE_ID:-main} with the actual WORKTREE_ID value (in both keys and values)
    # Replace ${WORKTREE_DOMAIN} with the actual WORKTREE_DOMAIN value
    sed -e "s|\${WORKTREE_ID:-main}|${WORKTREE_ID}|g" \
        -e "s|\${WORKTREE_DOMAIN}|${WORKTREE_DOMAIN}|g" \
        "$COMPOSE_FILE" > "$PROCESSED_FILE"
    
    # Execute docker-compose with processed file
    docker-compose \
      --project-name "$WORKTREE_DOCKER_PROJECT_NAME" \
      -f "$PROCESSED_FILE" \
      "$@"
    EXIT_CODE=$?
    
    # Clean up processed file after docker-compose completes
    rm -f "$PROCESSED_FILE"
    
    # Exit with the same code as docker-compose
    exit $EXIT_CODE
else
    # File doesn't need processing, use original
    docker-compose \
      --project-name "$WORKTREE_DOCKER_PROJECT_NAME" \
      -f "$COMPOSE_FILE" \
      "$@"
fi
