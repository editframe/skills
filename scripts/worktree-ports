#!/usr/bin/env bash
# Display port mappings for current worktree
# Run from telecine directory

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Source worktree config to get port variables
. "$SCRIPT_DIR/worktree-config"

echo "🔌 Port Mappings for Worktree: $WORKTREE_BRANCH"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "HTTP Services (via Traefik - same port for all worktrees):"
echo "   Web:              http://${WORKTREE_DOMAIN}:3000"
echo "   Mailhog Web UI:   http://mailhog.${WORKTREE_DOMAIN}:3000"
echo "   Playwright UI:    http://playwright.${WORKTREE_DOMAIN}:3000"
echo "   Otel Viewer:      http://otel-viewer.${WORKTREE_DOMAIN}:3000"
echo ""
echo "TCP Services (exposed on host for tool access):"
echo "   PostgreSQL:       localhost:${WORKTREE_POSTGRES_PORT}"
echo "   Valkey:           localhost:${WORKTREE_VALKEY_PORT}"
echo "   Mailhog SMTP:     localhost:${WORKTREE_MAILHOG_SMTP_PORT}"
echo ""
echo "💡 Note:"
echo "   - All containers use standard internal ports (5432, 6379, etc.)"
echo "   - Host ports are offset per worktree to avoid conflicts"
echo "   - Use these ports for host tools (Postico, Redis clients, etc.)"
echo "   - From containers, use service names (e.g., postgres:5432, valkey:6379)"
echo ""

