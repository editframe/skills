# Tables Pattern Guide

Data display and pagination patterns using the established Table components.

## Basic Table Structure

```tsx
import { Table, TableHead, TableRow, TableCell, ColumnHead } from "~/components/Table";

interface RowData {
  id: string;
  name: string;
  status: string;
  created_at: string;
}

const columns = [
  {
    name: "Name",
    content: ({ name }: RowData) => <span className="font-medium">{name}</span>
  },
  {
    name: "Status", 
    content: ({ status }: RowData) => <RenderStatus status={status} />
  },
  {
    name: "Created",
    content: ({ created_at }: RowData) => <PrettyTime date={created_at} />
  }
];

export default function MyTable({ data }: { data: RowData[] }) {
  return (
    <Table
      rows={data}
      columns={columns}
      emptyResultMessage="No items found"
      buildRowURL={(row) => `/items/${row.id}`}
    />
  );
}
```

## Paginated Table Pattern

```tsx
import { PaginatedTable } from "~/components/Table";
import { useTableSearchParams } from "~/ui/useTableSearchParams";

interface TableLoaderData {
  items: RowData[];
  count: number;
}

export const loader = async (args: Route.LoaderArgs) => {
  const url = new URL(args.request.url);
  const page = parseInt(url.searchParams.get("page") ?? "1");
  const limit = parseInt(url.searchParams.get("limit") ?? "20");
  const search = url.searchParams.get("search") ?? "";

  const session = await requireCookieOrTokenSession(args.request);
  
  let query = db
    .selectFrom("items")
    .where("org_id", "=", session.orgId);
    
  if (search) {
    query = query.where("name", "ilike", `%${search}%`);
  }
  
  const [items, countResult] = await Promise.all([
    query
      .limit(limit)
      .offset((page - 1) * limit)
      .selectAll()
      .execute(),
    query.select(db.fn.count("id").as("count")).executeTakeFirst()
  ]);
  
  return {
    items,
    count: Number(countResult?.count ?? 0)
  };
};

export default function PaginatedItemsTable() {
  const { items, count } = useLoaderData<typeof loader>();
  
  return (
    <PaginatedTable
      rows={items}
      count={count}
      columns={columns}
      emptyResultMessage="No items found"
      buildRowURL={(row) => `/items/${row.id}`}
    />
  );
}
```

## Table with Search and Filters

```tsx
import { Filters } from "~/components/Filters";

export default function FilterableTable() {
  const { items, count, filters } = useLoaderData<typeof loader>();
  const { updateSearchParams } = useTableSearchParams();
  
  const filterConfig = [
    {
      type: "search" as const,
      name: "search",
      placeholder: "Search items...",
      value: filters.search
    },
    {
      type: "select" as const,
      name: "status",
      label: "Status",
      value: filters.status,
      options: [
        { value: "", label: "All Statuses" },
        { value: "active", label: "Active" },
        { value: "inactive", label: "Inactive" }
      ]
    },
    {
      type: "date" as const,
      name: "created_after",
      label: "Created After",
      value: filters.created_after
    }
  ];
  
  return (
    <div className="space-y-4">
      <Filters
        filters={filterConfig}
        onFiltersChange={updateSearchParams}
        resultsCount={count}
      />
      
      <PaginatedTable
        rows={items}
        count={count}
        columns={columns}
        emptyResultMessage="No items match your filters"
        emptyResultContent={
          <Button 
            mode="secondary" 
            onClick={() => updateSearchParams({})}
          >
            Clear Filters
          </Button>
        }
      />
    </div>
  );
}
```

## Custom Cell Components

### Status Cell
```tsx
interface StatusCellProps {
  status: "success" | "error" | "pending" | "processing";
}

const StatusCell = ({ status }: StatusCellProps) => {
  const statusConfig = {
    success: { color: "text-green-600", bg: "bg-green-100", label: "Success" },
    error: { color: "text-red-600", bg: "bg-red-100", label: "Error" },
    pending: { color: "text-yellow-600", bg: "bg-yellow-100", label: "Pending" },
    processing: { color: "text-blue-600", bg: "bg-blue-100", label: "Processing" },
  };
  
  const config = statusConfig[status];
  
  return (
    <span className={clsx(
      "inline-flex items-center px-2 py-1 rounded-md text-xs font-medium",
      config.color,
      config.bg
    )}>
      {config.label}
    </span>
  );
};
```

### Action Cell
```tsx
interface ActionCellProps {
  id: string;
  onEdit: (id: string) => void;
  onDelete: (id: string) => void;
}

const ActionCell = ({ id, onEdit, onDelete }: ActionCellProps) => {
  return (
    <div className="flex gap-2">
      <Button 
        mode="secondary" 
        size="sm"
        onClick={(e) => {
          e.stopPropagation(); // Prevent row click
          onEdit(id);
        }}
      >
        Edit
      </Button>
      <Button 
        mode="destructive" 
        size="sm"
        confirmation={{
          title: "Delete Item",
          description: "Are you sure you want to delete this item?",
          confirmText: "Delete"
        }}
        onConfirm={() => onDelete(id)}
        onClick={(e) => e.stopPropagation()}
      >
        Delete
      </Button>
    </div>
  );
};
```

### Link Cell
```tsx
interface LinkCellProps {
  href: string;
  children: React.ReactNode;
}

const LinkCell = ({ href, children }: LinkCellProps) => {
  return (
    <Link 
      to={href}
      className="text-blue-600 hover:text-blue-800 font-medium"
      onClick={(e) => e.stopPropagation()}
    >
      {children}
    </Link>
