#!/usr/bin/env bash
set -e

# Start shared infrastructure for all worktrees
# This includes: Traefik (routing) and PostgreSQL (databases)

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
MONOREPO_ROOT="$SCRIPT_DIR/.."

echo "🚀 Starting shared Editframe infrastructure..."
echo ""

cd "$MONOREPO_ROOT"

# Generate self-signed TLS certs for Traefik HTTPS (HTTP/2) if they don't exist
CERT_DIR="$MONOREPO_ROOT/scripts/certs"
if [ ! -f "$CERT_DIR/cert.pem" ] || [ ! -f "$CERT_DIR/key.pem" ]; then
  echo "🔐 Generating self-signed TLS certificate for *.localhost..."
  mkdir -p "$CERT_DIR"
  openssl req -x509 -newkey rsa:2048 \
    -keyout "$CERT_DIR/key.pem" \
    -out "$CERT_DIR/cert.pem" \
    -days 3650 -nodes \
    -subj '/CN=localhost' \
    -addext 'subjectAltName=DNS:localhost,DNS:*.localhost' \
    2>/dev/null
  echo "   ✅ Certificate generated"
fi

# Start shared services
docker compose --project-name editframe up -d

echo ""
echo "✅ Shared infrastructure running:"
echo "   - Traefik dashboard: http://localhost:7777"
echo "   - PostgreSQL: localhost:5432"
echo ""
echo "📊 Each worktree will have its own database:"
echo "   - Main worktree: telecine-main"
echo "   - Feature branches: telecine-<branch-name>"
echo ""

