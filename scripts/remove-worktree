#!/usr/bin/env bash
# Remove worktree and associated branches from monorepo, telecine, and elements repos.
#
# Usage: ./scripts/remove-worktree [--force] <branch-name>
# Fails if branch is not merged into main (unless --force is used).

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

FORCE=false
BRANCH_ARG=""

if [ "$1" = "--force" ]; then
  FORCE=true
  BRANCH_ARG="$2"
elif [ "$2" = "--force" ]; then
  FORCE=true
  BRANCH_ARG="$1"
elif [ -n "$1" ]; then
  BRANCH_ARG="$1"
fi

if [ -z "$BRANCH_ARG" ]; then
  echo "Usage: $0 [--force] <branch-name>" >&2
  exit 1
fi

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

MAIN_WORKTREE=$(git rev-parse --show-toplevel)
EDITFRAME_DIR=$(dirname "$(dirname "$(dirname "$MAIN_WORKTREE")")")
WORKTREES_DIR="$EDITFRAME_DIR/worktrees"
TELECINE_MAIN="$WORKTREES_DIR/main/telecine"
ELEMENTS_MAIN="$WORKTREES_DIR/main/elements"

sanitize_branch_name() {
  local name="$1"
  name=$(echo "$name" | tr '[:upper:]' '[:lower:]')
  name=$(echo "$name" | sed 's/[^a-z0-9]/-/g')
  name=$(echo "$name" | sed 's/^-\+//; s/-\+$//')
  name=$(echo "$name" | sed 's/-\+/-/g')
  name=$(echo "$name" | cut -c1-63)
  name=$(echo "$name" | sed 's/-$//')
  echo "$name"
}

BRANCH_NAME="$BRANCH_ARG"
SANITIZED_BRANCH=$(sanitize_branch_name "$BRANCH_NAME")
WORKTREE_DIR="$WORKTREES_DIR/$SANITIZED_BRANCH"
MONOREPO_WORKTREE_DIR="$WORKTREE_DIR/monorepo"
TELECINE_WORKTREE_DIR="$WORKTREE_DIR/telecine"
ELEMENTS_WORKTREE_DIR="$WORKTREE_DIR/elements"

# Check merge status unless --force
if [ "$FORCE" = false ]; then
  MAIN_BRANCH="main"
  if ! git show-ref --verify --quiet "refs/heads/main"; then
    MAIN_BRANCH="master"
  fi

  IS_MERGED=false
  if git rev-parse --verify "refs/heads/${BRANCH_NAME}" > /dev/null 2>&1; then
    BRANCH_COMMIT=$(git rev-parse "refs/heads/${BRANCH_NAME}")
    if git merge-base --is-ancestor "$BRANCH_COMMIT" "refs/heads/${MAIN_BRANCH}" 2>/dev/null; then
      IS_MERGED=true
    fi
  else
    IS_MERGED=true
  fi

  if [ "$IS_MERGED" = false ]; then
    echo "Error: Branch '$BRANCH_NAME' has not been merged into '$MAIN_BRANCH'" >&2
    echo "Use --force to remove without merging." >&2
    exit 1
  fi
fi

echo "Removing worktree: $BRANCH_NAME"
[ "$FORCE" = true ] && echo "  (force mode)"
echo ""

# Read scope
WORKTREE_SCOPE="web"
if [ -f "$WORKTREE_DIR/.worktree-scope" ]; then
  WORKTREE_SCOPE=$(cat "$WORKTREE_DIR/.worktree-scope")
fi

# 1. Stop and remove Docker containers
echo "1. Stopping Docker containers..."

if [ "$WORKTREE_SCOPE" != "elements" ] && [ -d "$TELECINE_WORKTREE_DIR" ] && [ -f "$TELECINE_WORKTREE_DIR/scripts/docker-compose" ]; then
  cd "$TELECINE_WORKTREE_DIR"
  if [ -f "scripts/worktree-config" ]; then
    . scripts/worktree-config 2>/dev/null || true
  fi
  ./scripts/docker-compose down -v --remove-orphans 2>&1 | grep -v "No such" || true

  if [ -n "$WORKTREE_DATABASE" ] && [ "$WORKTREE_DATABASE" != "telecine-main" ]; then
    if docker ps --filter "name=editframe-postgres" --format "{{.Names}}" | grep -q editframe-postgres; then
      docker exec editframe-postgres psql -U postgres \
        -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$WORKTREE_DATABASE' AND pid <> pg_backend_pid();" \
        -c "DROP DATABASE IF EXISTS \"$WORKTREE_DATABASE\";" > /dev/null 2>&1 || true
    fi
  fi
  echo "   telecine containers removed"
fi

if [ -d "$ELEMENTS_WORKTREE_DIR" ] && [ -f "$ELEMENTS_WORKTREE_DIR/scripts/docker-compose" ]; then
  cd "$ELEMENTS_WORKTREE_DIR"
  ./scripts/docker-compose down -v --remove-orphans 2>&1 | grep -v "No such" || true
  echo "   elements containers removed"
fi

cd "$MAIN_WORKTREE"
echo ""

# 2. Remove git worktrees (telecine and elements first, then monorepo)
echo "2. Removing git worktrees..."

if [ -d "$TELECINE_MAIN/.git" ] || [ -f "$TELECINE_MAIN/.git" ]; then
  cd "$TELECINE_MAIN"
  if git worktree list | grep -qF "$TELECINE_WORKTREE_DIR"; then
    git worktree remove "$TELECINE_WORKTREE_DIR" --force 2>&1 || true
    echo "   telecine worktree removed"
  fi
fi

if [ -d "$ELEMENTS_MAIN/.git" ] || [ -f "$ELEMENTS_MAIN/.git" ]; then
  cd "$ELEMENTS_MAIN"
  if git worktree list | grep -qF "$ELEMENTS_WORKTREE_DIR"; then
    git worktree remove "$ELEMENTS_WORKTREE_DIR" --force 2>&1 || true
    echo "   elements worktree removed"
  fi
fi

cd "$MAIN_WORKTREE"
if git worktree list | grep -qF "$MONOREPO_WORKTREE_DIR"; then
  git worktree remove "$MONOREPO_WORKTREE_DIR" --force 2>&1 || true
  echo "   monorepo worktree removed"
fi

# Remove directory if still present
if [ -d "$WORKTREE_DIR" ]; then
  rm -rf "$WORKTREE_DIR"
  echo "   directory removed"
fi

echo ""

# 3. Delete branch refs
echo "3. Deleting branch refs..."

if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
  git branch -D "$BRANCH_NAME" 2>&1 || true
  echo "   monorepo branch deleted"
fi

if [ -d "$TELECINE_MAIN/.git" ] || [ -f "$TELECINE_MAIN/.git" ]; then
  cd "$TELECINE_MAIN"
  if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
    git branch -D "$BRANCH_NAME" 2>&1 || true
    echo "   telecine branch deleted"
  fi
fi

if [ -d "$ELEMENTS_MAIN/.git" ] || [ -f "$ELEMENTS_MAIN/.git" ]; then
  cd "$ELEMENTS_MAIN"
  if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
    git branch -D "$BRANCH_NAME" 2>&1 || true
    echo "   elements branch deleted"
  fi
fi

echo ""
echo "Worktree '$BRANCH_NAME' removed."
