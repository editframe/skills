#!/bin/bash
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

if ! git diff-index --quiet HEAD --; then
  echo "Error: Working tree is not clean."
  echo "The following files have changes:"
  git status --porcelain
  exit 1
else
  echo "Working tree is clean."
fi

echo "export const VERSION = \"$@\";" > "${SCRIPT_DIR}/../packages/cli/src/version.ts"; 

npm -s version --no-git-tag-version --workspaces --include-workspace-root --allow-same-version "$@"
set -ex
"${SCRIPT_DIR}"/node scripts/deps.js update-dependencies
"${SCRIPT_DIR}"/npm install --workspaces --include-workspace-root

git add .
git commit -m "Bump version to v$@"
git tag -a "v$@" -m "$@"

# Detect if we're in a monorepo by checking for elements remote
GIT_ROOT=$(git rev-parse --show-toplevel)
if git -C "$GIT_ROOT" remote | grep -q "^elements$"; then
  # In monorepo: push only elements/ subtree to elements remote
  TAG_NAME="v$@"
  # Change to git root for subtree operations
  cd "$GIT_ROOT"
  # Fetch remote to get latest state
  git fetch elements main
  # Split the elements/ subtree, using elements/main as the base
  # Use --ignore-joins to avoid cache conflicts
  SPLIT_BRANCH="elements-split-$$"
  SPLIT_COMMIT=$(git subtree split --prefix=elements --onto=elements/main --ignore-joins HEAD)
  # Create a temporary branch from the split commit
  git branch -f "$SPLIT_BRANCH" "$SPLIT_COMMIT"
  # Force push the split branch to elements/main
  git push elements "${SPLIT_BRANCH}:main" --force-with-lease
  # Clean up temporary branch
  git branch -D "$SPLIT_BRANCH" 2>/dev/null || true
  # Fetch the remote to get the latest split commits
  git fetch elements main
  # Tag the latest commit on elements/main (which corresponds to our version bump)
  git tag -f "${TAG_NAME}" elements/main -m "$@"
  # Push the tag to the elements remote
  git push elements "${TAG_NAME}" --force
  
  # Also tag telecine if telecine remote exists
  if git -C "$GIT_ROOT" remote | grep -q "^telecine$"; then
    git fetch telecine main
    # Tag the latest commit on telecine/main
    git tag -f "${TAG_NAME}" telecine/main -m "$@"
    # Push the tag to the telecine remote
    git push telecine "${TAG_NAME}" --force
  fi
  
  # Also tag the monorepo root at current HEAD
  git tag -f "${TAG_NAME}" HEAD -m "$@"
else
  # Standalone repo: use original behavior
  git push
  git push --tag
fi