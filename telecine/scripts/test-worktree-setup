#!/usr/bin/env bash
# End-to-end test script for worktree Docker environment setup
# This script creates a test worktree, verifies configuration, and cleans up

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."
WORKTREE_PARENT=$(dirname "$PROJECT_ROOT")

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

TEST_BRANCH="test-worktree-setup-$(date +%s)"
TEST_WORKTREE_DIR="$WORKTREE_PARENT/telecine-$TEST_BRANCH"

echo "🧪 Testing worktree Docker environment setup"
echo "   Test branch: $TEST_BRANCH"
echo "   Test worktree: $TEST_WORKTREE_DIR"
echo ""

# Cleanup function
cleanup() {
  echo ""
  echo "🧹 Cleaning up..."
  if [ -d "$TEST_WORKTREE_DIR" ]; then
    cd "$PROJECT_ROOT"
    git worktree remove "$TEST_WORKTREE_DIR" --force 2>/dev/null || true
    echo "✅ Removed test worktree"
  fi
  # Don't delete the test branch if it exists - let user handle it
}

trap cleanup EXIT

# Step 1: Create test branch and worktree
echo "1️⃣  Creating test worktree..."
cd "$PROJECT_ROOT"

# Create a test branch (don't commit, just for testing)
git checkout -b "$TEST_BRANCH" 2>/dev/null || git checkout "$TEST_BRANCH" 2>/dev/null
git worktree add "$TEST_WORKTREE_DIR" "$TEST_BRANCH" 2>/dev/null || {
  echo "⚠️  Worktree already exists, using existing"
}

echo "✅ Test worktree created at: $TEST_WORKTREE_DIR"
echo ""

# Step 2: Verify worktree configuration
echo "2️⃣  Verifying worktree configuration..."
cd "$TEST_WORKTREE_DIR"

if ! . "$TEST_WORKTREE_DIR/scripts/worktree-config" 2>/dev/null; then
  echo -e "${RED}❌ ERROR: Failed to load worktree-config${NC}"
  exit 1
fi

echo "   Branch: $WORKTREE_BRANCH"
echo "   Domain: $WORKTREE_DOMAIN"
echo "   Docker Project: $WORKTREE_DOCKER_PROJECT_NAME"
echo "   Docker Network: $WORKTREE_DOCKER_NETWORK_NAME"
echo ""

# Verify domain matches expected pattern
EXPECTED_DOMAIN=$(echo "$TEST_BRANCH" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/-\+/-/g' | sed 's/^-\+//; s/-\+$//' | cut -c1-63 | sed 's/-$//')
EXPECTED_DOMAIN="${EXPECTED_DOMAIN}.localhost"

if [ "$WORKTREE_DOMAIN" != "$EXPECTED_DOMAIN" ]; then
  echo -e "${YELLOW}⚠️  WARNING: Domain mismatch${NC}"
  echo "   Expected: $EXPECTED_DOMAIN"
  echo "   Got: $WORKTREE_DOMAIN"
else
  echo -e "${GREEN}✅ Domain matches expected pattern${NC}"
fi
echo ""

# Step 3: Verify docker-compose script
echo "3️⃣  Testing docker-compose script..."
if ! "$TEST_WORKTREE_DIR/scripts/docker-compose" config > /dev/null 2>&1; then
  echo -e "${RED}❌ ERROR: docker-compose config failed${NC}"
  exit 1
fi
echo -e "${GREEN}✅ docker-compose configuration is valid${NC}"
echo ""

# Step 4: Verify shared Traefik network
echo "4️⃣  Checking shared Traefik network..."
if docker network inspect telecine-traefik > /dev/null 2>&1; then
  echo -e "${GREEN}✅ Shared Traefik network exists${NC}"
else
  echo -e "${YELLOW}⚠️  Shared Traefik network doesn't exist yet${NC}"
  echo "   It will be created automatically when docker-compose runs"
fi
echo ""

# Step 5: Test domain resolution (macOS)
if [[ "$OSTYPE" == "darwin"* ]]; then
  echo "5️⃣  Testing domain resolution..."
  SANITIZED=$(echo "$TEST_BRANCH" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/-\+/-/g' | sed 's/^-\+//; s/-\+$//' | cut -c1-63 | sed 's/-$//')
  TEST_DOMAIN="${SANITIZED}.localhost"
  
  if ping -c 1 "$TEST_DOMAIN" > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Domain resolves: $TEST_DOMAIN${NC}"
  else
    echo -e "${YELLOW}⚠️  Domain doesn't resolve yet: $TEST_DOMAIN${NC}"
    echo "   macOS should auto-resolve .localhost domains - check DNS cache"
  fi
  echo ""
fi

# Summary
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${GREEN}✅ All tests passed!${NC}"
echo ""
echo "The worktree setup is working correctly."
echo ""
echo "To test with actual services:"
echo "  1. cd $TEST_WORKTREE_DIR"
echo "  2. ./scripts/start"
echo "  3. Access at: http://$WORKTREE_DOMAIN:3000"
echo ""
echo "Note: Traefik must be running in the main worktree for routing to work."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

