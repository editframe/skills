#!/usr/bin/env bash
# Merge a worktree branch into main across all repos (monorepo, telecine, elements).
#
# Usage: merge-worktree <branch-name>
#
# Merges the branch into main in each repo where the branch exists and has changes.
# After successful merge, use remove-worktree to clean up.

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

if [ -z "$1" ]; then
  echo "Usage: $0 <branch-name>" >&2
  exit 1
fi

BRANCH_NAME="$1"
MAIN_WORKTREE=$(git rev-parse --show-toplevel)
WORKTREE_PARENT=$(dirname "$MAIN_WORKTREE")

TELECINE_MAIN="$WORKTREE_PARENT/telecine"
ELEMENTS_MAIN="$WORKTREE_PARENT/elements"

merge_branch_in_repo() {
  local repo_dir="$1"
  local repo_name="$2"
  local branch="$3"

  if [ ! -d "$repo_dir/.git" ] && [ ! -f "$repo_dir/.git" ]; then
    return
  fi

  cd "$repo_dir"

  if ! git show-ref --verify --quiet "refs/heads/${branch}"; then
    return
  fi

  local main_branch="main"
  if ! git show-ref --verify --quiet "refs/heads/main"; then
    main_branch="master"
  fi

  git checkout "$main_branch" > /dev/null 2>&1

  if git merge-base --is-ancestor "refs/heads/${branch}" "refs/heads/${main_branch}" 2>/dev/null; then
    echo "  $repo_name: already merged"
    return
  fi

  if ! git diff-index --quiet HEAD --; then
    echo "  Error: $repo_name has uncommitted changes" >&2
    exit 1
  fi

  if git merge --no-edit "$branch"; then
    echo "  $repo_name: merged"
  else
    echo "  Error: merge conflict in $repo_name" >&2
    echo "  Resolve conflicts in $repo_dir, then run: git add . && git commit" >&2
    exit 1
  fi
}

echo "Merging '$BRANCH_NAME' into main..."
echo ""

merge_branch_in_repo "$MAIN_WORKTREE" "monorepo" "$BRANCH_NAME"
merge_branch_in_repo "$TELECINE_MAIN" "telecine" "$BRANCH_NAME"
merge_branch_in_repo "$ELEMENTS_MAIN" "elements" "$BRANCH_NAME"

cd "$MAIN_WORKTREE"

echo ""
echo "Merged. Next: scripts/remove-worktree $BRANCH_NAME"
