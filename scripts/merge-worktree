#!/usr/bin/env bash
# Merge current worktree branch back into main
# Run from within worktree directory

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

# Detect current worktree and branch
WORKTREE_ROOT=$(git rev-parse --show-toplevel)
BRANCH_NAME=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)

if [ -z "$BRANCH_NAME" ]; then
  echo "Error: Could not detect git branch name. Ensure you are on a valid branch." >&2
  exit 1
fi

# Check if we're in main worktree
if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
  echo "Error: Cannot merge main/master into itself. This script should be run from a worktree branch." >&2
  exit 1
fi

# Find main worktree
MAIN_WORKTREE=$(git worktree list | grep -E '\[main\]|\[master\]' | awk '{print $1}' | head -1)
if [ -z "$MAIN_WORKTREE" ]; then
  # Fallback: check if current is main/master (shouldn't happen due to check above)
  echo "Error: Could not find main worktree" >&2
  exit 1
fi

# Determine main branch name
cd "$MAIN_WORKTREE"
MAIN_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)
if [ "$MAIN_BRANCH" != "main" ] && [ "$MAIN_BRANCH" != "master" ]; then
  # Try to checkout main or master
  if git show-ref --verify --quiet "refs/heads/main"; then
    MAIN_BRANCH="main"
  elif git show-ref --verify --quiet "refs/heads/master"; then
    MAIN_BRANCH="master"
  else
    echo "Error: Could not determine main branch" >&2
    exit 1
  fi
fi

echo "🔄 Merging branch '$BRANCH_NAME' into '$MAIN_BRANCH'"
echo "   From worktree: $WORKTREE_ROOT"
echo "   To worktree:   $MAIN_WORKTREE"
echo ""

# Switch to main worktree and checkout main branch
cd "$MAIN_WORKTREE"
git checkout "$MAIN_BRANCH" > /dev/null 2>&1

# Check if branch is already merged
if git branch --merged | grep -q "^\s*${BRANCH_NAME}$" || git branch --merged | grep -q "^\s*\*.*${BRANCH_NAME}$"; then
  echo "✅ Branch '$BRANCH_NAME' is already merged into '$MAIN_BRANCH'"
  exit 0
fi

# Check for uncommitted changes in main
if ! git diff-index --quiet HEAD --; then
  echo "Error: Main worktree has uncommitted changes. Please commit or stash them first." >&2
  exit 1
fi

# Perform merge
echo "Merging..."
if git merge --no-edit "$BRANCH_NAME"; then
  echo ""
  echo "✅ Successfully merged '$BRANCH_NAME' into '$MAIN_BRANCH'"
  echo ""
  echo "Next step: cd $WORKTREE_ROOT && ./scripts/remove-worktree"
else
  echo ""
  echo "❌ Merge failed due to conflicts"
  echo ""
  echo "Resolve conflicts and complete the merge:"
  echo "  1. cd $MAIN_WORKTREE"
  echo "  2. Resolve conflicts in the files listed above"
  echo "  3. git add <resolved-files>"
  echo "  4. git commit"
  echo ""
  echo "Or abort the merge:"
  echo "  cd $MAIN_WORKTREE && git merge --abort"
  exit 1
fi

