#!/usr/bin/env bash
# Push telecine subtree to private repository

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
MONOREPO_ROOT="$SCRIPT_DIR/.."

cd "$MONOREPO_ROOT"

BRANCH="${1:-main}"

echo "Pushing telecine subtree to telecine remote (branch: $BRANCH)..."
git subtree push --prefix=telecine telecine "$BRANCH"

echo "✅ Successfully pushed telecine subtree to private repository"
