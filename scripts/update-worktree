#!/usr/bin/env bash
# Update worktree branch with latest changes from main
#
# This script merges changes from main/master into a worktree branch.
# Use this when you want to bring updates from main into your feature branch.
#
# Direction: main → worktree branch
#
# Can be run from:
#   1. Within the worktree directory (auto-detects branch)
#   2. From main worktree with branch name argument
#
# Usage:
#   # From within worktree:
#   cd /path/to/worktree
#   ./scripts/update-worktree
#
#   # From main with branch name:
#   ./scripts/update-worktree <branch-name>
#
# Example:
#   ./scripts/update-worktree feature-auth
#   # Merges main into feature-auth branch

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

# Detect current worktree and branch
CURRENT_ROOT=$(git rev-parse --show-toplevel)
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)

# Check if branch name provided as argument (running from main)
if [ -n "$1" ]; then
  BRANCH_NAME="$1"
  # Find worktree for this branch using porcelain output
  WORKTREE_ROOT=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^worktree[[:space:]]+(.+)$ ]]; then
      WORKTREE_ROOT="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^branch[[:space:]]+refs/heads/(.+)$ ]]; then
      if [ "${BASH_REMATCH[1]}" = "$BRANCH_NAME" ]; then
        break
      fi
      WORKTREE_ROOT=""
    fi
  done < <(git worktree list --porcelain)
  
  if [ -z "$WORKTREE_ROOT" ]; then
    echo "Error: Could not find worktree for branch '$BRANCH_NAME'" >&2
    exit 1
  fi
else
  # Running from within worktree
  WORKTREE_ROOT="$CURRENT_ROOT"
  BRANCH_NAME="$CURRENT_BRANCH"
  
  if [ -z "$BRANCH_NAME" ]; then
    echo "Error: Could not detect git branch name. Ensure you are on a valid branch or provide branch name as argument." >&2
    exit 1
  fi
  
  # Check if we're in main worktree
  if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
    echo "Error: Cannot update main/master with itself. This script should be run from a worktree branch or with a branch name argument." >&2
    exit 1
  fi
fi

# Find main worktree
MAIN_WORKTREE=$(git worktree list | grep -E '\[main\]|\[master\]' | awk '{print $1}' | head -1)
if [ -z "$MAIN_WORKTREE" ]; then
  echo "Error: Could not find main worktree" >&2
  exit 1
fi

# Determine main branch name
cd "$MAIN_WORKTREE"
MAIN_BRANCH=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)
if [ "$MAIN_BRANCH" != "main" ] && [ "$MAIN_BRANCH" != "master" ]; then
  # Try to checkout main or master
  if git show-ref --verify --quiet "refs/heads/main"; then
    MAIN_BRANCH="main"
  elif git show-ref --verify --quiet "refs/heads/master"; then
    MAIN_BRANCH="master"
  else
    echo "Error: Could not determine main branch" >&2
    exit 1
  fi
fi

echo "🔄 Updating branch '$BRANCH_NAME' with latest changes from '$MAIN_BRANCH'"
echo "   Worktree: $WORKTREE_ROOT"
echo "   Main:     $MAIN_WORKTREE"
echo ""

# Switch to worktree
cd "$WORKTREE_ROOT"

# Check for uncommitted changes in worktree
if ! git diff-index --quiet HEAD --; then
  echo "Error: Worktree has uncommitted changes. Please commit or stash them first." >&2
  exit 1
fi

# Ensure we're on the correct branch
git checkout "$BRANCH_NAME" > /dev/null 2>&1

# Ensure main branch is checked out in main worktree (for accurate merge-base check)
cd "$MAIN_WORKTREE"
git checkout "$MAIN_BRANCH" > /dev/null 2>&1

# Switch back to worktree
cd "$WORKTREE_ROOT"

# Check if already up to date
if git merge-base --is-ancestor "$MAIN_BRANCH" "$BRANCH_NAME"; then
  echo "✅ Branch '$BRANCH_NAME' is already up to date with '$MAIN_BRANCH'"
  exit 0
fi

# Perform merge
echo "Merging '$MAIN_BRANCH' into '$BRANCH_NAME'..."
if git merge --no-edit "$MAIN_BRANCH"; then
  echo ""
  echo "✅ Successfully updated '$BRANCH_NAME' with latest changes from '$MAIN_BRANCH'"
else
  echo ""
  echo "❌ Merge failed due to conflicts"
  echo ""
  echo "Resolve conflicts and complete the merge:"
  echo "  1. Resolve conflicts in the files listed above"
  echo "  2. git add <resolved-files>"
  echo "  3. git commit"
  echo ""
  echo "Or abort the merge:"
  echo "  git merge --abort"
  exit 1
fi

