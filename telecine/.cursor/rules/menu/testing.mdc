# Testing Patterns Guide

Unit and integration testing patterns using Vitest and established testing utilities.

## Basic Test Structure

```typescript
import { describe, test, expect } from "vitest";
import { render, screen } from "@testing-library/react";

describe("ComponentName", () => {
  test("renders correctly", () => {
    render(<ComponentName prop="value" />);
    
    expect(screen.getByText("Expected Text")).toBeInTheDocument();
  });
  
  test("handles user interaction", async () => {
    const handleClick = vi.fn();
    
    render(<ComponentName onClick={handleClick} />);
    
    fireEvent.click(screen.getByRole("button"));
    
    expect(handleClick).toHaveBeenCalled();
  });
});
```

## Form Testing Patterns

```typescript
import { formFor } from "~/formFor";
import { z } from "zod";

const schema = z.object({
  name: z.string().min(1),
  email: z.string().email()
});

const testForm = formFor(schema);

describe("Form Validation", () => {
  test("validates required fields", async () => {
    const formData = new FormData();
    formData.append("name", "");
    formData.append("email", "invalid-email");
    
    const result = await testForm.parseFormData(
      new Request("http://test", { method: "POST", body: formData })
    );
    
    expect(result.success).toBe(false);
    expect(result.errors.fieldErrors.name).toBeDefined();
    expect(result.errors.fieldErrors.email).toBeDefined();
  });
  
  test("succeeds with valid data", async () => {
    const formData = new FormData();
    formData.append("name", "John Doe");
    formData.append("email", "john@example.com");
    
    const result = await testForm.parseFormData(
      new Request("http://test", { method: "POST", body: formData })
    );
    
    expect(result.success).toBe(true);
    expect(result.data.name).toBe("John Doe");
    expect(result.data.email).toBe("john@example.com");
  });
});
```

## API Route Testing

```typescript
import { loader, action } from "~/routes/api/items";
import { createAuthenticatedRequest, createRequestWithFormData } from "~/test/utils";

describe("Items API", () => {
  test("loader returns items for authenticated user", async () => {
    const request = createAuthenticatedRequest("/api/items", { 
      userId: "test-user",
      orgId: "test-org" 
    });
    
    const response = await loader({ request, params: {} });
    const data = await response.json();
    
    expect(data.items).toBeInstanceOf(Array);
  });
  
  test("action creates new item", async () => {
    const request = createRequestWithFormData({
      name: "Test Item",
      description: "Test Description"
    }, { userId: "test-user", orgId: "test-org" });
    
    const response = await action({ request, params: {} });
    const data = await response.json();
    
    expect(response.status).toBe(200);
    expect(data.success).toBe(true);
    expect(data.id).toBeDefined();
  });
  
  test("returns 401 for unauthenticated request", async () => {
    const request = new Request("http://test/api/items");
    
    const response = await loader({ request, params: {} });
    
    expect(response.status).toBe(401);
  });
});
```

## Component Testing with User Events

```typescript
import { render, screen, fireEvent, waitFor } from "@testing-library/react";
import userEvent from "@testing-library/user-event";

describe("Interactive Component", () => {
  test("handles form submission", async () => {
    const user = userEvent.setup();
    const onSubmit = vi.fn();
    
    render(<ContactForm onSubmit={onSubmit} />);
    
    await user.type(screen.getByLabelText("Name"), "John Doe");
    await user.type(screen.getByLabelText("Email"), "john@example.com");
    await user.click(screen.getByRole("button", { name: /submit/i }));
    
    await waitFor(() => {
      expect(onSubmit).toHaveBeenCalledWith({
        name: "John Doe",
        email: "john@example.com"
      });
    });
  });
  
  test("shows validation errors", async () => {
    const user = userEvent.setup();
    
    render(<ContactForm />);
    
    await user.click(screen.getByRole("button", { name: /submit/i }));
    
    expect(screen.getByText("Name is required")).toBeInTheDocument();
  });
});
```

## Table Testing

```typescript
import { Table } from "~/components/Table";

describe("Table Component", () => {
  const mockData = [
    { id: "1", name: "Item 1", status: "active" },
    { id: "2", name: "Item 2", status: "inactive" }
  ];
  
  const columns = [
    { name: "Name", content: ({ name }: any) => name },
    { name: "Status", content: ({ status }: any) => status }
  ];
  
  test("renders table with data", () => {
    render(
      <Table
        rows={mockData}
        columns={columns}
        emptyResultMessage="No items"
      />
    );
    
    expect(screen.getByText("Item 1")).toBeInTheDocument();
    expect(screen.getByText("Item 2")).toBeInTheDocument();
    expect(screen.getByText("active")).toBeInTheDocument();
    expect(screen.getByText("inactive")).toBeInTheDocument();
  });
  
  test("shows empty state when no data", () => {
    render(
      <Table
        rows={[]}
        columns={columns}
        emptyResultMessage="No items found"
      />
    );
    
    expect(screen.getByText("No items found")).toBeInTheDocument();
  });
  
  test("handles row click navigation", () => {
    const mockNavigate = vi.fn();
    
    render(
      <Table
        rows={mockData}
        columns={columns}
        buildRowURL={(row) => `/items/${row.id}`}
        emptyResultMessage="No items"
      />
    );
    
    fireEvent.click(screen.getByText("Item 1"));
    expect(mockNavigate).toHaveBeenCalledWith("/items/1");
  });
});
```

## MSW for API Mocking

```typescript
import { http, HttpResponse } from "msw";
import { setupServer } from "msw/node";
import { useMSW } from "~/test/msw";

describe("API Integration", () => {
  const server = useMSW();
  
  test("handles successful API response", async () => {
    server.use(
      http.get("http://localhost/api/items", () => {
        return HttpResponse.json({
          items: [
            { id: "1", name: "Test Item" }
          ]
        });
      })
    );
    
    const response = await fetch("http://localhost/api/items");
    const data = await response.json();
    
    expect(data.items).toHaveLength(1);
    expect(data.items[0].name).toBe("Test Item");
  });
  
  test("handles API error", async () => {
    server.use(
      http.get("http://localhost/api/items", () => {
        return HttpResponse.text("Server Error", { status: 500 });
      })
    );
    
    const response = await fetch("http://localhost/api/items");
    
    expect(response.status).toBe(500);
  });
  
  test("handles streaming response", async () => {
    server.use(
      http.get("http://localhost/api/stream", () => {
        return HttpResponse.text("event: message\ndata: {\"type\": \"update\"}\n\n");
      })
    );
    
    const response = await fetch("http://localhost/api/stream");
    const text = await response.text();
    
    expect(text).toContain("event: message");
    expect(text).toContain("data: {\"type\": \"update\"}");
  });
});
```

## Authentication Testing

```typescript
import { requireCookieOrTokenSession } from "@/util/requireSession.server";

describe("Authentication", () => {
  test("allows access with valid session", async () => {
    const request = createAuthenticatedRequest("/protected", {
      userId: "test-user",
      orgId: "test-org"
    });
    
    const session = await requireCookieOrTokenSession(request);
    
    expect(session.userId).toBe("test-user");
    expect(session.orgId).toBe("test-org");
  });
  
  test("throws error for missing session", async () => {
    const request = new Request("http://test/protected");
    
    await expect(requireCookieOrTokenSession(request)).rejects.toThrow();
  });
});
```

## Database Testing

```typescript
import { db } from "@/sql-client.server";

describe("Database Operations", () => {
  beforeEach(async () => {
    // Clean up test data
    await db.deleteFrom("test_table").execute();
  });
  
  test("creates and retrieves record", async () => {
    const created = await db
      .insertInto("test_table")
      .values({
        name: "Test Record",
        org_id: "test-org"
      })
      .returning("id")
      .executeTakeFirst();
    
    expect(created?.id).toBeDefined();
    
    const retrieved = await db
      .selectFrom("test_table")
      .where("id", "=", created!.id)
      .selectAll()
      .executeTakeFirst();
    
    expect(retrieved?.name).toBe("Test Record");
  });
});
```

