FROM ubuntu:24.04 AS bento4-builder

WORKDIR /app

# Install dependencies for Bento4
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    cmake \
    build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates

# Clone and build Bento4 (same as Dockerfile.runner)
RUN git clone https://github.com/axiomatic-systems/Bento4.git && \
    cd Bento4 && \
    mkdir cmakebuild && \
    cd cmakebuild && \
    cmake -DCMAKE_BUILD_TYPE=Release .. && \
    make -j$(nproc)

FROM ubuntu:24.04

# Install Go and all test dependencies on same Ubuntu base for GLIBC compatibility
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Go 1.21 (auto-detect architecture)
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then GOARCH="arm64"; else GOARCH="amd64"; fi && \
    curl -L "https://golang.org/dl/go1.21.13.linux-${GOARCH}.tar.gz" | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:$PATH"

# Install FFmpeg and development dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    build-essential \
    pkg-config \
    libavformat-dev \
    libavcodec-dev \
    libavutil-dev \
    libavfilter-dev \
    libswresample-dev \
    libswscale-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy mp4dump from Bento4 build (exact same as Dockerfile.runner)
COPY --from=bento4-builder /app/Bento4/cmakebuild/mp4dump /usr/local/bin/
COPY --from=bento4-builder /app/Bento4/cmakebuild/mp4info /usr/local/bin/

# Set up Go environment for CGO (remove problematic flags)
ENV CGO_ENABLED=1
ENV CGO_CFLAGS=""
ENV CGO_CXXFLAGS=""
ENV CGO_LDFLAGS=""

# Set working directory
WORKDIR /app

# Copy go.mod first for better caching
COPY go.mod ./
RUN go mod download

# Copy source code
COPY . .

# Default command runs all tests
CMD ["go", "test", "-v", "./internal/transcoding", "-timeout", "300s"]
