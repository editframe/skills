+// ---------------------------------------------------------------------------
+// GBM device for DMA-BUF-backed native pixmaps.
+// Opened lazily on first CreateNativePixmap call.  When a GPU is present and
+// libgbm.so.1 is available (our libgbm_cuda.so.1 in production), allocations
+// go through GBM → CUDA VMM → real DMA-BUF fds.  When no GPU or GBM is
+// available the factory falls back to the original TestPixmap stub.
+// ---------------------------------------------------------------------------
+
+static struct gbm_device* g_gbm_device = nullptr;
+static int g_drm_fd = -1;
+static bool g_gbm_init_attempted = false;
+
+static uint32_t BufferFormatToDrmFourCC(gfx::BufferFormat format) {
+  // DRM_FORMAT_* values – keep in sync with drm_fourcc.h
+  switch (format) {
+    case gfx::BufferFormat::BGRA_8888:
+      return 0x34324142;  // DRM_FORMAT_ARGB8888
+    case gfx::BufferFormat::RGBA_8888:
+      return 0x34324241;  // DRM_FORMAT_ABGR8888
+    case gfx::BufferFormat::BGRX_8888:
+      return 0x34325258;  // DRM_FORMAT_XRGB8888
+    case gfx::BufferFormat::RGBX_8888:
+      return 0x34325842;  // DRM_FORMAT_XBGR8888
+    case gfx::BufferFormat::BGR_565:
+      return 0x36314752;  // DRM_FORMAT_RGB565
+    case gfx::BufferFormat::RGBA_F16:
+      return 0x48324241;  // DRM_FORMAT_ABGR16161616F
+    case gfx::BufferFormat::YVU_420:
+      return 0x32315659;  // DRM_FORMAT_YVU420
+    case gfx::BufferFormat::YUV_420_BIPLANAR:
+      return 0x3231564E;  // DRM_FORMAT_NV12
+    case gfx::BufferFormat::P010:
+      return 0x30313050;  // DRM_FORMAT_P010
+    default:
+      return 0;
+  }
+}
+
+static bool EnsureGbmDevice() {
+  if (g_gbm_init_attempted)
+    return g_gbm_device != nullptr;
+  g_gbm_init_attempted = true;
+
+  g_drm_fd = open("/dev/dri/renderD128", O_RDWR | O_CLOEXEC);
+  if (g_drm_fd < 0) {
+    LOG(WARNING) << "headless: cannot open /dev/dri/renderD128, "
+                    "DMA-BUF pixmaps unavailable";
+    return false;
+  }
+
+  g_gbm_device = gbm_create_device(g_drm_fd);
+  if (!g_gbm_device) {
+    LOG(WARNING) << "headless: gbm_create_device failed, "
+                    "DMA-BUF pixmaps unavailable";
+    close(g_drm_fd);
+    g_drm_fd = -1;
+    return false;
+  }
+
+  LOG(INFO) << "headless: GBM device created for DMA-BUF pixmaps";
+  return true;
+}
+
+static scoped_refptr<gfx::NativePixmap> CreateGbmPixmap(
+    gfx::Size size,
+    gfx::BufferFormat format) {
+  uint32_t fourcc = BufferFormatToDrmFourCC(format);
+  if (!fourcc) {
+    LOG(WARNING) << "headless: unsupported buffer format for GBM: "
+                 << static_cast<int>(format);
+    return nullptr;
+  }
+
+  // GBM_BO_USE_RENDERING: buffer will be used as GPU render target
+  // GBM_BO_USE_LINEAR: ensure linear (non-tiled) layout for DMA-BUF export
+  constexpr uint32_t kGbmFlags = GBM_BO_USE_RENDERING | GBM_BO_USE_LINEAR;
+
+  struct gbm_bo* bo = gbm_bo_create(
+      g_gbm_device, size.width(), size.height(), fourcc, kGbmFlags);
+  if (!bo) {
+    LOG(WARNING) << "headless: gbm_bo_create failed for "
+                 << size.width() << "x" << size.height()
+                 << " fourcc=0x" << std::hex << fourcc;
+    return nullptr;
+  }
+
+  gfx::NativePixmapHandle handle;
+  handle.modifier = gbm_bo_get_modifier(bo);
+
+  int num_planes = gbm_bo_get_plane_count(bo);
+  for (int i = 0; i < num_planes; ++i) {
+    int fd = gbm_bo_get_fd_for_plane(bo, i);
+    if (fd < 0) {
+      // Fall back to single-fd path
+      fd = gbm_bo_get_fd(bo);
+    }
+    if (fd < 0) {
+      LOG(WARNING) << "headless: cannot get DMA-BUF fd for plane " << i;
+      gbm_bo_destroy(bo);
+      return nullptr;
+    }
+
+    uint32_t stride = gbm_bo_get_stride_for_plane(bo, i);
+    uint32_t offset = gbm_bo_get_offset(bo, i);
+    uint64_t plane_size = stride * gbm_bo_get_height(bo);
+
+    handle.planes.emplace_back(
+        static_cast<int>(stride),
+        static_cast<int>(offset),
+        plane_size,
+        base::ScopedFD(fd));
+  }
+
+  gbm_bo_destroy(bo);
+
+  if (handle.planes.empty()) {
+    LOG(WARNING) << "headless: GBM bo had zero planes";
+    return nullptr;
+  }
+
+  LOG(INFO) << "headless: created DMA-BUF pixmap " << size.width() << "x"
+            << size.height() << " planes=" << handle.planes.size()
+            << " fd=" << handle.planes[0].fd.get()
+            << " stride=" << handle.planes[0].stride
+            << " modifier=0x" << std::hex << handle.modifier;
+
+  return base::MakeRefCounted<gfx::NativePixmapDmaBuf>(size, format,
+                                                        std::move(handle));
+}
+
