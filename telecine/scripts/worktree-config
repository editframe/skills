#!/usr/bin/env bash
# Detects worktree context and exports configuration variables
# Must be sourced: . scripts/worktree-config

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

# Get the worktree root (works for both main worktree and git worktrees)
WORKTREE_ROOT=$(git rev-parse --show-toplevel)

# Detect branch name
BRANCH_NAME=$(git branch --show-current 2>/dev/null || git symbolic-ref --short HEAD 2>/dev/null)

if [ -z "$BRANCH_NAME" ]; then
  echo "Error: Could not detect git branch name. Ensure you are on a valid branch." >&2
  exit 1
fi

# Check if this is the main worktree (branch is main/master)
# Simplified: if branch is main/master, treat as main worktree
IS_MAIN_WORKTREE=false
if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
  IS_MAIN_WORKTREE=true
fi

# Sanitize branch name for use in domains and project names
sanitize_branch_name() {
  local name="$1"
  # Convert to lowercase
  name=$(echo "$name" | tr '[:upper:]' '[:lower:]')
  # Replace / and other non-alphanumeric chars with -
  name=$(echo "$name" | sed 's/[^a-z0-9]/-/g')
  # Remove leading/trailing hyphens
  name=$(echo "$name" | sed 's/^-\+//; s/-\+$//')
  # Remove consecutive hyphens
  name=$(echo "$name" | sed 's/-\+/-/g')
  # Limit to 63 chars (DNS label limit)
  name=$(echo "$name" | cut -c1-63)
  # Remove trailing hyphen if truncation created one
  name=$(echo "$name" | sed 's/-$//')
  
  # Validate: must not be empty and must start with alphanumeric
  if [ -z "$name" ] || ! echo "$name" | grep -q '^[a-z0-9]'; then
    echo "Error: Invalid branch name after sanitization: '$BRANCH_NAME' -> '$name'" >&2
    exit 1
  fi
  
  echo "$name"
}

if [ "$IS_MAIN_WORKTREE" = true ]; then
  # Main worktree: use main.localhost domain (auto-resolves on macOS)
  WORKTREE_DOMAIN="main.localhost"
  WORKTREE_DOCKER_PROJECT_NAME="telecine"
  WORKTREE_DOCKER_NETWORK_NAME="telecine_default"
else
  # Worktree: use sanitized branch name with .localhost domain (auto-resolves on macOS)
  SANITIZED_BRANCH=$(sanitize_branch_name "$BRANCH_NAME")
  WORKTREE_DOMAIN="${SANITIZED_BRANCH}.localhost"
  WORKTREE_DOCKER_PROJECT_NAME="telecine-${SANITIZED_BRANCH}"
  WORKTREE_DOCKER_NETWORK_NAME="telecine-${SANITIZED_BRANCH}_default"
fi

# Export variables for use by other scripts
export WORKTREE_BRANCH="$BRANCH_NAME"
export WORKTREE_DOMAIN
export WORKTREE_DOCKER_PROJECT_NAME
export WORKTREE_DOCKER_NETWORK_NAME

# Optional: Export worktree ID for reference (sanitized branch name)
if [ "$IS_MAIN_WORKTREE" = true ]; then
  export WORKTREE_ID="main"
else
  export WORKTREE_ID="$SANITIZED_BRANCH"
fi

# Calculate deterministic ports for worktrees based on branch name hash
# Ports are in range 10000-60000, distributed based on branch name
# Main worktree uses standard ports, worktrees get calculated ports
calculate_worktree_port() {
  local base_port=$1
  local branch_name="${2:-$BRANCH_NAME}"
  
  if [ "$IS_MAIN_WORKTREE" = true ]; then
    # Main worktree uses standard ports
    echo "$base_port"
    return
  fi
  
  # Calculate hash of branch name (simple numeric hash)
  # Use a simple hash function that produces consistent results
  local hash=$(echo -n "$branch_name" | cksum | awk '{print $1}')
  
  # Make hash within port range (0-50000)
  hash=$((hash % 50000))
  
  # Port range: 10000-60000 (avoiding common ports < 10000)
  local worktree_port=$((10000 + hash))
  
  # Add service-specific offset to avoid collisions
  # Each service gets a small offset (0-99) based on base_port
  local service_offset=$((base_port % 100))
  worktree_port=$((worktree_port + service_offset))
  
  # Ensure port is in valid range
  if [ $worktree_port -gt 60000 ]; then
    worktree_port=$((worktree_port - 50000))
  fi
  
  echo "$worktree_port"
}

# Export port variables for common services
if [ "$IS_MAIN_WORKTREE" = true ]; then
  # Main worktree: standard ports
  export WORKTREE_VALKEY_PORT=6379
  export WORKTREE_MAILHOG_SMTP_PORT=1025
  export WORKTREE_MAILHOG_WEB_PORT=8025
  export WORKTREE_PLAYWRIGHT_PORT=4444
  export WORKTREE_TRACING_GRPC_PORT=4317
  export WORKTREE_TRACING_HTTP_PORT=4318
  export WORKTREE_TRACING_SSE_PORT=4319
  export WORKTREE_OTEL_VIEWER_PORT=4320
else
  # Worktree: calculated ports
  export WORKTREE_VALKEY_PORT=$(calculate_worktree_port 6379)
  export WORKTREE_MAILHOG_SMTP_PORT=$(calculate_worktree_port 1025)
  export WORKTREE_MAILHOG_WEB_PORT=$(calculate_worktree_port 8025)
  export WORKTREE_PLAYWRIGHT_PORT=$(calculate_worktree_port 4444)
  export WORKTREE_TRACING_GRPC_PORT=$(calculate_worktree_port 4317)
  export WORKTREE_TRACING_HTTP_PORT=$(calculate_worktree_port 4318)
  export WORKTREE_TRACING_SSE_PORT=$(calculate_worktree_port 4319)
  export WORKTREE_OTEL_VIEWER_PORT=$(calculate_worktree_port 4320)
fi

