#!/usr/bin/env bash

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

set -ex

"${SCRIPT_DIR}"/clean
"${SCRIPT_DIR}"/docker-compose run --rm runner npm run typecheck --workspaces
"${SCRIPT_DIR}"/docker-compose run --rm runner npm run lint
"${SCRIPT_DIR}"/docker-compose run --rm runner npm run format
"${SCRIPT_DIR}"/run scripts/verify-package-dependencies.js

# Run tests in cache-only mode to ensure they only use cached data
echo "Running tests in cache-only mode..."
export EF_CACHE_ONLY=true
"${SCRIPT_DIR}"/npm run test
VITEST_BROWSER_MODE=connect "${SCRIPT_DIR}"/npm run browsertest

"${SCRIPT_DIR}"/build-all
"${SCRIPT_DIR}"/verify-cli-boot
"${SCRIPT_DIR}"/run scripts/verify-package-exports.js

"${SCRIPT_DIR}"/version "$@"
"${SCRIPT_DIR}"/clean