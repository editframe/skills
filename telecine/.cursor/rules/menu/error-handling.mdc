## API Error Handling

### Typed Error Responses

```tsx
// Error types
export class APIError extends Error {
  constructor(
    message: string,
    public status: number = 500,
    public code?: string,
    public details?: Record<string, any>
  ) {
    super(message);
    this.name = "APIError";
  }
}

export class ValidationError extends APIError {
  constructor(message: string, public fieldErrors?: Record<string, string>) {
    super(message, 400, "VALIDATION_ERROR", { fieldErrors });
    this.name = "ValidationError";
  }
}

export class NotFoundError extends APIError {
  constructor(resource: string) {
    super(`${resource} not found`, 404, "NOT_FOUND");
    this.name = "NotFoundError";
  }
}

export class UnauthorizedError extends APIError {
  constructor(message = "Unauthorized") {
    super(message, 401, "UNAUTHORIZED");
    this.name = "UnauthorizedError";
  }
}
```

### Error Handler Middleware

```tsx
import { isRouteErrorResponse } from "react-router";
import { ZodError } from "zod";

export function handleApiError(error: unknown): Response {
  logger.error(error, "API error occurred");

  // Zod validation errors
  if (error instanceof ZodError) {
    const fieldErrors: Record<string, string> = {};
    error.issues.forEach((issue) => {
      const path = issue.path.join(".");
      fieldErrors[path] = issue.message;
    });

    return Response.json(
      {
        error: "Validation failed",
        code: "VALIDATION_ERROR",
        fieldErrors,
      },
      { status: 400 }
    );
  }

  // Custom API errors
  if (error instanceof APIError) {
    return Response.json(
      {
        error: error.message,
        code: error.code,
        details: error.details,
      },
      { status: error.status }
    );
  }

  // Database errors
  if (error instanceof Error && error.message.includes("duplicate key")) {
    return Response.json(
      {
        error: "Resource already exists",
        code: "DUPLICATE_RESOURCE",
      },
      { status: 409 }
    );
  }

  // Generic server errors
  return Response.json(
    {
      error: process.env.NODE_ENV === "development" 
        ? error instanceof Error ? error.message : "Unknown error"
        : "Internal server error",
      code: "INTERNAL_ERROR",
    },
    { status: 500 }
  );
}

// Route error wrapper
export function withErrorHandler<T extends (...args: any[]) => any>(
  handler: T
): T {
  return (async (...args: Parameters<T>) => {
    try {
      return await handler(...args);
    } catch (error) {
      return handleApiError(error);
    }
  }) as T;
}
```

### Route Error Handling

```tsx
// API route with error handling
export const action = withErrorHandler(async ({ request, params }: Route.ActionArgs) => {
  const session = await requireCookieOrTokenSession(request);
  const body = await request.json();
  
  // Validate input
  const validData = createUserSchema.parse(body);
  
  // Check permissions
  if (!hasPermission(session, "create_user")) {
    throw new UnauthorizedError("Insufficient permissions");
  }
  
  // Create user
  const user = await db
    .insertInto("identity.users")
    .values(validData)
    .returningAll()
    .executeTakeFirstOrThrow(() => new APIError("Failed to create user"));
  
  return Response.json({ user });
});

// Error boundary for routes
export function ErrorBoundary({ error }: { error: unknown }) {
  if (isRouteErrorResponse(error)) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="text-center">
          <h1 className="text-4xl font-bold text-gray-900 mb-4">
            {error.status}
