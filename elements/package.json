{
  "name": "@editframe/packages",
  "version": "0.43.0",
  "description": "Editframe Elements Development package",
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/patch-rolldown-plugin-dts.mjs",
    "test": "npx vitest --config vitest.config.ts --configLoader bundle --run",
    "test:watch": "npx vitest --config vitest.config.ts --configLoader bundle --watch",
    "browsertest": "npx vitest --config vitest.config.browser.ts --configLoader bundle --run",
    "browsertest:watch": "npx vitest --config vitest.config.browser.ts --configLoader bundle --watch",
    "lint": "oxlint . --config oxlint.json",
    "format": "oxfmt .",
    "start": "scripts/start",
    "build:all": "node scripts/deps.js sorted 2>/dev/null | xargs -I {} npm run build --workspace {}",
    "typedoc": "typedoc --out docs/packages/ packages/api/src"
  },
  "type": "module",
  "author": "Editframe",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@lit/context": "^1.1.6",
