#!/usr/bin/env bash

# Wait for a GitHub Actions workflow to complete
# Usage: wait-for-github-action <repo> [workflow-file] [timeout-seconds]
# If workflow-file is omitted, watches the most recent active run

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Run the TypeScript version
exec npx tsx "${SCRIPT_DIR}/wait-for-github-action.ts" "$@"

