#!/usr/bin/env bash

# Build and run production web container locally for debugging
# This is useful for debugging production issues like the custom element registration problem
#
# Usage:
#   ./scripts/debug-prod-web                    # Run with dev database
#   ./scripts/debug-prod-web --use-prod-db      # Use production database settings
#   ./scripts/debug-prod-web --shell            # Drop into shell instead of running server
#   ./scripts/debug-prod-web --rebuild          # Force rebuild of image

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
TELECINE_ROOT="${SCRIPT_DIR}/.."
cd "$TELECINE_ROOT"

IMAGE_NAME="telecine-web-prod-debug"
DOCKERFILE="${TELECINE_ROOT}/Dockerfile.web.prod.debug"

USE_PROD_DB=false
SHELL_MODE=false
REBUILD=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --use-prod-db)
      USE_PROD_DB=true
      shift
      ;;
    --shell)
      SHELL_MODE=true
      shift
      ;;
    --rebuild)
      REBUILD=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [--use-prod-db] [--shell] [--rebuild]"
      exit 1
      ;;
  esac
done

# Check if .env file exists
if [ ! -f "${TELECINE_ROOT}/.env" ]; then
  echo "Warning: .env file not found. You may need to create one with required environment variables."
fi

# Create debug Dockerfile if it doesn't exist
if [ ! -f "$DOCKERFILE" ]; then
  echo "Creating debug Dockerfile..."
  cat > "$DOCKERFILE" << 'EOF'
FROM node:22 AS installer

WORKDIR /app

COPY ./package.json ./package-lock.json  ./
COPY ./postcss.config.cjs ./

ENV ELECTRON_SKIP_BINARY_DOWNLOAD=1
RUN npm install

COPY ./lib/ ./lib/
COPY ./services/web/ ./services/web/
COPY ./tsconfig.json ./ 
COPY ./react-router.config.ts /app/react-router.config.ts
COPY ./tailwind.config.ts /app/tailwind.config.ts
COPY ./postcss.config.cjs /app/postcss.config.cjs

ENV NODE_ENV=production
ENV VITE_HASURA_CLIENT_URL="https://editframe.com/v1/graphql"
ENV VITE_WEB_HOST="https://editframe.com"
RUN npx react-router build --config services/web/vite.config.ts

# Use node:22 instead of distroless for debugging
FROM node:22

WORKDIR /app

ENV NODE_ENV=production

COPY --from=installer /app/package.json /app/package-lock.json ./
COPY --from=installer /app/node_modules /app/node_modules
COPY --from=installer /app/services/web/ /app/services/web/
COPY --from=installer /app/lib /app/lib
COPY --from=installer /app/services/web/build /app/services/web/build
COPY ./tsconfig.json /app/tsconfig.json
COPY ./loader.js /app/loader.js

# Install useful debugging tools
RUN apt-get update && apt-get install -y \
  curl \
  vim \
  less \
  && rm -rf /var/lib/apt/lists/*

CMD ["--loader", "/app/loader.js", "/app/services/web/server.js"]
EOF
fi

# Build the image
if [ "$REBUILD" = "true" ] || ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
  echo "Building production web container for debugging..."
  export DOCKER_BUILDKIT=1
  docker build \
    -f "$DOCKERFILE" \
    -t "$IMAGE_NAME" \
    --progress=plain \
    .
else
  echo "Using existing image: $IMAGE_NAME (use --rebuild to force rebuild)"
fi

# Determine database connection and network
if [ "$USE_PROD_DB" = "false" ]; then
  # Connect to dev database via docker network
  # Find the docker network used by telecine services
  NETWORK_NAME="telecine_default"
  if ! docker network inspect "$NETWORK_NAME" &>/dev/null; then
    # Try alternative network names
    NETWORK_NAME=$(docker network ls --format '{{.Name}}' | grep -E '^(telecine|editframe)' | head -1 || echo "")
    if [ -z "$NETWORK_NAME" ]; then
      echo "Warning: Could not find telecine docker network. Database connection may fail."
      echo "Make sure docker-compose services are running: cd telecine && docker-compose up -d"
    fi
  fi
  
  DB_HOST="${DB_HOST:-graphql-engine}"
  DB_PORT="${DB_PORT:-5432}"
  DB_NAME="${DB_NAME:-hasura}"
  DB_USER="${DB_USER:-postgres}"
  DB_PASSWORD="${DB_PASSWORD:-postgres}"
  
  echo "Using dev database: ${DB_USER}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
  echo "Connecting to network: ${NETWORK_NAME}"
else
  # Use production database settings from .env
  echo "Using production database settings from .env"
  NETWORK_NAME=""
fi

# Determine command to run
if [ "$SHELL_MODE" = "true" ]; then
  CMD=("/bin/bash")
else
  CMD=("--loader" "/app/loader.js" "/app/services/web/server.js")
fi

# Run the container
echo "Starting production web container..."
if [ "$USE_PROD_DB" = "false" ] && [ -n "$NETWORK_NAME" ]; then
  docker run -it --rm \
    --name telecine-web-prod-debug \
    -p 3000:3000 \
    --network "${NETWORK_NAME}" \
    --env-file "${TELECINE_ROOT}/.env" \
    -e "POSTGRES_HOST=${DB_HOST}" \
    -e "POSTGRES_PORT=${DB_PORT}" \
    -e "POSTGRES_DB=${DB_NAME}" \
    -e "POSTGRES_USER=${DB_USER}" \
    -e "POSTGRES_PASSWORD=${DB_PASSWORD}" \
    -e NODE_ENV=production \
    -e PORT=3000 \
    "$IMAGE_NAME" \
    "${CMD[@]}"
else
  docker run -it --rm \
    --name telecine-web-prod-debug \
    -p 3000:3000 \
    --env-file "${TELECINE_ROOT}/.env" \
    -e NODE_ENV=production \
    -e PORT=3000 \
    "$IMAGE_NAME" \
    "${CMD[@]}"
fi

