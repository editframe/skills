#!/usr/bin/env bash
# Bump the major version and run prepare-release.
# Usage: scripts/major-release

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

CURRENT=$(node -e "process.stdout.write(require('${SCRIPT_DIR}/../packages/elements/package.json').version)")
IFS='.' read -r MAJOR _MINOR _PATCH <<< "$CURRENT"
NEXT="$((MAJOR + 1)).0.0"

echo "Preparing major release: ${CURRENT} → ${NEXT}"
"${SCRIPT_DIR}"/prepare-release "$NEXT"
