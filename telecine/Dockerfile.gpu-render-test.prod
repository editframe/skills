FROM node:22-slim AS builder

ENV NODE_ENV=production

WORKDIR /app

RUN apt-get update \
  && apt-get install -y \
  unzip \
  libnss3 \
  libgtk-3-0 \
  libxss1 \
  libasound2 \
  libxrandr2 \
  libgconf-2-4 \
  libxdamage1 \
  libxcomposite1 \
  libxcursor1 \
  libxi6 \
  libxtst6 \
  libnss3-dev \
  libdrm2 \
  libxkbcommon0 \
  libgtk2.0-0 \
  libegl1-mesa \
  libgles2-mesa \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

COPY package.json package-lock.json ./
RUN npm install

COPY lib/ lib/
COPY services/gpu-render-test/ services/gpu-render-test/
COPY tsconfig.json ./

WORKDIR /app/services/gpu-render-test
RUN npx vite build

WORKDIR /app
RUN npx vite build --config /app/lib/electron-exec/vite.electron-rpc.config.ts

FROM nvidia/cuda:12.6.3-runtime-ubuntu22.04

ENV NODE_ENV=production

# graphics,video: inject libEGL_nvidia.so, Vulkan ICD, /dev/dri render nodes
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics,video
ENV NVIDIA_VISIBLE_DEVICES=all
# Tell the GLVND EGL dispatcher where to find vendor ICD files.
# The NVIDIA container toolkit injects nvidia_icd.json here at runtime.
ENV __EGL_VENDOR_LIBRARY_DIRS=/usr/share/glvnd/egl_vendor.d

RUN apt-get update \
  && apt-get install -y curl \
  && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install -y nodejs \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN apt-get update \
  && apt-get install -y \
  unzip \
  libnss3 \
  libgtk-3-0 \
  libxss1 \
  libasound2 \
  libxrandr2 \
  libgconf-2-4 \
  libxdamage1 \
  libxcomposite1 \
  libxcursor1 \
  libxi6 \
  libxtst6 \
  libnss3-dev \
  libdrm2 \
  libxkbcommon0 \
  libgtk2.0-0 \
  libgbm1 \
  libglvnd0 \
  libglvnd-dev \
  libegl1 \
  libgl1 \
  libgles2 \
  libvulkan1 \
  vulkan-tools \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN apt-get update \
  && apt-get install -y wget \
  && wget https://repo.jellyfin.org/files/ffmpeg/ubuntu/latest-7.x/amd64/jellyfin-ffmpeg7_7.1.3-3-jammy_amd64.deb \
  && dpkg -i jellyfin-ffmpeg7_7.1.3-3-jammy_amd64.deb || apt-get install -yf \
  && ln -sf /usr/lib/jellyfin-ffmpeg/ffmpeg /usr/local/bin/ffmpeg \
  && rm jellyfin-ffmpeg7_7.1.3-3-jammy_amd64.deb \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/package.json /app/package.json
COPY --from=builder /app/node_modules/ /app/node_modules/
COPY --from=builder /app/services/gpu-render-test/dist/ /app/services/gpu-render-test/dist/
COPY --from=builder /app/lib/ /app/lib/
COPY --from=builder /app/tsconfig.json /app/tsconfig.json

# Diagnostic entrypoint: verify GPU access before starting the render job
CMD ["bash", "-c", "\
  echo '=== /dev/dri ===' && ls -la /dev/dri/ 2>/dev/null || echo MISSING; \
  echo '=== /dev/nvidia* ===' && ls -la /dev/nvidia* 2>/dev/null || echo MISSING; \
  echo '=== GLVND EGL ICD ===' && ls -la /usr/share/glvnd/egl_vendor.d/ 2>/dev/null || echo MISSING; \
  echo '=== /etc/vulkan/icd.d ===' && ls -la /etc/vulkan/icd.d/ 2>/dev/null || echo MISSING; \
  echo '=== libEGL candidates ===' && ldconfig -p | grep -i egl || echo none; \
  echo '=== nvidia-smi ===' && nvidia-smi 2>&1 | head -8 || echo MISSING; \
  exec node /app/services/gpu-render-test/dist/main.js"]
