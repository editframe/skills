DEBUG=ef:*
POSTGRES_PASSWORD=postgrespassword
POSTGRES_USER=postgres
POSTGRES_HOST=editframe-postgres
POSTGRES_PORT=5432
POSTGRES_DB=telecine-main
DB_NAME=telecine-main
HASURA_GRAPHQL_UNAUTHORIZED_ROLE=anonymous
POSTGRES_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
HASURA_SERVER_URL=http://graphql-engine:8080/v1/graphql
VITE_HASURA_CLIENT_URL=http://localhost:8080/v1/graphql
HASURA_URL=http://graphql-engine:8080/v1/graphql
HASURA_ADMIN_SECRET=hasuraadminsecret
APPLICATION_JWT_SECRET=INSECURE_DEV_SECRET_CHANGE_FOR_PRODUCTION
HASURA_JWT_SECRET=INSECURE_DEV_SECRET_CHANGE_FOR_PRODUCTION
APPLICATION_SECRET=INSECURE_DEV_SECRET_CHANGE_FOR_PRODUCTION
ACTION_SECRET=INSECURE_ACTION_SECRET_CHANGE_FOR_PRODUCTION
ENABLE_ALL_FEATURES=true
MAILHOG_URL=http://mailhog:8025

# Using host.docker.internal to allow for traefik routing
HASURA_ACTION_ORIGIN=http://web:3000

HASURA_GRAPHQL_METADATA_DATABASE_URL=${POSTGRES_DATABASE_URL}
PG_DATABASE_URL=${POSTGRES_DATABASE_URL}
# enable the console served by server
HASURA_GRAPHQL_ENABLE_CONSOLE=false
## enable debugging mode. It is recommended to disable this in production
HASURA_GRAPHQL_DEV_MODE=true
HASURA_GRAPHQL_ENABLED_LOG_TYPES=startup,http-log,webhook-log,websocket-log,query-log
## uncomment next line to run console offline (i.e load console assets from server instead of CDN)
# HASURA_GRAPHQL_CONSOLE_ASSETS_DIR: /srv/console-assets
## uncomment next line to set an admin secret
HASURA_GRAPHQL_ADMIN_SECRET=hasuraadminsecret
HASURA_GRAPHQL_METADATA_DEFAULTS='{"backend_configs":{"dataconnector":{"athena":{"uri":"http://data-connector-agent:8081/api/v1/athena"},"mariadb":{"uri":"http://data-connector-agent:8081/api/v1/mariadb"},"mysql8":{"uri":"http://data-connector-agent:8081/api/v1/mysql"},"oracle":{"uri":"http://data-connector-agent:8081/api/v1/oracle"},"snowflake":{"uri":"http://data-connector-agent:8081/api/v1/snowflake"}}}}'
HASURA_GRAPHQL_JWT_SECRET="{ \"type\": \"HS256\", \"key\": \"${HASURA_JWT_SECRET}\" }"

### RENDER CONFIG
MAX_RENDER_CONCURRENCY=4

### SMPT MAILER CONFIG
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=user
SMTP_PASSWORD=password
SMTP_SECURE=false
SMTP_SENDER=telecine@example.com

### EMAIL CONFIG
EMAIL_SENDER=no-reply@editframe.com

WEB_HOST=http://localhost:3000
# This allows playwright-in-docker to follow email links
PLAYWRIGHT_WEB_HOST=http://web:3000
FRAMEGEN_OUTBOUND_HOST=http://web:3000
RENDER_HOST=http://render:3000
TRANSCRIBE_HOST=http://transcribe:3000
UPLOAD_TO_BUCKET=false
# STORAGE_BUCKET=telecine-dot-dev-data-4fedc83
STORAGE_BUCKET=editframe-dev

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5080/api/default/
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic YWRtaW5AZWRpdGZyYW1lLmRldjowVld2SEJZMFFlNHRzOHRq,stream-name=default

EF_TOKEN=ef_d6659715d9b74e9a8513597e5c6c5656_36dc5699-418f-478f-951c-e800acb110c5
EF_HOST=http://web:3000

# DOCKER SWARM CONFIG
EXTERNAL_IP=192.168.2.1
DOCKER_VM_IP=172.17.0.1

SLACK_WEBHOOK_URL=http://slack:8080
PUBLIC_STORAGE_BUCKET=editframe-assets
SLACK_TRANSACTIONS_URL=https://example.org

# ELectron needs to be informed of the location of the electron executable
ELECTRON_OVERRIDE_DIST_PATH=/electron-build

# Scheduler configuration
SCHEDULER_QUEUES=process-html-initializer,process-html-finalizer,process-isobmff,render-initializer,render-fragment,render-finalizer,ingest-image,test-fast-initializer,test-fast-main,test-fast-finalizer
SCHEDULER_TICK_MS=500
SCHEDULER_MIN_CONN_AGE_MS=5000
SCHEDULER_SCALE_DOWN_SMOOTHING=0.7
SCHEDULER_PING_INTERVAL_MS=2000
SCHEDULER_DISCONNECT_TIMEOUT_MS=5000

# Test Fast Workers
TEST_FAST_INITIALIZER_WEBSOCKET_HOST=http://worker-test-fast-initializer:3000
TEST_FAST_INITIALIZER_MAX_WORKER_COUNT=5
TEST_FAST_INITIALIZER_WORKER_CONCURRENCY=1
TEST_FAST_MAIN_WEBSOCKET_HOST=http://worker-test-fast-main:3000
TEST_FAST_MAIN_MAX_WORKER_COUNT=10
TEST_FAST_MAIN_WORKER_CONCURRENCY=2
TEST_FAST_FINALIZER_WEBSOCKET_HOST=http://worker-test-fast-finalizer:3000
TEST_FAST_FINALIZER_MAX_WORKER_COUNT=5
TEST_FAST_FINALIZER_WORKER_CONCURRENCY=1