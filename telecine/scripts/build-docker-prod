#!/usr/bin/env bash

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

set -ex

export DOCKER_BUILDKIT=1

REPO=us-central1-docker.pkg.dev/editframe/telecine-artifacts

CACHE_FROM=""
BUILD_ARGS=""

name=$1

if [ -n "$CI" ]; then
  CACHE_FROM="--cache-from=type=registry,ref=${REPO}/${name}:buildcache ${CACHE_FROM}"
  CACHE_TO="--cache-to=type=registry,ref=${REPO}/${name}:buildcache,mode=max"
else
  CACHE_TO=""
fi

VERSION="latest"

if [ -n "$GITHUB_SHA" ]; then
  VERSION=$GITHUB_SHA
else
  # Try to get current git commit SHA if not in CI environment
  GIT_SHA=$(git rev-parse HEAD 2>/dev/null || echo "latest")
  VERSION=$GIT_SHA
fi

TAG=${REPO}/${name}:${VERSION}

#This section runs before the docker build
# this is crucial for downloading dependencies that aren't available in images
case $name in
  transcribe)
    # Build and cache whisper stage separately with registry caching
    WHISPER_BUILDER_TAG="${REPO}/${name}-whisper-builder:latest"
    docker buildx build \
      ${SCRIPT_DIR}/.. \
      --target whisper-builder \
      -t ${WHISPER_BUILDER_TAG} \
      --cache-from=type=registry,ref=${WHISPER_BUILDER_TAG} \
      --cache-to=type=registry,ref=${WHISPER_BUILDER_TAG},mode=max \
      --platform=linux/amd64 \
      -f ${SCRIPT_DIR}/../Dockerfile.${name}.prod \
    
    # Add whisper builder to cache sources
    CACHE_FROM="--cache-from=type=registry,ref=${WHISPER_BUILDER_TAG} ${CACHE_FROM}"
    DOCKERFILE="Dockerfile.${name}.prod"
    ;;
  *)
    DOCKERFILE="Dockerfile.${name}.prod"
    ;;
esac

docker buildx build \
  ${SCRIPT_DIR}/.. \
  -f ${SCRIPT_DIR}/../${DOCKERFILE} \
  --platform=linux/amd64 \
  -t ${TAG} \
  ${CACHE_FROM} \
  ${CACHE_TO} \
  ${BUILD_ARGS} \
  --progress=plain
