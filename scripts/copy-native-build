#!/usr/bin/env bash
# Discovers and executes all copy-build-artifacts scripts in the project
# Each module/service that has build artifacts should have its own
# copy-build-artifacts script in its directory

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Find all copy-build-artifacts scripts
# Look in lib/ and services/ directories
find "$PROJECT_ROOT" \
  \( -path "*/lib/*" -o -path "*/services/*" \) \
  -type f \
  -name "copy-build-artifacts" \
  | sort | while read -r script; do
  if [ -x "$script" ]; then
    echo "Running: $script"
    "$script" || {
      echo "Error: Failed to run $script" >&2
      exit 1
    }
  fi
done

