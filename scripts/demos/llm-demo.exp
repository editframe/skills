set timeout 300
set env(TERM) "xterm-256color"
set env(COLORTERM) "truecolor"
set env(npm_config_user_agent) "npm"

set WORK_DIR $env(WORK_DIR)
set PROMPT_FILE $env(PROMPT_FILE)
set DONE_MARKER "EF_CLAUDE_DONE_7x9q"

cd $WORK_DIR

# Use zsh — clean on macOS, no upgrade warnings
spawn zsh --no-rcs

# Set a clean prompt that looks like a real project directory: ~/weather-composition $
send "PROMPT='%F{green}~/weather-composition%f %# '; setopt PROMPT_SUBST; clear\r"
sleep 0.4
expect "% "
after 500

# Type the claude command char by char
set cmd "claude -p --allowedTools Write,Bash --dangerously-skip-permissions < prompt.txt && echo $DONE_MARKER"
foreach ch [split $cmd ""] {
    send -- $ch
    after 45
}
after 600
send "\r"

# Wait for the completion marker
expect {
    -timeout 300
    "$DONE_MARKER" {}
    timeout {
        send_error "Timed out waiting for claude\n"
        exit 1
    }
}

# Wait for shell prompt to return
expect {
    -timeout 10
    "% " {}
    timeout {}
}
after 600

# Show a peek at the written file — viewer sees real HTML code
set peek_cmd "head -40 index.html"
foreach ch [split $peek_cmd ""] {
    send -- $ch
    after 50
}
send "\r"
expect {
    -timeout 10
    "% " {}
    timeout {}
}
after 1200

# Now run the render
set render_cmd "npx editframe render -o output.mp4"
foreach ch [split $render_cmd ""] {
    send -- $ch
    after 55
}
after 500
send "\r"

expect {
    -timeout 120
    "Render complete" { after 2500 }
    timeout {
        send_error "Timed out waiting for render\n"
        exit 1
    }
}

after 1000
send "exit\r"
expect eof
