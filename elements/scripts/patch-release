#!/usr/bin/env bash
# Bump the patch version and run prepare-release.
# Usage: scripts/patch-release

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

CURRENT=$(node -e "process.stdout.write(require('${SCRIPT_DIR}/../packages/elements/package.json').version)")
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
NEXT="${MAJOR}.${MINOR}.$((PATCH + 1))"

echo "Preparing patch release: ${CURRENT} → ${NEXT}"
"${SCRIPT_DIR}"/prepare-release "$NEXT"
