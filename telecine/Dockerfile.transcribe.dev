# Build stage for whisper.cpp
FROM ubuntu:22.04 AS whisper-builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && \
    apt-get install -y build-essential git \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Build whisper.cpp without CUDA
ARG WHISPER_BRANCH=v1.7.1
RUN git clone --depth 1 --branch ${WHISPER_BRANCH} https://github.com/ggerganov/whisper.cpp.git && \
    cd whisper.cpp && \
    make -j

# Download the model (changed to tiny model for dev)
RUN apt-get update && \
    apt-get install -y python3 python3-pip && \
    pip3 install --no-cache-dir huggingface_hub && \
    python3 -c "from huggingface_hub import hf_hub_download; hf_hub_download(repo_id='distil-whisper/distil-small.en', filename='ggml-distil-small.en.bin', local_dir='/app/whisper.cpp/models')"

# Final runtime stage
FROM node:22-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3-venv \
    python3-pip \
    ffmpeg \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

ENV NODE_ENV=development
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
ENV WHISPER_PATH /whisper.cpp/main
ENV GGML_MODEL_PATH=/whisper.cpp/models/ggml-distil-small.en.bin
ENV BEAM_SIZE=1

# Create and activate virtual environment
RUN python3 -m venv $VIRTUAL_ENV

# Copy whisper.cpp build artifacts
COPY --from=whisper-builder /app/whisper.cpp /whisper.cpp

CMD ["node", "/app/services/transcribe/server.js"]