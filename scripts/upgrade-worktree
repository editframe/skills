#!/usr/bin/env bash
# Upgrade a worktree to a broader scope.
#
# Usage: upgrade-worktree [branch-name] <new-scope>
#   If branch-name is omitted, uses the current branch.
#
# Transitions:
#   elements -> web      Start telecine core services, create database, run migrations
#   elements -> render   Same as above + render pipeline
#   web -> render        Start additional render-profile services

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

# Parse arguments
if [ $# -eq 1 ]; then
  NEW_SCOPE="$1"
  BRANCH_NAME=$(git branch --show-current 2>/dev/null)
  WORKTREE_ROOT=$(git rev-parse --show-toplevel)
elif [ $# -eq 2 ]; then
  BRANCH_NAME="$1"
  NEW_SCOPE="$2"
  # Find worktree for this branch
  WORKTREE_ROOT=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^worktree[[:space:]]+(.+)$ ]]; then
      WORKTREE_ROOT="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^branch[[:space:]]+refs/heads/(.+)$ ]]; then
      if [ "${BASH_REMATCH[1]}" = "$BRANCH_NAME" ]; then
        break
      fi
      WORKTREE_ROOT=""
    fi
  done < <(git worktree list --porcelain)
  if [ -z "$WORKTREE_ROOT" ]; then
    echo "Error: Could not find worktree for branch '$BRANCH_NAME'" >&2
    exit 1
  fi
else
  echo "Usage: $0 [branch-name] <elements|web|render>" >&2
  exit 1
fi

case "$NEW_SCOPE" in
  elements|web|render) ;;
  *) echo "Invalid scope: $NEW_SCOPE" >&2; exit 1 ;;
esac

# Read current scope
SCOPE_FILE="$WORKTREE_ROOT/.worktree-scope"
CURRENT_SCOPE="elements"
if [ -f "$SCOPE_FILE" ]; then
  CURRENT_SCOPE=$(cat "$SCOPE_FILE")
fi

# Validate transition
SCOPE_ORDER="elements web render"
current_idx=0; new_idx=0; i=0
for s in $SCOPE_ORDER; do
  if [ "$s" = "$CURRENT_SCOPE" ]; then current_idx=$i; fi
  if [ "$s" = "$NEW_SCOPE" ]; then new_idx=$i; fi
  i=$((i + 1))
done

if [ $new_idx -le $current_idx ]; then
  echo "Already at scope '$CURRENT_SCOPE'. Cannot downgrade to '$NEW_SCOPE'." >&2
  exit 1
fi

echo "Upgrading worktree from '$CURRENT_SCOPE' to '$NEW_SCOPE'..."

# Sanitize branch name
sanitize_branch_name() {
  local name="$1"
  name=$(echo "$name" | tr '[:upper:]' '[:lower:]')
  name=$(echo "$name" | sed 's/[^a-z0-9]/-/g')
  name=$(echo "$name" | sed 's/^-\+//; s/-\+$//')
  name=$(echo "$name" | sed 's/-\+/-/g')
  name=$(echo "$name" | cut -c1-63)
  name=$(echo "$name" | sed 's/-$//')
  echo "$name"
}
SANITIZED_BRANCH=$(sanitize_branch_name "$BRANCH_NAME")
MAIN_WORKTREE=$(git worktree list | grep -E '\[main\]|\[master\]' | awk '{print $1}' | head -1)

# If upgrading from elements to web/render, need to set up telecine
if [ "$CURRENT_SCOPE" = "elements" ]; then
  WORKTREE_DATABASE="telecine-${SANITIZED_BRANCH}"

  # Copy telecine .env if not present
  if [ ! -f "$WORKTREE_ROOT/telecine/.env" ] && [ -f "$MAIN_WORKTREE/telecine/.env" ]; then
    cp "$MAIN_WORKTREE/telecine/.env" "$WORKTREE_ROOT/telecine/.env"
  fi

  # Copy native build artifacts
  if [ -f "$WORKTREE_ROOT/telecine/scripts/copy-native-build" ]; then
    cd "$WORKTREE_ROOT/telecine"
    ./scripts/copy-native-build > /dev/null 2>&1 || true
  fi

  # Create database from template
  TEMPLATE_EXISTS=$(docker exec editframe-postgres psql -U postgres -tAc "SELECT 1 FROM pg_database WHERE datname = 'telecine-template'" 2>/dev/null)
  DB_EXISTS=$(docker exec editframe-postgres psql -U postgres -tAc "SELECT 1 FROM pg_database WHERE datname = '$WORKTREE_DATABASE'" 2>/dev/null)

  if [ "$DB_EXISTS" != "1" ]; then
    if [ "$TEMPLATE_EXISTS" = "1" ]; then
      echo "Cloning database from template..."
      docker exec editframe-postgres psql -U postgres \
        -c "CREATE DATABASE \"$WORKTREE_DATABASE\" TEMPLATE \"telecine-template\";" > /dev/null 2>&1
    fi
  fi

  # Set profile and start telecine
  case "$NEW_SCOPE" in
    web)    export COMPOSE_PROFILES="" ;;
    render) export COMPOSE_PROFILES="render" ;;
  esac

  cd "$WORKTREE_ROOT/telecine"

  echo "Starting telecine runner..."
  ./scripts/docker-compose up -d runner > /dev/null 2>&1

  echo "Installing telecine dependencies..."
  ./scripts/npm install > /dev/null 2>&1

  echo "Starting telecine services ($NEW_SCOPE)..."
  ./scripts/docker-compose up -d > /dev/null 2>&1

  echo "Applying migrations..."
  ./scripts/migrate-db > /dev/null 2>&1 || true

  # Generate EF_TOKEN
  . scripts/worktree-config > /dev/null 2>&1 || true
  EF_TOKEN=$(./scripts/run node \
    --import 'data:text/javascript,import { register } from "node:module"; import { pathToFileURL } from "node:url"; register("./loader.js", pathToFileURL("./"));' \
    scripts/generate-forever-token.ts 2>&1 | tail -n1) || true

  if [ -n "$EF_TOKEN" ] && ! echo "$EF_TOKEN" | grep -q "Error"; then
    ELEMENTS_ENV="$WORKTREE_ROOT/elements/.env"
    TELECINE_WEB_HOST="http://telecine-${SANITIZED_BRANCH}-web-1:3000"
    grep -v "^EF_TOKEN=\|^EF_HOST=\|^VITEST_BROWSER_MODE=" "$ELEMENTS_ENV" > "$ELEMENTS_ENV.tmp" 2>/dev/null || true
    mv "$ELEMENTS_ENV.tmp" "$ELEMENTS_ENV"
    echo "EF_TOKEN=\"$EF_TOKEN\"" >> "$ELEMENTS_ENV"
    echo "EF_HOST=\"$TELECINE_WEB_HOST\"" >> "$ELEMENTS_ENV"
    echo "VITEST_BROWSER_MODE=\"connect\"" >> "$ELEMENTS_ENV"
  fi

  cd "$MAIN_WORKTREE"

elif [ "$CURRENT_SCOPE" = "web" ] && [ "$NEW_SCOPE" = "render" ]; then
  # Just start the render-profile services
  export COMPOSE_PROFILES="render"
  echo "Starting render pipeline services..."
  cd "$WORKTREE_ROOT/telecine"
  ./scripts/docker-compose up -d > /dev/null 2>&1
  cd "$MAIN_WORKTREE"
fi

# Update scope file
echo "$NEW_SCOPE" > "$SCOPE_FILE"

echo "Upgraded to scope: $NEW_SCOPE"
