#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Find monorepo root or use telecine root
find_monorepo_root() {
  local current_dir="$1"
  
  # Try git rev-parse first
  if git rev-parse --git-dir > /dev/null 2>&1; then
    local git_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
    if [ -n "$git_root" ] && [ -d "$git_root/elements" ] && [ -d "$git_root/telecine" ]; then
      echo "$git_root"
      return 0
    fi
  fi
  
  # Traverse up to find directory containing both elements and telecine
  local dir="$current_dir"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/elements" ] && [ -d "$dir/telecine" ]; then
      echo "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  
  # Fallback to telecine root
  echo "$SCRIPT_DIR/.."
}

MONOREPO_ROOT=$(find_monorepo_root "$SCRIPT_DIR/..")
WS_ENDPOINT_PATH="$MONOREPO_ROOT/.wsEndpoint.json"

# Check if .wsEndpoint.json exists, if not start browser server
if [ ! -f "$WS_ENDPOINT_PATH" ]; then
  echo "Browser server not running. Starting browser server..."
  
  # Determine path to start-host-chrome.ts
  if [ -f "$MONOREPO_ROOT/elements/scripts/start-host-chrome.ts" ]; then
    # Use elements script from monorepo
    START_CHROME_SCRIPT="$MONOREPO_ROOT/elements/scripts/start-host-chrome.ts"
  elif [ -f "$SCRIPT_DIR/../elements/scripts/start-host-chrome.ts" ]; then
    # Try relative path
    START_CHROME_SCRIPT="$SCRIPT_DIR/../elements/scripts/start-host-chrome.ts"
  else
    echo "Error: Could not find start-host-chrome.ts script" >&2
    exit 1
  fi
  
  # Start browser server in background
  npx tsx "$START_CHROME_SCRIPT" &
  BROWSER_PID=$!
  
  # Wait for .wsEndpoint.json to be created (poll with timeout)
  TIMEOUT=10
  ELAPSED=0
  while [ $ELAPSED -lt $TIMEOUT ]; do
    if [ -f "$WS_ENDPOINT_PATH" ]; then
      echo "Browser server started successfully"
      break
    fi
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))
  done
  
  if [ ! -f "$WS_ENDPOINT_PATH" ]; then
    echo "Error: Browser server failed to start within ${TIMEOUT}s" >&2
    kill $BROWSER_PID 2>/dev/null || true
    exit 1
  fi
fi

# Set connect mode if not already set and .wsEndpoint.json exists
if [ -z "${VITEST_BROWSER_MODE}" ] && [ -f "$WS_ENDPOINT_PATH" ]; then
  export VITEST_BROWSER_MODE=connect
fi

# Load worktree config to get WORKTREE_DOMAIN
if [ -f "${SCRIPT_DIR}/worktree-config" ]; then
  source "${SCRIPT_DIR}/worktree-config"
  export WORKTREE_DOMAIN
fi

"${SCRIPT_DIR}"/npx vitest --config vitest.config.browser.ts --configLoader bundle "$@"

