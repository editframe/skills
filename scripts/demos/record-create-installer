#!/usr/bin/env bash
# Records the @editframe/create installer demo and renders it to mp4.
#
# Usage: scripts/demos/record-create-installer [output.mp4]
#   output.mp4 defaults to /tmp/create-installer.mp4

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS="$(cd "$SCRIPT_DIR/.." && pwd)"
MONOREPO="$(cd "$SCRIPTS/.." && pwd)"

OUT_MP4="${1:-/tmp/create-installer.mp4}"
CAST="$(mktemp /tmp/create-installer-XXXXXX.cast)"
trap 'rm -f "$CAST"' EXIT

# Clean any leftover demo directories from previous runs
rm -rf ~/my-video-app

# Pass the create binary path to the expect script via env
export CREATE_BIN="$MONOREPO/elements/packages/create/dist/index.js"

# Record
"$SCRIPTS/record-cast" \
  "$SCRIPT_DIR/create-installer.exp" \
  "$CAST" \
  --cols 100 \
  --rows 28

# Strip "spawn node ..." artifact, collapse the npm install spinner to 0.5s,
# then prepend a convincing shell prompt
"$SCRIPTS/cast-edit" \
  --strip-first 1 \
  --collapse-spinner "Installing dependencies with npm:0.5" \
  --prepend-prompt $'\x1b[32m~\x1b[0m $ :npm create @editframe@latest' \
  "$CAST"

# Render to mp4 — larger font for readability on landing page
node "$SCRIPTS/render-cast" \
  --title "npm create @editframe@latest" \
  --font-px 17 \
  "$CAST" "$OUT_MP4"

echo "Done: $OUT_MP4"
