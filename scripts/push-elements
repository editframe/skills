#!/usr/bin/env bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
PROJECT_ROOT="$SCRIPT_DIR/.."

cd "$PROJECT_ROOT"

WAIT_FOR_ACTION=false
BRANCH="main"

while [[ $# -gt 0 ]]; do
  case $1 in
    --wait)
      WAIT_FOR_ACTION=true
      shift
      ;;
    --branch)
      BRANCH="$2"
      shift 2
      ;;
    *)
      BRANCH="$1"
      shift
      ;;
  esac
done

git fetch elements "$BRANCH" 2>/dev/null || true

MONO_SHORT=$(git rev-parse --short HEAD)
TREE=$(git rev-parse HEAD:elements)

if git rev-parse "elements/$BRANCH" >/dev/null 2>&1; then
  PARENT=$(git rev-parse "elements/$BRANCH")
  REMOTE_TREE=$(git rev-parse "elements/${BRANCH}^{tree}" 2>/dev/null || echo "")
  if [ "$TREE" = "$REMOTE_TREE" ]; then
    echo "elements/${BRANCH} already up to date"
    exit 0
  fi
  COMMIT=$(git commit-tree "$TREE" -p "$PARENT" -m "sync $MONO_SHORT")
else
  COMMIT=$(git commit-tree "$TREE" -m "sync $MONO_SHORT (initial)")
fi

git push elements "${COMMIT}:${BRANCH}" --force-with-lease 2>&1 | grep -v "^$"

echo "pushed elements -> ${BRANCH} (${COMMIT:0:10})"

if [ "$WAIT_FOR_ACTION" = "true" ]; then
  "$SCRIPT_DIR/wait-for-elements-action" "release.yaml"
fi
