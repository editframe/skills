## Client-Side Error Handling

### Async Error Handling

```tsx
import { useFetcher } from "react-router";
import { useEffect, useState } from "react";

export function useAsyncError() {
  const [error, setError] = useState<Error | null>(null);

  const captureError = (error: Error) => {
    setError(error);
    logger.error(error, "Async error captured");
  };

  const clearError = () => setError(null);

  return { error, captureError, clearError };
}

// Safe async wrapper
export function useSafeAsync<T>(
  asyncFn: () => Promise<T>,
  deps: React.DependencyList
) {
  const [data, setData] = useState<T | null>(null);
  const [loading, setLoading] = useState(false);
  const { error, captureError, clearError } = useAsyncError();

  useEffect(() => {
    let cancelled = false;
    setLoading(true);
    clearError();

    asyncFn()
      .then((result) => {
        if (!cancelled) {
          setData(result);
        }
      })
      .catch((err) => {
        if (!cancelled) {
          captureError(err);
        }
      })
      .finally(() => {
        if (!cancelled) {
          setLoading(false);
        }
      });

    return () => {
      cancelled = true;
    };
  }, deps);

  return { data, loading, error, clearError };
}
```

### Form Error Handling

```tsx
export function useFormErrors() {
  const [errors, setErrors] = useState<Record<string, string>>({});

  const setFieldError = (field: string, message: string) => {
    setErrors(prev => ({ ...prev, [field]: message }));
  };

  const clearFieldError = (field: string) => {
    setErrors(prev => {
      const { [field]: _, ...rest } = prev;
      return rest;
    });
  };

  const clearAllErrors = () => setErrors({});

  const hasErrors = Object.keys(errors).length > 0;

  return {
    errors,
    setFieldError,
    clearFieldError,
    clearAllErrors,
    hasErrors,
  };
}

// Form with error handling
export function UserForm() {
  const fetcher = useFetcher();
  const { errors, setFieldError, clearFieldError, clearAllErrors } = useFormErrors();

  useEffect(() => {
    if (fetcher.data?.fieldErrors) {
      Object.entries(fetcher.data.fieldErrors).forEach(([field, message]) => {
        setFieldError(field, message as string);
      });
    }
  }, [fetcher.data]);

  return (
    <fetcher.Form method="post" onSubmit={clearAllErrors}>
      <div>
        <input
          name="email"
          type="email"
          onChange={() => clearFieldError("email")}
          className={errors.email ? "border-red-500" : ""}
        />
        {errors.email && (
          <p className="text-red-500 text-sm mt-1">{errors.email}</p>
        )}
      </div>
      
      {fetcher.data?.error && (
        <div className="bg-red-50 border border-red-200 rounded p-3 mb-4">
          <p className="text-red-700">{fetcher.data.error}</p>
        </div>
      )}
      
      <button
        type="submit"
        disabled={fetcher.state === "submitting"}
      >
        {fetcher.state === "submitting" ? "Submitting..." : "Submit"}
      </button>
    </fetcher.Form>
  );
}
```

## Error Logging and Monitoring

### Structured Error Logging

```tsx
import pino from "pino";

export const logger = pino({
  level: process.env.LOG_LEVEL || "info",
  serializers: {
    error: pino.stdSerializers.err,
    req: pino.stdSerializers.req,
    res: pino.stdSerializers.res,
  },
});

// Enhanced error logging
export function logError(
  error: Error,
  context: {
    userId?: string;
    orgId?: string;
    action?: string;
    metadata?: Record<string, any>;
  } = {}
) {
  logger.error(
    {
      error: {
        name: error.name,
        message: error.message,
        stack: error.stack,
      },
      context,
      timestamp: new Date().toISOString(),
    },
    "Error occurred"
  );
}

// Database error logging
export async function logErrorToDatabase(
  error: Error,
  context: Record<string, any> = {}
) {
  try {
    await db
      .insertInto("error_logs")
      .values({
        error_name: error.name,
        error_message: error.message,
        error_stack: error.stack,
        context: JSON.stringify(context),
        user_id: context.userId,
        org_id: context.orgId,
      })
      .execute();
  } catch (logError) {
    logger.error(logError, "Failed to log error to database");
  }
}
```

### Error Reporting

```tsx
// Send errors to external service
export function sendErrorReport(error: Error, errorInfo?: any) {
  if (process.env.NODE_ENV !== "production") return;

  const errorData = {
    name: error.name,
    message: error.message,
    stack: error.stack,
    url: window.location.href,
    userAgent: navigator.userAgent,
    timestamp: new Date().toISOString(),
    errorInfo,
  };

  // Send to error tracking service (e.g., Sentry, Bugsnag)
  fetch("/api/errors", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify(errorData),
  }).catch((err) => {
    console.error("Failed to send error report:", err);
  });
}

// Global error handlers
export function setupGlobalErrorHandlers() {
  // Unhandled promise rejections
  window.addEventListener("unhandledrejection", (event) => {
    console.error("Unhandled promise rejection:", event.reason);
    sendErrorReport(
      event.reason instanceof Error ? event.reason : new Error(String(event.reason)),
      { type: "unhandledrejection" }
    );
  });

  // Global JavaScript errors
  window.addEventListener("error", (event) => {
    console.error("Global error:", event.error);
    sendErrorReport(event.error, {
      type: "javascript",
      filename: event.filename,
      line: event.lineno,
      column: event.colno,
    });
  });
}
```

## Recovery Patterns

### Retry Logic

```tsx
export async function withRetry<T>(
  operation: () => Promise<T>,
  options: {
    maxAttempts?: number;
    delay?: number;
    backoff?: "linear" | "exponential";
    shouldRetry?: (error: any) => boolean;
  } = {}
): Promise<T> {
  const {
    maxAttempts = 3,
    delay = 1000,
    backoff = "exponential",
    shouldRetry = () => true,
  } = options;

  let lastError: any;

  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      return await operation();
    } catch (error) {
      lastError = error;

      if (attempt === maxAttempts || !shouldRetry(error)) {
        throw error;
      }

      const waitTime = backoff === "exponential" 
        ? delay * Math.pow(2, attempt - 1)
        : delay * attempt;

      await new Promise(resolve => setTimeout(resolve, waitTime));
    }
  }

  throw lastError;
}

// Usage example
const data = await withRetry(
  () => fetch("/api/data").then(res => res.json()),
  {
    maxAttempts: 3,
    delay: 1000,
    shouldRetry: (error) => {
      // Only retry on network errors or 5xx responses
      return error.name === "TypeError" || 
             (error.status >= 500 && error.status < 600);
    },
  }
);
```

### Circuit Breaker Pattern

```tsx
export class CircuitBreaker {
  private failures = 0;
  private lastFailureTime = 0;
  private state: "closed" | "open" | "half-open" = "closed";

  constructor(
    private threshold: number = 5,
    private timeout: number = 60000
  ) {}

  async execute<T>(operation: () => Promise<T>): Promise<T> {
    if (this.state === "open") {
      if (Date.now() - this.lastFailureTime > this.timeout) {
        this.state = "half-open";
      } else {
        throw new Error("Circuit breaker is open");
      }
    }

    try {
      const result = await operation();
      
      if (this.state === "half-open") {
        this.reset();
      }
      
      return result;
    } catch (error) {
      this.recordFailure();
      throw error;
    }
  }

  private recordFailure() {
    this.failures++;
    this.lastFailureTime = Date.now();

    if (this.failures >= this.threshold) {
      this.state = "open";
    }
  }

  private reset() {
    this.failures = 0;
    this.state = "closed";
  }
}
```

### Graceful Degradation

```tsx
export function useGracefulDegradation<T>(
  primaryOperation: () => Promise<T>,
  fallback: T,
  deps: React.DependencyList
) {
  const [data, setData] = useState<T>(fallback);
  const [isUsingFallback, setIsUsingFallback] = useState(false);

  useEffect(() => {
    primaryOperation()
      .then((result) => {
        setData(result);
        setIsUsingFallback(false);
      })
      .catch((error) => {
        logger.warn(error, "Primary operation failed, using fallback");
        setData(fallback);
        setIsUsingFallback(true);
      });
  }, deps);

  return { data, isUsingFallback };
}

// Component with graceful degradation
export function UserProfile({ userId }: { userId: string }) {
  const { data: user, isUsingFallback } = useGracefulDegradation(
    () => fetchUserProfile(userId),
    { name: "Unknown User", avatar: "/default-avatar.png" },
    [userId]
  );

  return (
    <div>
      {isUsingFallback && (
        <div className="bg-yellow-50 border border-yellow-200 rounded p-2 mb-4">
          <p className="text-yellow-700 text-sm">
            Unable to load full profile. Showing basic information.
          </p>
        </div>
      )}
      <div className="flex items-center">
        <img src={user.avatar} alt={user.name} className="w-10 h-10 rounded-full" />
        <span className="ml-3">{user.name}</span>
      </div>
    </div>
  );
}
```

## Best Practices

### Error Prevention
- Use TypeScript for compile-time error checking
- Implement comprehensive input validation
- Use ESLint and proper code reviews
- Write thorough unit and integration tests
- Implement proper authentication and authorization

### Error Detection
- Set up comprehensive logging
- Use error boundaries in React components
- Implement health checks for external dependencies
- Monitor application performance and errors
- Set up alerts for critical errors

### Error Recovery
- Implement retry logic for transient failures
- Provide meaningful error messages to users
- Offer alternative workflows when possible
- Cache data to provide offline functionality
- Implement graceful degradation for non-critical features

### User Experience
- Show loading states during operations
- Provide clear error messages without technical jargon
- Offer actionable steps to resolve errors
- Maintain application state when possible
- Allow users to retry failed operations

### Monitoring and Alerting
- Log errors with sufficient context
- Set up automated alerts for critical errors
- Monitor error rates and patterns
- Track error resolution time
- Implement error budgets for reliability targets
